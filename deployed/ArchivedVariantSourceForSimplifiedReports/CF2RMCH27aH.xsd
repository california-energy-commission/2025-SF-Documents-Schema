                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Requirements for Balanced and Supply Only Ventialtion Systems (150.0(o)Civa1)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">The section is required if FaultIndicatorDisplayStatus in section A equals FactoryInstalledFID or FieldInstalledFID.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="F_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible persons signature on this document indicates the installation complies with the following requirements</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">IAQ Filter and HRV/ERV</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           IAQ filter and HRV/ERV accessibility. System air filters ad HRV/ERV heat/energy recovery cores shall be located such that they are accessible for service from within occupiable spaces, basements, garages, balconies, and mechanical closets.
Filters and heat/energy cores behind access panels, access doors, or grilles located no more than 10 feet above a walking surface inside a space specified above comply with this requirement.  
                           <ns1:line1/>
                           <ns1:b>Exception to Section 150.0(o)1Civa:</ns1:b>
                            Systems that require servicing from inside the attic shall have the following:

                           <ns1:l t="#">
                              <ns1:list> A Fault Indicator Display (FID) meeting the requirements of Reference Appendix JA17 and </ns1:list>
                              <ns1:list> An attic access door located in a wall or , where attic access is provided through a ceiling, an attic access hatch that includes an integrated ladder; and </ns1:list>
                              <ns1:list> A walkway from the attic access door to the HRV/ERV. </ns1:list>
                           </ns1:l>
                            
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">IAQ Accessibility</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">IAQ System component accessibility: Fans, motors, heat exchangers, filters and recovery cores shall meet all applicable requirements of California Mechanical Code Section 304.0 accessibility for service.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Outdoor Air Intake Design</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Outdoor air intake design: Outdoor air intakes shall compl with California Mechanical Code Section 402.4.1.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Outdoor Air Intake Location</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Outdoor air intake location and accessibility: To provide access for cleaning, outdoor air intakes shall be accessible.  Air intakes located not more than 10 feet above a walking surface comply with this requirement,  If located on roofs, they shall meet all applicable requirements of California Mechanical Code Section 304.3.1 

                           <ns1:line1/>
                            
                           <ns1:b>Exception to Section 1550.0(o)1Civd: </ns1:b>
                            Outdoor air intake serving equipment with an FID meeting requirements of Reference Appendix JA 17.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="FEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
