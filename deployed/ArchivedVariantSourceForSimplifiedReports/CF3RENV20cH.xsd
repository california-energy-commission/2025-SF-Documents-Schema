<?xml version="1.0" ?>
<xs:schema xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF3RENV20cH" version="2016.1.006">
   
    
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
    
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   

    
   <xs:element name="ComplianceDocumentPackage">
      
        
      <xs:complexType>
         
            
         <xs:sequence>
            
                
            <xs:element minOccurs="0" name="DocID">
               
                    
               <xs:complexType>
                  
                        
                  <xs:attribute fixed="CF3RENV20cH" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                        
                  <xs:attribute fixed="CERTIFICATE OF VERIFICATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                        
                  <xs:attribute fixed="Building Air Leakage Diagnostic Test - Building Enclosures and Dwelling Unit Enclosures" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
                        
                  <xs:attribute fixed="ENV20c Multi-Point Air Tightness Test" name="docVariantSubtitle" type="comp:ComplianceDocumentVariantSubtitle"/>
                  
                        
                  <xs:attribute fixed="c" name="docVariantLetter" type="comp:ComplianceDocumentVariant"/>
                  
                    
               </xs:complexType>
               
                
            </xs:element>
            
                
            <xs:element name="Payload" type="comp:Payload"/>
            
                
            <xs:element name="DocumentData">
               
                    
               <xs:complexType>
                  
                        
                  <xs:sequence>
                     
                            
                     <xs:element name="Header" type="comp:HeaderCF2R_3R"/>
                     
                            
                     <xs:element ref="cF3RENV20cH"/>
                     
                            
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                            
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF3R"/>
                     
                            
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                        
                  </xs:sequence>
                  
                    
               </xs:complexType>
               
                
            </xs:element>
            
                
            <xs:element name="Report" type="xsd:base64Binary"/>
             
            
         </xs:sequence>
         
            
         <xs:attribute fixed="rev 9/11/2013" name="revision" type="xsd:string" use="required"/>
         
            
         <xs:attribute fixed="CF3RENV20cH" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
        
      </xs:complexType>
      
    
   </xs:element>
   

   <xs:complexType name="CF3RENV20cH">
      
    
      <xs:annotation>
         
        
         <xs:documentation>Building Leakage Diagnostic Test - ENV20c Multi-Point Air Tightness Test</xs:documentation>
         
    
      </xs:annotation>
      
    
      <xs:sequence>
         
        
         <xs:element maxOccurs="1" minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Building Air Leakage - General Information</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element name="A01_AirLeakageTestProcedure" type="comp:AirLeakageTestProcedure">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Test Procedure Used</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Display text for the following possible values stored in this field:  SinglePointTestManualMeter - display text: Single-Point Test with Manual Meter    SinglePointTestAutomaticMeter - display text: Single-Point Test with Automatic Meter    MultiPointTest display text: Multi-Point Test    RepeatedSinglePointTestManualMeter - display text: Repeated Single Point with Manual Meter    RepeatedSinglePointTestAutomaticMeter - display text: Repeated Single Point with Automatic Meter</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A02_AirInfiltrationRate" type="env:AirInfiltrationRate">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Building Air Leakage Target form CF1R</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Data from project CF-1R</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A03_TestTemperatureIndoor" type="comp:TestTemperatureIndoor">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Indoor Temperature During Test  (degreeF)</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A04_TestTemperatureOutdoor" type="comp:TestTemperatureOutdoor">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Outdoor Temperature During Test  (degreeF)</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A05_BlowerDoorLocation" type="comp:BlowerDoorLocation">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Blower Door Location</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A06_Elevation" type="com:Elevation">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Building Elevation (ft)</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A07_TotalConditionedVolume" type="com:TotalConditionedVolume">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Building Volume (ft3)</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Data from project CF-1R</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="A08_TestDate" type="comp:TestDate">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Date of Diagnostic Test for this Dwelling</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
               </xs:sequence>
               
            
            </xs:complexType>
            
        
         </xs:element>
         

        
         <xs:element maxOccurs="1" minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Diagnostic Equipment Information</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element name="B01_ManometerCount" type="comp:ManometerCount">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Number of Manometers Used to Measure Home Pressurization</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If ManometerCount is greater than 1, provide a row for each manometer in ManometerCount to record its data</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="Table">
                     
            
                     <xs:complexType>
                        
            
                        <xs:sequence>
                           
              
                           <xs:element maxOccurs="unbounded" name="Row">
                              
              
                              <xs:complexType>
                                 
              
                                 <xs:sequence>
                                    

            
                                    <xs:element name="B02_ManometerMake" type="comp:ManometerMake">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Manometer Make</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B03_ManometerModel" type="comp:ManometerModel">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Manometer Model</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B04_ManometerSerialNumber" type="comp:ManometerSerialNumber">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Manometer Serial Number</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B05_ManometerCalibrationDate" type="comp:ManometerCalibrationDate">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Manometer Calibration Date</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B06_IsManometerCalibrationCurrent" type="comp:IsManometerCalibrationCurrent">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Manometer Calibration Status</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">If ManometerCalibrationDate  is within 12 months of the diagnostic TestDate in section A, then report that Manometer Calibration is valid Else report warning that Manometer Calibration is expired.</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

              
                                 </xs:sequence>
                                 
              
                              </xs:complexType>
                              
              
                           </xs:element>
                           
            
                        </xs:sequence>
                        
            
                     </xs:complexType>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="B07_FanCount" type="comp:FanCount">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Number of Fans Used to Pressurize Home</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If BlowerDoorFanCount is greater than 1, provide a row for each fan in BlowerDoorFanCount to record its data</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="Table2">
                     
            
                     <xs:complexType>
                        
            
                        <xs:sequence>
                           
              
                           <xs:element maxOccurs="unbounded" name="Row">
                              
              
                              <xs:complexType>
                                 
              
                                 <xs:sequence>
                                    

            
                                    <xs:element name="B08_FanMake" type="comp:FanMake">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Fan Make</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B09_FanModel" type="comp:FanModel">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Fan Model</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B10_FanSerialNumber" type="comp:FanSerialNumber">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Fan Serial Number</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

            
                                    <xs:element name="B11_FanConfiguration" type="comp:FanConfiguration">
                                       
                
                                       <xs:annotation>
                                          
                    
                                          <xs:documentation source="FieldText">Fan Configuration (rings)</xs:documentation>
                                          
                    
                                          <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                                          
                
                                       </xs:annotation>
                                       
            
                                    </xs:element>
                                    

              
                                 </xs:sequence>
                                 
              
                              </xs:complexType>
                              
              
                           </xs:element>
                           
            
                        </xs:sequence>
                        
            
                     </xs:complexType>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="B11After">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Env20c Variant Banner</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">ENV20c - Multi-Point Air Tightness Test</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If AirLeakageTestProcedure equals MultiPointTest , Then ENV20c - Multi-Point Air Tightness Test is the correct variant to use for the remainder of this document.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
               </xs:sequence>
               
            
            </xs:complexType>
            
        
         </xs:element>
         

        
         <xs:element maxOccurs="1" minOccurs="1" name="Section_C">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Envelope Leakage Diagnostic Test</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element name="C01_ASTM_E779_10Software" type="comp:ASTM_E779_10Software">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Name and version of ASTM E779-10 compliant software used for multi-point test.</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">maximum 50 characters</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C02_BuildingPressureReadingPreTest" type="comp:BuildingPressureReadingPreTest">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Pre-test baseline building pressure</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Resolution of 0.1 Pa</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C03_MeterTimeAveragePeriod" type="comp:MeterTimeAveragePeriod">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Time average period of meter</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Value entered by user must be no less than 10 seconds</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C04_BuildingAirLeakageTestMethod" type="comp:BuildingAirLeakageTestMethod">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Test Methodology</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C05_BuildingPressureTargetUnadjusted" type="comp:BuildingPressureTargetUnadjusted">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Unadjusted Building Pressure Target</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If BuildingAirLeakageTestMethod = Pressurization report result of adding 60 to BuildingPressureReadingPreTest ElseIf BuildingAirLeakageTestMethod = Depressurization then  report result of subtracting 60 from BuildingPressureReadingPreTest   Resolution of 0.1 Pa</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C06_BuildingPressureMeasuredUnadjusted" type="comp:BuildingPressureMeasuredUnadjusted">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Unadjusted Building Pressure Measured</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Resolution of 0.1 Pa</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C07_BuildingPressureInduced" type="comp:BuildingPressureInduced">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Induced building pressure</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Report result BuildingPressureMeasuredUnadjusted minus BuildingPressureReadingPreTest</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C08_MinReadingAcknowledge" type="comp:MinReadingAcknowledge">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">A minimum of eight readings were taken spaced evenly between 15 Pa and 60 Pa (or highest attainable pressure)</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C09_BuildingPressureReadingPostTest" type="comp:BuildingPressureReadingPostTest">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Post-test baseline building pressure</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Resolution of 0.1 Pa</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="C10_NominalCFM50" type="comp:NominalCFM50">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Corrected CFM50 (from software)</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">User entry of value calculated by the software.  Resolution of 1 CFM</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
               </xs:sequence>
               
            
            </xs:complexType>
            
        
         </xs:element>
         

        
         <xs:element maxOccurs="1" minOccurs="0" name="Section_D">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Altitude and Temperature Correction (Not used, performed by blower door software)</xs:documentation>
               
                    
               <xs:documentation source="CalculationsAndRules">This section is not used as it is performed by blower door software</xs:documentation>
               
            
            </xs:annotation>
            
        
         </xs:element>
         

        
         <xs:element maxOccurs="1" minOccurs="1" name="Section_E">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Accuracy Adjustment</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element name="E01_SoftwareTestPercentUncertainty" type="comp:SoftwareTestPercentUncertainty">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Percent Uncertainty at 95% confidence level (from software)</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">User entry of value calculated by software</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="E02_SoftwareTestAccuracy" type="comp:SoftwareTestAccuracy">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Accuracy Level</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If SoftwareTestPercentUncertainty is less than or equal to 10, report Standard, else report Reduced</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="E03_TestAccuracyFactor" type="comp:TestAccuracyFactor">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Accuracy Adjustment factor</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If SoftwareTestAccuracy is Standard report 1, Else If SoftwareTestAccuracy is Reduced report 1+ (SoftwareTestPercentUncertainty  divided by 100)</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="E04_CFM50Adjusted" type="comp:CFM50Adjusted">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Adjusted CFM50 (measured air leakage rate)</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">Report result of calculation - NominalCFM50 in section C times TestAccuracyFactor</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
               </xs:sequence>
               
            
            </xs:complexType>
            
        
         </xs:element>
         

        
         <xs:element maxOccurs="1" minOccurs="1" name="Section_F">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element name="F01_DoesBuildingAirLeakageTestComply" type="comp:DoesBuildingAirLeakageTestComply">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">If ManometerCalibrationDate in section B is within 12 months of the diagnostic TestDate in section A. and if CFM50Adjusted in section E is less than or equal to the AirInfiltrationRate in section A, then result is true.  For Boolean true value display text: Building Passes Envelope Leakage Test; Else if ManometerCalibrationDate is more than 12 months from diagnostic TestDate or if CFM50Adjusted  is more than AirInfiltrationRate then  result is false.  For Boolean false value display text:  Building Fails Envelope Leakage Test</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
               </xs:sequence>
               
            
            </xs:complexType>
            
        
         </xs:element>
         

        
         <xs:element minOccurs="1" name="Section_G">
            
            
            <xs:annotation>
               
                
               <xs:documentation source="FieldText">Additional Requirements For Compliance</xs:documentation>
               
                
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
            
               <xs:sequence>
                  

            
                  <xs:element minOccurs="0" name="G01">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Open all interior doors</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">Open all interior doors and access including those to closets and those between a conditioned basement and attic.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="G02">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">HVAC Supply and return</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">HVAC Supply and return register dampers shall be fully open.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="G03">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Temporarily sealing</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">Temporarily sealing of combustion flues and intermittent exhaust fans are not allowed.  Some examples are: combustion flues, fresh air intakes, dryer vents, bathroom and kitchen exhaust vents and fire place.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="G04">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Continuously operated ventilation</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">Continuously operated ventilation devices like energy recovery ventilators may be sealed.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="G05">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Multifamily</xs:documentation>
                        
                    
                        <xs:documentation source="AdditionalRequirements">Multifamily Each dwelling unit must be tested individually and shown to meet the leakage requirements.  Pressurization of the adjacent dwelling units while conducting this test is not allowed.</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element name="G06_DoesSystemComplyWithRequirements" type="comp:DoesSystemComplyWithRequirements">
                     
                
                     <xs:annotation>
                        
                    
                        <xs:documentation source="FieldText">Verification Status</xs:documentation>
                        
                    
                        <xs:documentation source="CalculationsAndRules">For Pass choice display text: Pass - all applicable requirements are met.  For Fail choice display text: Fail - one or more applicable requirements are not met. Enter reason for failure in corrections notes field below.  For N/A choice display text: All n/a - This entire table is not applicable</xs:documentation>
                        
                
                     </xs:annotation>
                     
            
                  </xs:element>
                  

            
                  <xs:element minOccurs="0" name="G07_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                
