<?xml version="1.0" ?>
<xs:schema xmlns:ns1="http://www.lmonte.com/besm/dtyp" xmlns:ns2="http://www.lmonte.com/besm/d" xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF3RMCH23cH" version="2025.0.000">
   
   
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   
   
   <xs:element name="ComplianceDocumentPackage">
      
      
      <xs:complexType>
         
         
         <xs:sequence>
            
            
            <xs:element minOccurs="0" name="DocID">
               
               
               <xs:complexType>
                  
                  
                  <xs:attribute fixed="CF3RMCH23cH" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                  
                  <xs:attribute fixed="CERTIFICATE OF VERIFICATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                  
                  <xs:attribute fixed="Space Conditioning System Airflow Rate" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
                  
                  <xs:attribute fixed="MCH23c Forced Air System Airflow Rate Measurement -  Alternative to Compliance with Minimum System Airflow Requirements for Altered Systems" name="docVariantSubtitle" type="comp:ComplianceDocumentVariantSubtitle"/>
                  
                  
                  <xs:attribute fixed="c" name="docVariantLetter" type="comp:ComplianceDocumentVariant"/>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Payload" type="comp:Payload"/>
            
            
            <xs:element name="DocumentData">
               
               
               <xs:complexType>
                  
                  
                  <xs:sequence>
                     
                     
                     <xs:element name="Header" type="comp:HeaderHERS"/>
                     
                     
                     <xs:element ref="cF3RMCH23cH"/>
                     
                     
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                     
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF3R"/>
                     
                     
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                  
                  </xs:sequence>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Report" type="xsd:base64Binary"/>
            
         
         </xs:sequence>
         
         
         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF3RMCH23cH" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF3RMCH23cH">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Space Conditioning System Airflow Rate - MCH23c Forced Air System Airflow Rate Measurement -  Alternative to Compliance with Minimum System Airflow Requirements for Altered Systems</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Ducted Cooling System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section MCH-01 refers to the project CF2R-MCH-01</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="A01_ResidentialCoolingSystemName" type="hvac:ResidentialCoolingSystemName">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Space Conditioning System Identification or Name</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">auto filled text: referenced from MCH-01</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Space Conditioning System Description of Area Served</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">auto filled text: referenced from MCH-01</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A03_IndoorUnitName" type="hvac:IndoorUnitName">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Indoor Unit Name</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">auto filled text: referenced from MCH-01</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A04_ImprovementStatus">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">System Installation Type</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If parent  Mch01 = MCH01b then If its B08_DuctSystemAllAccessibleForSealingWithPlus75PercentNewReplaced == true Or  B09_AllNewOrReplacedHvacSystem == true then user picks from list: New, Replacement Else user picks from list: New, Replacement, Alteration</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="hvac:ImprovementStatus">
                           
                           
                           <xs:enumeration value="Alteration"/>
                           
                           
                           <xs:enumeration value="New"/>
                           
                           
                           <xs:enumeration value="Replacement"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A05_IndoorUnitNominalCoolingCapacity" type="hvac:IndoorUnitNominalCoolingCapacity">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Nominal Cooling Capacity (tons)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field - the assigned result value cannot be overwritten by the user except for MCH23a, MCH23b, MCH23c, MCH23e, and MCH23f If parent is MCH01d and specific condition allows it. If MCH01's  ResidentialCoolingSystemType == NoCooling  result = N/A stored in the NotApplicableMessage and display text: N/A - Heating-only system;  Else Switch (parent MCH01 fields)  case MCH-01a:  If duct system in M03 has value in D06_IndoorUnitsCount GT 1 And the system type in D04_ResidentialHeatingSystemType or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, Or VCHP_IndoorUnitDuctedAndDuctless , then result = MCH-01a G10_IndoorUnitNominalCoolingCapacity;   Else If section F IsPresent  And not HP system result = MCH-01a F09_CondenserNominalCoolingCapacity; Else If section I IsPresent  And is HP system result = MCH-01a field I10_CondenserNominalCoolingCapacity.  case MCH01b: If duct system in J03 has value in C12_IndoorUnitsCount GT 1 And system type in C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType ==  VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, Or VCHP_IndoorUnitDuctedAndDuctless  then If section F IsPResent (LT 75% of duct system altered) result = MCH-01b field F12_IndoorUnitNominalCoolingCapacity; Else If section G IsPresent (new or complete replaced duct system), result = G15_IndoorUnitNominalCoolingCapacity;  Else result = MCH-01b field E09_CondenserNominalCoolingCapacity.  case MCH-01c: If duct system in L03 has C11_IndoorUnitsCount GT 1 And  the system type in C04_ResidentialHeatingSystemType or C05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, Or VCHP_IndoorUnitDuctedAndDuctless, then result = F10_IndoorUnitNominalCoolingCapacity; Else If section E IsPresent  and not HP system result = E09_CondenserNominalCoolingCapacity; Else If section H IsPresent  and is HP system result = H10_CondenserNominalCoolingCapacity.  case Mch01d: If duct system in O03 has D06_IndoorUnitsCount GT 1  And the system type in D04_ResidentialHeatingSystemType or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, Or VCHP_IndoorUnitDuctedAndDuctless  Then If section K IsPresent (LT 75% of duct system altered) result = K12_IndoorUnitNominalCoolingCapacity; Else If section L IsPresent (new or complete replaced duct system), result = L15_IndoorUnitNominalCoolingCapacity; Else If section G IsPresent and not HP system result = G09_CondenserNominalCoolingCapacity; Else If section J IsPresent  and is HP system result = J10_ CondenserNominalCoolingCapacity;
Else If D05_ResidentialCoolingSystemType != NoCooling And value could not be found in parent MCH01d, allow user input  End If
End Switch  End If</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A05_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Nominal Cooling Capacity (tons)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If MCH01's  ResidentialCoolingSystemType == NoCooling  result = N/A stored in the NotApplicableMessage and display text: N/A - Heating-only system;</xs:documentation>
                           
                           
                           <xs:appinfo source="displayterm">
                              
                              
                              <ns1:displayterm value="N/A">N/A - Heating-only system</ns1:displayterm>
                              
                           
                           </xs:appinfo>
                           
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A06_CondenserSpeedType" type="hvac:CondenserSpeedType">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Condenser Speed Type</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If MCH01's  ResidentialCoolingSystemType == NoCooling  result =  N/A stored in the NotApplicableMessage and display term: N/A - Heating-only system;  Else If  condenser speed type is not given on the MCH-01, result = N/A stored in the NotApplicableMessage and display text:  N/A - Condenser Speed requirements do not apply.   Else store and display value for Condenser Speed Type given on the  MCH-01 which will be one of these options: MultiSpeed; or SingleSpeed</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A06_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Condenser Speed Type</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If MCH01's  ResidentialCoolingSystemType == NoCooling  result =  N/A stored in the NotApplicableMessage and display term: N/A - Heating-only system;  Else If  condenser speed type is not given on the MCH-01, result = N/A stored in the NotApplicableMessage and display text:  N/A - Condenser Speed requirements do not apply.   Else store and display value for Condenser Speed Type given on the  MCH-01 which will be one of these options: MultiSpeed; or SingleSpeed</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A07_ResidentialCoolingZoneType" type="hvac:ResidentialCoolingZoneType">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Cooling System Zonal Control Type</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If MCH01's  ResidentialCoolingSystemType == NoCooling  result = N/A stored in the NotApplicableMessage and display term N/A - Heating-only system;   Else If the  MCH-01 has no value for ResidentialCoolingZoneType  result = N/A stored in the NotApplicableMessage  and display text: N/A - Cooling System Zonal Control requirements do not apply;   Else result = MCH-01 ResidentialCoolingZoneType value which is one the following: ZoneControlled display term Zonally Controlled and NotZoneControlled display term Not Zonal</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A07_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Cooling System Zonal Control Type</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If MCH01's  ResidentialCoolingSystemType == NoCooling  result = N/A stored in the NotApplicableMessage and display term N/A - Heating-only system;   Else If the  MCH-01 has no value for ResidentialCoolingZoneType  result = N/A stored in the NotApplicableMessage  and display text: N/A - Cooling System Zonal Control requirements do not apply;   Else result = MCH-01 ResidentialCoolingZoneType value which is one the following: ZoneControlled display term Zonally Controlled and NotZoneControlled display term Not Zonal</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="A08_IsVentilationSystemCFI" type="comp:IsVentilationSystemCFI">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Central  Fan Integrated (CFI) Ventilation System Status</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: reference value from MCH-01, allowable values: true display term CFI System  and false display term Not a CFI System</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A09_HasBypassDuct" type="hvac:HasBypassDuct">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">System Bypass Duct Status</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If parent is MCH-01b,MCH-01c or MCH-01d result = N/A in the NotApplicableMessage;  elseif parent is MCH-01a, result =  MCH-01a J10 HasBypassDuct;  allowable values: true display term Has Bypass Duct and false display term  No Bypass Duct</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A09_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">System Bypass Duct Status</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If parent is MCH-01b,MCH-01c or MCH-01d result = N/A in the NotApplicableMessage;  elseif parent is MCH-01a, result =  MCH-01a J10 HasBypassDuct;  allowable values: true display term Has Bypass Duct and false display term  No Bypass Duct</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="A10_AirflowRateMeasurementDate" type="comp:AirflowRateMeasurementDate">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Date of System Airflow Rate Measurement</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">user input: date: use validated date format</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A11_AirflowRateMeasurementProtocol" type="comp:AirflowRateMeasurementProtocol">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Airflow Rate Protocol Utilized</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  A04_ImprovementStatus == New or Replacement result = AirflowRateProtocolRA3_3 display term RA3.3 procedures for airflow rate measurement.     Else A04_ImprovementStatus == Alteration user selects from list:  AirflowRateProtocolRA3_3 with display term  RA3.3 procedures for airflow rate measurement.   and   AirflowRateProtocolAlternativeCompliance display term  RA3..3.3.1.5 Alternative to Compliance with Minimum System Airflow Requirements.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A12_CFVCS_Type" type="comp:CFVCS_Type">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Central Fan Ventilation Cooling System Status</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If parent MCH01 = MCH01b Or MCH01c result = NotCFVCS display term Not a CFVC; Else (parent MCH01a Or MCH01d) If B05_CFVCS_Type== VariableCFVCS  result = VariableCFVCS display term Variable  CFVCS, Else If B05_CFVCS_Type== FixedCFVCS  result = FixedCFVCS display term Fixed CFVCS; Else result = NotCFVCS display term Not a CFVC.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Hole for the placement of a Static Pressure Probe (HSPP), and Permanently Installed Static Pressure Probe (PSPP) in the Supply Plenum.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="B_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Procedures for installing HSPP or PSPP are specified in RA3.3.1.1.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="B01_HSPP_PSPP_ComplianceMethod" type="comp:HSPP_PSPP_ComplianceMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Method Used to Demonstrate Compliance with the HSPP/PSPP Requirement</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list: HSPP_InstalledAsRequired  display term  HSPP installed and labeled consistent with Figure RA3.3-1.   PSPP_InstalledAsRequired   display term  PSPP installed and labeled consistent with Figure RA3.3-1.  HSPP_PSPP_InstalledAlternativeLocation display term HSPP/PSPP cannot be installed consistent with Figure RA3.3-1.  An alternative location has been provided and clearly labeled.    HSPP_PSPP_NotApplicable  display term HSPP/PSPP  are not applicable to this system.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Airflow Rate Measurement Apparatus and Procedure Information</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="C_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Instrument Specifications are given in RA3.3.1.1, and system airflow rate measurement apparatus information is given in RA3.3.2.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C01_AirflowRateMeasurementType" type="comp:AirflowRateMeasurementType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Airflow Rate Measurement Type used for this airflow rate verification.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list:  FanFlowmeter display term Fan Flowmeter according to procedure in RA3.3.3.1.1      FlowGrid  display term  Flow Grid according to procedure in RA3.3.3.1.2  PoweredFlowCaptureHood  display term Powered Flow Capture Hood according to procedure in RA3.3.3.1.3.  TraditionalFlowCaptureHood  display term Traditional Flow Capture Hood according to procedure in RA3.3.3.1.4.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C02_AirflowMeasuringDeviceManufacturer" type="comp:AirflowMeasuringDeviceManufacturer">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Manufacturer of Airflow Measurement Apparatus</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: text  (or consider referencing data from a data registry user profile)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C03_AirflowMeasuringDeviceModelNumber" type="comp:AirflowMeasuringDeviceModelNumber">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Model number of Airflow Measurement Apparatus</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: text.  Or consider referencing data from a data registry user profile</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C04_IsAirflowMeasurementDeviceCertified" type="comp:IsAirflowMeasurementDeviceCertified">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Certification Status of the Airflow Measurement Apparatus Accuracy</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input:   For Boolean value true,  display text: Certified by Manufacturer and listed on CEC Website athttp://www.energy.ca.gov/title24/equipment_cert/ama_fas/index.html..  For Boolean value false, displayed text: Not Certified (do not continue)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C04After">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">MCH-23c Variant</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">MCH23c  Forced Air System Airflow Rate Measurement -  Alternative to Compliance with Minimum System Airflow Requirements for Altered Systems</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field that establishes which variant to use; FIRST CALC for variant result  If A11_AirflowRateMeasurementProtocol == AirflowRateProtocolAlternativeCompliance If A04_ImprovementStatus == Alteration variant result = MCH-23c;  Else If A11 == AirflowRateProtocolRA3_3 Then If A04_ImprovementStatus == Alteration Then If A12_CentralFanVentilationCoolingType =! NotCFVCS  variant result = MCH-23e; Else variant result = MCH-23a.    SECOND CALC for variant result If A07_ResidentialCoolingZoneType  == ZoneControlled: Switch (A06_CondenserSpeedType) case SingleSpeed: If A12_CentralFanVentilationCoolingType =! NotCFVCS  variant result = MCH-23f Else variant result = MCH-23b;  case MultiSpeed: If A12_CentralFanVentilationCoolingType =! NotCFVCS  variant result = MCH-23e Else variant result = MCH-23a.   THIRD CALC for variant result If A07_ResidentialCoolingZoneType  == NotZoneControlled:  If ResidentialCoolingSystemType on MCH-01 == NoCooling And A08_ IsVentilationSystemCFI == true Or A12_CentralFanVentilationCoolingType =! NotCFVCS, variant result = MCH-23d;  Else  If A04_ImprovementStatus == New or Replacement Then If A12_CentralFanVentilationCoolingType =! NotCFVCS  variant result = MCH-23e Else variant result = MCH-23a.  FOURTH CALC for variant result If A07_NotApplicableMessage == N/A:  If A04_ImprovementStatus == New or Replacement, Then If ResidentialCoolingSystemType on MCH-01 == NoCooling And A08_IsVentilationSystemCFI == true Or A12_CentralFanVentilationCoolingType =! NotCFVCS, variant result = MCH-23d Else If   A12_CentralFanVentilationCoolingType =! NotCFVCS, variant result = MCH-23e Else variant result = MCH-23a.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_D">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Alternative to Compliance with Minimum System Airflow Requirements for Altered Systems</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="D_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The HERS Rater shall review the information submitted on the installation certificate and perform follow-up communications with the HVAC installer or the homeowner. The system complies if the HERS Rater determines the remedial actions have been performed, and the information reported on the installation certificate is valid as specified in RA3.3.3.1.5</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D01_IsAirFilterMediaCheckCompleted" type="comp:IsAirFilterMediaCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Determine that the air filter media is clean. If the air filter media is dirty, then replace it with clean filter media</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D02_IsRegistersDampersCheckCompleted" type="comp:IsRegistersDampersCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Open all registers and dampers and remove any obstructions.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D03_IsDuctRepairCheckCompleted" type="comp:IsDuctRepairCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Replace/Repair all accessible crushed, blocked, restricted, remove excess length, and sharp bends in ducts.  Supported every 4 ft max. with a max. 2 in sag.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D04_IsEvaporatorCoilCheckCompleted" type="comp:IsEvaporatorCoilCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Clean the evaporator coil according to the manufacturer and ensure the coil is not obstructed.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D05_IsAirHandlerFanCheckCompleted" type="comp:IsAirHandlerFanCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air handler fan speed set to high and blower wheel and motor are operating properly.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D06_IsReturnDuctSizingCheckCompleted" type="comp:IsReturnDuctSizingCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">If determined to be too small, replace the return duct with a larger one and/or add a second return duct.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D07_IsReturnGrilleSizingCheckCompleted" type="comp:IsReturnGrilleSizingCheckCompleted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">If determined to be too small, replace the return grille with a larger area grille.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, For Boolean  true value display text choice: Completed  For Boolean false value display text choice:  Not Completed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D08_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">If any of the above were not completed list the Action Required and a description of why the action could not be completed:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input, text, maximum 500 characters</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D09_DoesForcedAirSystemPassAlternativeComplianceRequirements" type="comp:DoesForcedAirSystemPassAlternativeComplianceRequirements">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification Status:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: 
If D01-D07 values all == true then 
result = true display term System Complies;   
 
Else If D08_SectionCorrectionNotes NotNull and has an explanation
result =  true display term System Complies;
 
Else result = false, display term System Does Not Comply:  one or more applicable remedial actions were not completed as required.  Enter reason(s) for non-compliance in corrections notes field below.
 
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="D10_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Correction Notes:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If Verification Status == false, then text entry in this Corrections Notes field is required as condition of registration of the failure;  user input text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="D11_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Optional Notes:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Response is optional:  user input text.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="DEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met unless otherwise noted in the Verification Status and the Corrections Notes in this table.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Forced Air System Airflow Rate Measurement - Best Airflow Rate Attainable</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section MCH-01 refers to the project CF2R-MCH-01</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="E_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The procedures for System Airflow Rate Verification are specified in Reference Residential Appendix RA3.3.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="E01_AirflowPerUnitCoolingCapacity" type="hvac:AirflowPerUnitCoolingCapacity">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Required Minimum System Airflow Rate (cfm/ton)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If parent Mch01 ResidentialCoolingSystemType == SmallDuctHighVelocityAC Or  SmallDuctHighVelocityHP  result =250 Else result = 300;</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="E02_AirflowRequiredMinimumTarget" type="hvac:AirflowRequiredMinimumTarget">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Required Minimum System Airflow Target (cfm)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: result =  PRODUCT (A05_IndoorUnitNominalCoolingCapacity,  E01_AirflowPerUnitCoolingCapacity)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="E03_AirflowMeasuredRate" type="hvac:AirflowMeasuredRate">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Actual System Airflow Rate Measurement (cfm)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input numeric value: xxxx</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="E04_DoesForcedAirSystemAirflowRateComply" type="comp:DoesForcedAirSystemAirflowRateComply">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Compliance Statement:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If E03_AirflowMeasuredRate GTE E02_AirflowRequiredMinimumTarget, result = true display term    System airflow rate complies.  Else result is false display term  The measured Airflow Rate reported on this document is the best airflow rate attainable for compliance utilizing the procedures given in  RA3.3.3.1.5. This system shall not be included in a sample group for HERS verification compliance.</xs:documentation>
                        
                        
                        <xs:appinfo source="displayterm">
                           
                           
                           <ns1:displayterm value="false">The measured Airflow Rate reported on this document is the best airflow rate attainable for compliance utilizing the procedures given in  RA3.3.3.1.5. This system shall not be included in a sample group for HERS verification compliance
</ns1:displayterm>
                           
                        
                        </xs:appinfo>
                        
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="E05_IsEligibleForSampleGroup" type="comp:IsEligibleForSampleGroup">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">HERS Sample Group Eligibility</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If E04_DoesForcedAirSystemAirflowRateComply ==  true then result = true display term Eligible for HERS sample group;  Else result = false display term Not Eligible for HERS Sample Group for Airflow.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Additional Requirements</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="F01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Filters Installed properly</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Air filters that meet the applicable requirements of Standards Section 150.0(m)12 or 150.0(m)13 were properly installed in the system during system air flow rate measurement identified on this Certificate of Verification.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="1" minOccurs="0" name="F02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Airflow rate measurement apparatus certified</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The airflow rate measurement apparatus used to perform the airflow rate measurement identified on this Certificate of Verification was calibrated in accordance with the apparatus manufacturer's specifications and conforms to the instrumentation specifications given in RA3.3.1.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Bypass Duct</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           A visual inspection shall confirm that bypass ducts that deliver conditioned supply air directly to the space conditioning system return duct airflow are not used on 
                           <ns2:u> newly constructed</ns2:u>
                            zonally controlled systems unless the Performance Certificate of Compliance indicates an allowance for use of a bypass duct.  When a bypass duct is accounted for on the Performance Certificate of Compliance, the airflow rate shall conform to the specifications listed on the Certificate of Compliance.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="1" minOccurs="0" name="F04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">All registers fully open</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All registers were fully open during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">System fan testing speed</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">System fan was set at maximum speed during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Fresh Air Duct</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">If fresh air duct is part of the HVAC system it was not closed during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Fan Efficacy tested value</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Airflow rate and fan watt draw shall be simultaneous measurements when used to calculate the Fan Efficacy tested value.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F08">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Multi-speed compressor</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Multi-speed compressor space cooling systems or variable speed compressor systems shall verify air flow (cfm/ton) and fan efficacy (Watt/cfm) with system operating in cooling mode at the maximum compressor speed and the maximum air handler fan speed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F09">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Alternate systems using remedial actions</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">For altered systems that do not comply with the minimum 300 cfm per ton airflow rate requirement but opt to comply using the remedial actions on this MCH-23 compliance document according to Section RA3.3.3.1.5 the system's thermostat shall conform to the specifications in Reference Joint Appendix JA5 and shall be capable of receiving and responding to Demand Response Signals prior to final approval of the building permit by the enforcing agency (Section 150.2(b)1Fia).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F10_DoesSystemComplyWithRequirements" type="comp:DoesSystemComplyWithRequirements">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification Status:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">For Pass choice display text: Pass - all applicable requirements are met.  For Fail choice display text: Fail - one or more applicable requirements are not met. Enter reason for failure in corrections notes field below.  For N/A choice display text: All n/a - This entire table is not applicable</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F11_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Correction Notes:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If Verification Status= Fail, then text entry in this Corrections Notes field is required</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="FEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met unless otherwise noted in the Verification Status and the Corrections Notes in this table.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Determination of HERS Verification Compliance</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="G_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All applicable sections of this document shall indicate compliance with the specified verification protocol requirements in order for this Certificate of Verification as a whole to be determined to be in compliance.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="G01_DoesCF3R_Pass" type="comp:DoesCF3R_Pass">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If  B01_HSPP_PSPP_ComplianceMethod =! HSPP_PSPP_NotInstalled; and C04_IsAirflowMeasurementDeviceCertified == true; and D09_DoesForcedAirSystemPassAlternativeComplianceRequirements == true and F10_DoesSystemComplyWithRequirements  == Pass or N/A  then result = true display term  Complies: All specified verification protocol requirements on this document are met;  Else result = false display term  Does not comply: One or more specified verification protocol requirements on this document are not met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
      
      </xs:sequence>
      
   
   </xs:complexType>
   
   
   <xs:element name="cF3RMCH23cH" type="CF3RMCH23cH">
      
      
      <xs:annotation>
         
         
         <xs:documentation>This element contains all of the data and text required to generate the CF3RMCH23cH compliance report.</xs:documentation>
         
      
      </xs:annotation>
      
   
   </xs:element>
   

</xs:schema>
