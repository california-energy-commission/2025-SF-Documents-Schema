                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="B11After">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Mch24a Variant Banner</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">MCH24a - Single Point Air Tightness Test With Manual Meter</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Enclosure Air Leakage Diagnostic Test</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="C01_MeterTimeAveragePeriod" type="comp:MeterTimeAveragePeriod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Time Average Period of Meter (seconds)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input integer GTE  10 seconds</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C02_BuildingAirLeakageTestMethod" type="comp:BuildingAirLeakageTestMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test Methodology</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list: Pressurization, Depressurization</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C03_BuildingPressureReadingPreTest" type="comp:BuildingPressureReadingPreTest">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pre-test Baseline Enclosure Pressure (Pa) (may be positive or negative)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input numeric xx.x in InclusiveRange(-40, 40)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C04_BuildingPressureTargetUnadjusted" type="comp:BuildingPressureTargetUnadjusted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Unadjusted Enclosure Pressure Target (Pa)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Pressurization result = SUM (50, C03_  BuildingPressureReadingPreTest )  Else result = SUM (-50, C03_  BuildingPressureReadingPreTest )  (resolution of 0.1)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C05_BuildingPressureMeasuredUnadjusted" type="comp:BuildingPressureMeasuredUnadjusted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Unadjusted Enclosure Pressure Measured (Pa) (Pressurization is positive; Depressurization is negative)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input numeric xx.x in InclusiveRange(-75, 75)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C06_InducedEnclosurePressureDifference" type="comp:InducedEnclosurePressureDifference">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Induced Enclosure Pressure Difference (Pa) Goal = 50 +- 3 (Pressurization is positive; Depressurization is negative)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: result =  C05_BuildingPressureMeasuredUnadjusted - C03_BuildingPressureReadingPreTest</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C07_IsInducedPressureWithinRange" type="comp:IsInducedPressureWithinRange">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Induced Enclosure Pressure Check</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If ABS  ( C06_InducedEnclosurePressureDifference) GTE 15 Pa, result = true.  display term Induced pressure within range for single point test.  Else result = false display term Induced pressure is too low for single point test.   Do Not Proceed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C08_NominalFanFlow" type="comp:NominalFanFlow">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Measured Nominal Fan Flow at Above Fan Pressure (cfm) at the Induced Enclosure Pressure Difference (in C06 above)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input  integer (resolution of 1 CFM)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C09_NominalCFM50" type="comp:NominalCFM50">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Calculated Nominal CFM50</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated Field: PRODUCT (C08_NominalFanlow, (50 / ABS(C06_InducedEnclosurePressureDifference )) exp 0.65)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_D">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Altitude and Temperature Correction</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="Calculations">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">NOT REPORTED IN PDF</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Da1_OutdoorAirViscosityCorrection" type="comp:OutdoorAirViscosityCorrection">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Outdoor Dynamic Viscosity of Air Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Depressurization result = 2.629 * 10^-3 * ((A05_TestTemperatureOutdoor+460)^0.5 / (1+(198.7 /  (A05_TestTemperatureOutdoor+460)))); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                              
                              <xs:element name="Da1_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Outdoor Dynamic Viscosity of Air Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Depressurization result = 2.629 * 10^-3 * ((A05_TestTemperatureOutdoor+460)^0.5 / (1+(198.7 /  (A05_TestTemperatureOutdoor+460)))); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Da2_IndoorAirViscosityCorrection" type="comp:IndoorAirViscosityCorrection">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Indoor Dynamic Viscosity of Air Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Pressurization result =2.629 * 10^-3 * ((A04_TestTemperatureIndoor+460)^0.5 / (1+(198.7 /  (A04_TestTemperatureIndoor+460))));   Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                              
                              <xs:element name="Da2_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Indoor Dynamic Viscosity of Air Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Pressurization result =2.629 * 10^-3 * ((A04_TestTemperatureIndoor+460)^0.5 / (1+(198.7 /  (A04_TestTemperatureIndoor+460))));   Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Da3_OutdoorAirDensityCorrection" type="comp:OutdoorAirDensityCorrection">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Outdoor Air Density Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Depressurization result = 0.07517 * (1-((0.0035666 * A07_Elevation)/528))^(5.2553) * (528/(A05_TestTemperatureOutdoor+460)); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                              
                              <xs:element name="Da3_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Outdoor Air Density Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Depressurization result = 0.07517 * (1-((0.0035666 * A07_Elevation)/528))^(5.2553) * (528/(A05_TestTemperatureOutdoor+460)); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Da4_IndoorAirDensityCorrection" type="comp:IndoorAirDensityCorrection">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Indoor Air Density Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Pressurization result = 0.07517 * (1-((0.0035666 * A07_Elevation)/528))^(5.2553) * (528/(A04_TestTemperatureIndoor+460)); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                              
                              <xs:element name="Da4_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Indoor Air Density Correction</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">Calculated field: If C02_BuildingAirLeakageTestMethod == Pressurization result = 0.07517 * (1-((0.0035666 * A07_Elevation)/528))^(5.2553) * (528/(A04_TestTemperatureIndoor+460)); Else result = N/A</xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D01_AltitudeTemperatureCorrectionFactor" type="comp:AltitudeTemperatureCorrectionFactor">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Altitude and Temperature Correction Factor</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  If C02_BuildingAirLeakageTestMethod == Depressurization result = (Da1_OutdoorAirVicosityCorrection / 0.044)^(2* 0.65-1) * (Da3_OutdoorAirDensityCorrection / 0.07517) ^(1-(0.65));  Else  If C02_BuildingAirLeakageTestMethod == Pressurization result =  (Da2_IndoorAirVicosityCorrection / 0.044)^(2 * 0.65-1) * (Da4_IndoorAirDensityCorrection / 0.07517)^(1-(0.65))</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D02_CFM50TempAltCorrected" type="comp:CFM50TempAltCorrected">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Corrected CFM50</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  PRODUCT (C09_NominalCFM50,  D01_AltitudeTemperatureCorrectionFactor)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D03_ACH50" type="comp:ACH50">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">ACH50</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  ((D02_CFM50TempAltCorrected * 60) div Dwelling Unit Volume from A13_BuildingTotalVolume}</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Accuracy Adjustment</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="E01_CFM50Adjusted" type="comp:CFM50Adjusted">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Adjusted CFM50 (measured air leakage rate)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: PRODUCT (D02_CFM50TempAltCorrected, 1.1)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Measured Enclosure Air Leakage Rate</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="F01_AirLeakageRateMeasuredACH50" type="comp:AirLeakageRateMeasuredACH50">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Enclosure Air Leakage Rate is: (ACH50)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">
                              If B06_IsManometerCalibrationCurrent == false result = false stored in F01_IsManometerCalibrationCurrent display term Manometer Calibration is expired. A manometer with current calibration is required in order to comply with this Enclosure Air Leakage worksheet    Else If A01_IsEnvelopeAirLeakageHERSVerificationRequired == true, Then result =  (E01_CFM50Adjusted x 60) /  Dwelling Unit Volume from A13_BuildingTotalVolume  and stored in F01_AirLeakageRateMeasuredACH50  and display text: Enclosure Air Leakage Rate is (result) ACH
                              <ns2:sub>50</ns2:sub>
                              ; Else If A02_CompartmentilizationLeakageVerificationRequiredHERS == true Then result = E01_CFM50Adjusted  stored in F01_AirLeakageRateMeasuredCFM50.
                           </xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="F01_AirLeakageRateMeasuredCFM50" type="comp:AirLeakageRateMeasuredCFM50">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Enclosure Air Leakage Rate is:  (CFM50)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">
                              If B06_IsManometerCalibrationCurrent == false result = false stored in F01_IsManometerCalibrationCurrent display term Manometer Calibration is expired. A manometer with current calibration is required in order to comply with this Enclosure Air Leakage worksheet    Else If A01_IsEnvelopeAirLeakageHERSVerificationRequired == true, Then result =  (E01_CFM50Adjusted x 60) /  Dwelling Unit Volume from A13_BuildingTotalVolume  and stored in F01_AirLeakageRateMeasuredACH50  and display text: Enclosure Air Leakage Rate is (result) ACH
                              <ns2:sub>50</ns2:sub>
                              ; Else If A02_CompartmentilizationLeakageVerificationRequiredHERS == true Then result = E01_CFM50Adjusted  stored in F01_AirLeakageRateMeasuredCFM50.
                           </xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="F01_IsManometerCalibrationCurrent" type="comp:IsManometerCalibrationCurrent">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Manometer Calibration is expired.</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">
                              If B06_IsManometerCalibrationCurrent == false result = false stored in F01_IsManometerCalibrationCurrent display term Manometer Calibration is expired. A manometer with current calibration is required in order to comply with this Enclosure Air Leakage worksheet    Else If A01_IsEnvelopeAirLeakageHERSVerificationRequired == true, Then result =  (E01_CFM50Adjusted x 60) /  Dwelling Unit Volume from A13_BuildingTotalVolume  and stored in F01_AirLeakageRateMeasuredACH50  and display text: Enclosure Air Leakage Rate is (result) ACH
                              <ns2:sub>50</ns2:sub>
                              ; Else If A02_CompartmentilizationLeakageVerificationRequiredHERS == true Then result = E01_CFM50Adjusted  stored in F01_AirLeakageRateMeasuredCFM50.
                           </xs:documentation>
                           
                           
                           <xs:appinfo source="displayterm">
                              
                              
                              <ns1:displayterm value="false"> Manometer Calibration is expired. A manometer with current calibration is required in order to comply with this Enclosure Air Leakage worksheet</ns1:displayterm>
                              
                           
                           </xs:appinfo>
                           
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Additional Requirements For Worksheet Compliance</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="G01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The procedure for preparing the enclosure for testing is detailed in RESNET 380-2016 Section 3.2.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="G02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">When multifamily attached dwelling units must comply with the maximum dwelling unit enclosure air leakage specified in Standards Section 150.0(o)1Eii, the test shall be conducted with the dwelling unit as if it were exposed to the outdoor air on all sides, top and bottom by opening doors and windows of adjacent dwelling units as specified by RA3.8.3.1.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="G03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The test procedure for installation of the test apparatus, and preparations for measurement shall conform to RESNET 380-2016 Section 3.3</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="G04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The procedure for the conduct of the enclosure air leakage test shall conform to the One-Point Airtightness Test specified in RESNET 380-2016 Section 3.4.1</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
      
      </xs:sequence>
      
   
   </xs:complexType>
   
   
   <xs:element name="cF3RMCH24aH" type="CF3RMCH24aH">
      
      
      <xs:annotation>
         
         
         <xs:documentation>This element contains all of the data and text required to generate the CF3RMCH24aH compliance report.</xs:documentation>
         
      
      </xs:annotation>
      
   
   </xs:element>
   

</xs:schema>
