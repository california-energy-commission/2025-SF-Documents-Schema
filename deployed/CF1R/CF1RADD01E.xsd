                                          <xs:documentation source="FieldText">Exterior Shading Device</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list; Choices:  DropArmAwnings, LouveredSunScreen, LowSunAngleLouveredSunScreen,  OperableAwnings, Overhang, RetractableAwnings, RollDownBlindsOrSlats, StandardBugScreen, SunScreen, VerticalRollerOrShades and NoExternalShadingDevice</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
