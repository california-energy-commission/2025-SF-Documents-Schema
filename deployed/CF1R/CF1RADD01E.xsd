                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E02_NotApplicablemessage == N/A result = N/A stored in NotApplicablemessage Else Switch ( E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone == 16 result = R7; Else If A09_ClimateZone == InRange(1,15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised:  If A09_ClimateZone == 1,2,11,13,14 Or 16 result = R8; Else If A09_ClimateZone == InRange(3,10) result = R0; Else If A09_ClimateZone == 12 Or 15 result = R4;  case SlabHeated: If A09_ClimateZone == InRange(1,15) result = R5; Else If A09_ClimateZone == 16, user selects:  R10 vertical  Or  R10 vertical and R7 horizontal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E02_NotApplicablemessage == N/A result = N/A stored in NotApplicablemessage Else Switch ( E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone == 16 result = R7; Else If A09_ClimateZone == InRange(1,15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised:  If A09_ClimateZone == 1,2,11,13,14 Or 16 result = R8; Else If A09_ClimateZone == InRange(3,10) result = R0; Else If A09_ClimateZone == 12 Or 15 result = R4;  case SlabHeated: If A09_ClimateZone == InRange(1,15) result = R5; Else If A09_ClimateZone == 16, user selects:  R10 vertical  Or  R10 vertical and R7 horizontal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E05_SlabInsulationUFactorRequired" type="env:SlabInsulationUFactorRequired">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E03_NotApplicablemessage == N/A result = N/A stored in NotApplicablemessage Else Switch ( E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone == 16 result = 0.58; Else If A09_ClimateZone == InRange(1,15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised:  If A09_ClimateZone == 1,2,11,13,14 Or 16 result = 0.092; Else If A09_ClimateZone == InRange(3,10) result = 0.269; Else If A09_ClimateZone == 12 Or 15 result = 0.138;  case SlabHeated: result = N/A stored in NotApplicableMessage.  Note: Range check, value in E03 must be less than or equal to E05 (both can be N/A) in order to comply.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E03_NotApplicablemessage == N/A result = N/A stored in NotApplicablemessage Else Switch ( E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone == 16 result = 0.58; Else If A09_ClimateZone == InRange(1,15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised:  If A09_ClimateZone == 1,2,11,13,14 Or 16 result = 0.092; Else If A09_ClimateZone == InRange(3,10) result = 0.269; Else If A09_ClimateZone == 12 Or 15 result = 0.138;  case SlabHeated: result = N/A stored in NotApplicableMessage.  Note: Range check, value in E03 must be less than or equal to E05 (both can be N/A)  in order to comply.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="E06_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input: Text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Radiant Barrier (Section 150.1(c).2)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable If A09_ClimateZone is in InclusiveRange (2, 15)And  If A13_ProjectScopeAddition includes at least one of the following: AdditionLTE300, AdditionGT300LTE400, AdditionGT400LTE700, AdditionGT700LTE1000,  AdditionLTE300ADU, AdditionGT300LTE400ADU, AdditionGT400LTE700ADU, Or AdditionGT700LTE1000ADU.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="FBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Notes: A radiant barrier is required (for Climate Zones 2-15)</ns1:b>
                            
                           <ns1:l t="*">
                              <ns1:list>Radiant barriers shall meet specific eligibility and installation criteria to receive energy credit for compliance with the Building Energy Efficiency Standards for low-rise residential buildings.  Refer to Reference Appendices, Residential Appendix RA4.2.1.</ns1:list>
                               
                              <ns1:list>The emittance of the radiant barrier shall be less than or equal to 0.05 as tested in accordance with American Society for Testing and Materials (ASTM) C1371 or ASTM E408.</ns1:list>
                               

                              <ns1:list>
                                 For Prescriptive Compliance the attic shall be ventilated to provide a minimum free ventilation area of not less than 1 square foot (ft
                                 <ns1:sup>2</ns1:sup>
                                  of vent area for each 300 square feet ft
                                 <ns1:sup>2</ns1:sup>
                                  of attic floor area with a minimum of 30 percent upper vents. Refer to Reference Appendices, Residential Appendix, RA4.2.1 
                              </ns1:list>
                               
                              <ns1:list>Ridge vents or gable end vents are recommended to achieve the best performance. The material should be cut to allow for full airflow to the venting. Refer to Reference Appendices, Residential Appendix, RA4.2.1.1  </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="F01_RadiantBarrierRequired" type="comp:RadiantBarrierRequired">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Radiant Barrier installed below the roof deck and on all gable end walls</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">User selects from: Yes (Boolean true) or No  (Boolean false) Or N/A stored in NotApplicableMessage.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="F01_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Radiant Barrier installed below the roof deck and on all gable end walls</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">User selects from: Yes (Boolean true) or No  (Boolean false) Or N/A stored in NotApplicableMessage.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element minOccurs="0" name="F02_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comments</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If F01_NotApplicablemessage = N/A, require user input: Text; Else optional input</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Roofing Products (Cool Roof)  (Section 150.1(c).11)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable If A13_ProjectScopeAddition includes at least one of the following: AdditionGT300LTE400, AdditionGT400LTE700,  AdditionGT300LTE400ADU, AdditionGT400LTE700ADU, Or AdditionGT700LTE1000ADU.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="GBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Notes:</ns1:b>
                            
                           <ns1:l t="*">
                              <ns1:list>Exception 1 Any roof area covered by building integrated photovoltaic (PV) panels and solar thermal panels are not required to comply with the Cool Roof requirements</ns1:list>
                              <ns1:list>
                                  Exception 2: Roof construction with a weight of 25 pounds per square foot  (lb/ft
                                 <ns1:sup>2</ns1:sup>
                                 ) are also not required to comply with the Cool Roof requirements. 
                              </ns1:list>
                              <ns1:list>Liquid field applied roof coatings must comply with installation criteria from Section 110.8(i)4</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableRoofing">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="G01_PartitionName" type="env:PartitionName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input: ObjectNamePermissive</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G02_CoolRoofException">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exception</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from SolarOnRoof display term 1, MassRoof25Lbs display term 2 and NoException display term None. If result == SolarOnRoof or MassRoof25Lbs, inform the user that this meets cool roof requirements and  the rest of this table entry is set to N/A; Else If  result == NoExceptions, user must complete rest of table entry.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:CoolRoofException">
                                             
                                             
                                             <xs:enumeration value="MassRoof25Lbs"/>
                                             
                                             
                                             <xs:enumeration value="NoException"/>
                                             
                                             
                                             <xs:enumeration value="SolarOnRoof"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G03_IsRoofPitchGTE2Run12Rise" type="comp:IsRoofPitchGTE2Run12Rise">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Roof Pitch</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage;  Else User selects from list: Roof pitch is greater than 2:12 (Boolean true) or Roof pitch is less than or equal to 2:12. (Boolean false).</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Roof Pitch</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage;  Else User selects from list: Roof pitch is greater than 2:12 (Boolean true) or Roof pitch is less than or equal to 2:12. (Boolean false).</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G04_CoolRoofComplianceMethod">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Method of Compliance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User selects from list: Not in applicable climate zone, Aged Solar Reflectance and Thermal Emittance  or SRI.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="comp:CoolRoofComplianceMethod">
                                                
                                                
                                                <xs:enumeration value="AgedSolarReflectanceThermaEmittance"/>
                                                
                                                
                                                <xs:enumeration value="ClimateZoneNotApplicable"/>
                                                
                                                
                                                <xs:enumeration value="SolarReflectanceIndex"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Method of Compliance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User selects from list: Not in applicable climate zone, Aged Solar Reflectance and Thermal Emittance  or SRI.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G05_RoofProductType" type="env:RoofProductType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Product Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User selects from CRRC product list.   Asphalt Shingles, Built Up Roofing, Clay Roof Tiles, Factory Applied Coating, Field Applied Coating, Fluid Applied Membrane, Metal Roof, Metal Shakes Shingles, Modified Bitumen, Polymer Composite Steep Slope, Roof  Pavers, Single Ply Thermoplastic, Single Ply Thermoset, Spray Polyurethane Foam, Stone Aggregate Ballast.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Product Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User selects from CRRC product list.   Asphalt Shingles, Built Up Roofing, Clay Roof Tiles, Factory Applied Coating, Field Applied Coating, Fluid Applied Membrane, Metal Roof, Metal Shakes Shingles, Modified Bitumen, Polymer Composite Steep Slope, Roof  Pavers, Single Ply Thermoplastic, Single Ply Thermoset, Spray Polyurethane Foam, Stone Aggregate Ballast.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G06_CRRCProductID" type="env:CRRCProductID">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CRRC Product ID Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User input: product ID from CRRC Directory if user knows what they are installing, otherwise user enters N/A stored in NotApplicablemessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CRRC Product ID Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else User input: product ID from CRRC Directory if user knows what they are installing, otherwise user enters N/A stored in NotApplicablemessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="G06After_HeadingForG07toG10">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b> Proposed</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for G07-G10</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G07_CRRC_InitialReflectance" type="env:CRRC_InitialReflectance">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Initial Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage Else If G04_CoolRoofComplianceMethod == ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else If user knows what they are installing, user inputs DecimalNonnegative value which must be GT 0 and LT 1 from CRRC Directory;  Else allow user to enter N/A stored in NotApplicablemessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Initial Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage Else If G04_CoolRoofComplianceMethod == ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else If user knows what they are installing, user inputs DecimalNonnegative value which must be GT 0 and LT 1 from CRRC Directory;  Else allow user to enter N/A stored in NotApplicablemessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G08_SolarReflectanceAged" type="com:SolarReflectanceAged">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod ==  ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else User input: DecimalNonnegative value must be GT 0 and LT 1.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G08_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod ==  ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else User input: DecimalNonnegative value must be GT 0 and LT 1.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G09_ThermalEmittance" type="com:ThermalEmittance">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod ==  ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else User input: DecimalNonnegative value must be GT 0 and LT 1 .</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod ==  ClimateZoneNotApplicable then result = N/A stored in the NotApplicableMessage; Else User input: DecimalNonnegative value must be GT 0 and LT 1 .</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G10_SolarReflectanceIndex" type="env:SolarReflectanceIndex">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod !=  SolarRefectanceIndex result = N/A stored in the NotApplicableMessage;  Else  user enters value from CRRC directory or from a completed SRI Worksheet.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else If G04_CoolRoofComplianceMethod !=  SolarRefectanceIndex result = N/A stored in the NotApplicableMessage;  Else  user enters value from CRRC directory or from a completed SRI Worksheet.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="G10After_HeadingForG11toG13">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b> Required</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for G11-G13</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G11_SolarReflectanceAgedLimit" type="env:SolarReflectanceAgedLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else  Calculated field: If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false, result = 0.63; Else If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.20;   Else for all other combinations of climate zone and roof pitch, the result = N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G11_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else  Calculated field: If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false, result = 0.63; Else If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.20;   Else for all other combinations of climate zone and roof pitch, the result = N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G12_ThermalEmittanceLimit" type="com:ThermalEmittanceLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else Calculated field: If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false  Then If G04_CoolRoofComplianceMethod == SolarReflectanceIndex result = 0.85; Else If G04_CoolRoofComplianceMethod == AgedSolarReflectanceThermaEmittance then  result = 0.75;  If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.75;  Else for all other combinations of climate zone, roof pitch and cool roof compliance method, the result is N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G12_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else Calculated field: If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false  Then If G04_CoolRoofComplianceMethod == SolarReflectanceIndex result = 0.85; Else If G04_CoolRoofComplianceMethod == AgedSolarReflectanceThermaEmittance then  result = 0.75;  If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.75;  Else for all other combinations of climate zone, roof pitch and cool roof compliance method, the result is N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G13_SolarReflectanceIndexLimit" type="env:SolarReflectanceIndexLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else Calculated field: G04_CoolRoofComplianceMethod != SolarReflectanceIndex result = N/A stored in the NotApplicableMessage;   Else If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false  result = 75; Else If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 16;  Else for all other combinations of climate zone and roof pitch, result is N/A stored in the NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G13_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicablemessage; Else Calculated field: G04_CoolRoofComplianceMethod != SolarReflectanceIndex result = N/A stored in the NotApplicableMessage;   Else If A09_ClimateZone == 13 Or 15, and  G03_IsRoofPitchGreaterThan2Run12Rise == false  result = 75; Else If A09_ClimateZone is in InclusiveRange(10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 16;  Else for all other combinations of climate zone and roof pitch, result is N/A stored in the NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_H">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Fenestration/Glazing Allowed Areas and Efficiencies (Section 150.2(a)1)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable if A13_ProjectScopeAddition includes  FenestrationAddition.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="H01_ProjectScopeAdditions">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Addition Type ft
                           <ns1:sup>2</ns1:sup>
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Value auto-filled from A13_ProjectScopeAddition   with one of these values: AdditionLTE300, AdditionGT300LTE400, AdditionGT400LTE700,  AdditionGT700LTE1000, AdditionLTE300ADU, AdditionGT300LTE400ADU, AdditionGT400LTE700ADU,  AdditionGT700LTE1000ADU,</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="comp:ProjectScopeAdditions">
                           
                           
                           <xs:enumeration value="AdditionGT300LTE400"/>
                           
                           
                           <xs:enumeration value="AdditionGT300LTE400ADU"/>
                           
                           
                           <xs:enumeration value="AdditionGT400LTE700"/>
                           
                           
                           <xs:enumeration value="AdditionGT400LTE700ADU"/>
                           
                           
                           <xs:enumeration value="AdditionGT700LTE1000"/>
                           
                           
                           <xs:enumeration value="AdditionGT700LTE1000ADU"/>
                           
                           
                           <xs:enumeration value="AdditionLTE300"/>
                           
                           
                           <xs:enumeration value="AdditionLTE300ADU"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H01After_HeadingForH02toH03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Maximum Allowed Fenestration Area For All Orientations ft
                           <ns1:sup>2</ns1:sup>
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This multicolumn heading is for H02-H03</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H01After_SubHeadingForH02toH03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">The Greater</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This multicolumn subheading is for H02-H03</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="H02_GlazingAreaAdditionLimitPercentBased" type="env:GlazingAreaAdditionLimitPercentBased">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Calculated based on Allowed %</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If H01_ProjectScopeAddition == AdditionLTE300, AdditionGT300LTE400, AdditionLTE300ADU Or AdditionGT300LTE400ADU result = PRODUCT ( A10_AdditionTotalConditionedFloorArea,   0.30);  Else If  H01_ProjectScopeAddition == AdditionGT400LTE700 Or AdditionGT400LTE700ADU result = PRODUCT (A10_AdditionTotalConditionedFloorArea,  0.25);  Else If  H01_ProjectScopeAddition == AdditionGT700LTE1000 Or AdditionGT700LTE1000 result = PRODUCT ( A10_AdditionTotalConditionedFloorArea,  0.20).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="H03_GlazingAreaAdditionLimit" type="env:GlazingAreaAdditionLimit">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Maximum Calculated Allowed ft
                           <ns1:sup>2</ns1:sup>
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If H01_ProjectScopeAddition ==  AdditionLTE300 Or AdditionGT300LTE400 result = 75 ft2;  Else If  H01_ProjectScopeAddition == AdditionGT400LTE700 result = 120 ft2;  Else If  H01_ProjectScopeAddition ==   AdditionGT700LTE1000 result = 175 ft2</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H03After_HeadingForH04toH05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Maximum Allowed West-Facing Fenestration Area Only  ft
                           <ns1:sup>2</ns1:sup>
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This multicolumn heading is for H04-H05</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H03After_SubHeadingForH04toH05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">The Greater</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This multicolumn subheading is for H04-H05</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="H04_GlazingAreaLimitWestPercentageBased" type="env:GlazingAreaLimitWestPercentageBased">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Calculated based on Allowed %</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1,   3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else If H01_ProjectScopeAddition ==  AdditionLTE300 Or AdditionGT300LTE400 Or AdditionGT400LTE700, result = N/A stored in the NotApplicableMessage;   Else If  H01_ProjectScopeAddition ==   AdditionGT700LTE1000 result = PRODUCT(A10_AdditionTotalConditionedFloorArea,  0.05).</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="H04_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Calculated based on Allowed %</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1,   3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else If H01_ProjectScopeAddition ==  AdditionLTE300 Or AdditionGT300LTE400 Or AdditionGT400LTE700, result = N/A stored in the NotApplicableMessage;   Else If  H01_ProjectScopeAddition ==   AdditionGT700LTE1000 result = PRODUCT(A10_AdditionTotalConditionedFloorArea,  0.05).</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="H05_GlazingAreaAdditionLimitWest" type="env:GlazingAreaAdditionLimitWest">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">
                              Maximum Calculated Allowed ft
                              <ns1:sup>2</ns1:sup>
                           </xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1,   3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else If H01_ProjectScopeAddition ==  AdditionLTE300 Or AdditionGT300LTE400 Or AdditionGT400LTE700  result = 60 ft2;  ElseIf  H01 equals  AdditionGT700LTE1000 result =  70 ft2</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="H05_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">
                              Maximum Calculated Allowed ft
                              <ns1:sup>2</ns1:sup>
                           </xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1,   3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else If H01_ProjectScopeAddition ==  AdditionLTE300 Or AdditionGT300LTE400 Or AdditionGT400LTE700  result = 60 ft2;  ElseIf  H01 equals  AdditionGT700LTE1000 result =  70 ft2</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="H06_UFactorLimit" type="com:UFactorLimit">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Allowed  U-factor (Windows)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If A09_ClimateZone == 1-5, 11-14 Or 16 result = 0.27 Else result =  0.30</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="H07_UFactorLimitSkylight" type="com:UFactorLimitSkylight">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Allowed  U-factor (Skylights)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightLTE16Ft2 Or FenestrationGlazingSkylightTubularLTE3Ft2, result = 0.40; Else If A09_ClimateZone == 1-5, 11-14 Or 16 result = 0.27 Else result = 0.30</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="H08_SHGC_Limit" type="com:SHGC_Limit">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in the NotApplicableMessage; Else If A09_ClimateZone == 15 result = 0.20 Else result =  0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="H08_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else If A09_ClimateZone == 15 result = 0.20 Else result =  0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="H09_SHGC_Limit" type="com:SHGC_Limit">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in the NotApplicableMessage; Else If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightLTE16Ft2 Or FenestrationGlazingSkylightTubularLTE3Ft2,  result = 0.30; Else result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="H09_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in the NotApplicableMessage;  Else A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightLTE16Ft2 Or FenestrationGlazingSkylightTubularLTE3Ft2,  result = 0.30; Else result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element minOccurs="0" name="H10_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comments</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: Text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Fenestration Proposed Areas and Efficiencies Section 150.2(a))</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable if A13_ProjectScopeAddition includes FenestrationAddition.   Each row in the table is for a unique type of vertical fenestration or skylight in the project.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="I_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Note: 
                           <ns1:tab1/>
                           If meeting Exception 1 to 150.1(c)3A, New dwelling units with a conditioned floor area of 500 square feet or less in Climate Zone 5 may comply with a maximum U-factor of 0.30. 
                           <ns1:line1/>
                            

                           <ns1:tab1/>
                           If meeting Exception 2 to 150.1(c)3A, Installing less than or equal to 3 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) glass in door or less than or equal to 3 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) tubular skylight, it is assumed to meet the minimum required U-factor of 0.27 for climate zones 1 through 5, 11 through 14 and 16, and 0.30 for climate zones 6 through 10 and 15, and SHGC of 0.23 for climate zones 2, 4, 6 through 15.
                           <ns1:line1/>
                           

                           <ns1:tab1/>
                           If meeting Exception 3 to 150.1(c)3A, Installing less than or equal to 16 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) tubular skylight, it is assumed to meet the minimum required U-factor (0.40) and SHGC (0.30). In climate zones 1, 3, 5 and 16 there is no SHGC requirement.
                           <ns1:line1/>
                           

                           <ns1:tab1/>
                            Doors with greater than or equal to 25 percent glazing area are considered glazed doors and are treated as fenestration products.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableFenestration">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="I01_FenestrationName" type="comp:FenestrationName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input: ObjectNamePermissive</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I02_FenestrationAdditionType" type="env:FenestrationAdditionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fenestration Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list:  FixedWindow  display term fixed window, OperableWindow display term operable window, Skylight display term skylight,  If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightTubularLTE3Ft2  also list TubularSkylight display term tubular skylight;  If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingDoorLTE3Ft2 also list GlazedDoor display term glass in door.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I03_FenestrationFraming">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Frame Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: Metal,  Metal Thermal Break,  Non-metal</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="env:FenestrationFraming">
                                             
                                             
                                             <xs:enumeration value="MetalFraming"/>
                                             
                                             
                                             <xs:enumeration value="MetalFramingWithThermalBreak"/>
                                             
                                             
                                             <xs:enumeration value="NonMetalFraming"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I04_DynamicGlazingType" type="env:DynamicGlazingType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dynamic Glazing</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list:  Chromogenic Glazing, Integrated Shading Device and None</xs:documentation>
                                          
                                       
