                                             <xs:documentation source="FieldText">Proposed SHGC</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Maximum Allowed SHGC in H08 or H09 equals N/A then result = N/A  Else User input: DecimalNonnegative   </xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
