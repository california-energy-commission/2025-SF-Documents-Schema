                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Combined SHGC from CF1R-ENV-03</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If I13_ExternalShadingObjectType == NoExternalShadingDevice or If I04_DynamicGlazingType ==  ChromogenicGlazing result = N/A stored in NotApplicableMessage, Else If Maximum Allowed SHGC in H08 or H09 equals N/A then result = N/A Else result =  value from CF-1R-ENV-03.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I14_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Combined SHGC from CF1R-ENV-03</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If I13_ExternalShadingObjectType == NoExternalShadingDevice or If I04_DynamicGlazingType ==  ChromogenicGlazing result = N/A stored in NotApplicableMessage, Else If Maximum Allowed SHGC in H08 or H09 equals N/A then result = N/A Else result =  value from CF-1R-ENV-03 field D04.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I15_TotalGlazingAreaAllOrientations" type="env:TotalGlazingAreaAllOrientations">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total Proposed Fenestration Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: Result = SUM( SUM ALL(I07_TotalGlazingAreaEastSameTypeAndFrame, I07_TotalGlazingAreaNorthSameTypeAndFrame, I07_TotalGlazingAreaSouthSameTypeAndFrame), SUM ALL (I08_TotalGlazingAreaWestSameTypeAndFrame))</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I16_GlazingAreaLimitAll" type="env:GlazingAreaLimitAll">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Allowed Fenestration Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  Result = Largest (H02_GlazingAreaAdditionLimitPercentBased, H03_GlazingAreaAdditionLimit)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I17_IsFenestrationAllowedAreaCompliant" type="comp:IsFenestrationAllowedAreaCompliant">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If I15_TotalGlazingAreaAllOrientations LTE I16_GlazingAreaLimitAll result = true   display term Design complies with the Total Allowed Fenestration Area;  Else result = false display term  Total Proposed Fenestration Area Exceeds Allowable.  Do Not Proceed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I18_TotalGlazingAreaWest" type="env:TotalGlazingAreaWest">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total Propose West-Facing Fenestration Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: Result = SUM ALL (I08_TotalGlazingAreaWestSameTypeAndFrame)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I19_GlazingAreaLimitWest" type="env:GlazingAreaLimitWest">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed West Facing Fenestration Area</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If H04_GlazingAreaLimitWestPercentageBased Or  H05_GlazingAreaAdditionLimitWest == N/A result = N/A stored in NotApplicableMessage Else result = Largest (H04_GlazingAreaLimitWestPercentageBased, H05_GlazingAreaAdditionLimitWest)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I19_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed West Facing Fenestration Area</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If H04_GlazingAreaLimitWestPercentageBased Or  H05_GlazingAreaAdditionLimitWest == N/A result = N/A stored in NotApplicableMessage Else result = Largest (H04_GlazingAreaLimitWestPercentageBased, H05_GlazingAreaAdditionLimitWest)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="I20_IsFenestrationWestFacingAllowedAreaCompliant" type="comp:IsFenestrationWestFacingAllowedAreaCompliant">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If I18_TotalGlazingAreaWest LTE GlazingAreaLimitWest Or If I19_GlazingAreaLimitWest == N/A, then result = true display term Design complies with the Total Allowed West-facing Fenestration Area.  Else result = false display term Total Proposed West-facing Fenestration Area Exceeds Allowable.  Do Not Proceed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I21_UfactorProposedAllWindowFenestration" type="comp:UfactorProposedAllWindowFenestration">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration U-factor (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != FixedWindow or OperableWindow result = N/A stored in the NotApplicableMessage;  Else If  all I09_U-factor values LTE H06_UFactorLimit, result = Largest (All I09_U-factor values); Else enter the weighted average value from the CF1R-ENV-02</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I21_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration U-factor (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != FixedWindow or OperableWindow result = N/A stored in the NotApplicableMessage;  Else If  all I09_U-factor values LTE H06_UFactorLimit, result = Largest (All I09_U-factor values); Else enter the weighted average value from the CF1R-ENV-02</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I22_UFactorLimit" type="com:UFactorLimit">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration U-factor (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Result = H06_UFactorLimit</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I22_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration U-factor (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Report value from H06</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I23_IsWindowFenestrationAllowedUFactorCompliant" type="comp:IsWindowFenestrationAllowedUFactorCompliant">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I21_UfactorProposedAllWindowFenestration == N/A then result = N/A stored in the NotApplicableMessage; Else If I21_UfactorProposedAllWindowFenestration LTE I22_UFactorLimit, then result = true display term Design complies with the Maximum Allowed Fenestration U-factor; Else result = false display term Fenestration U-factor Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I23_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I21_UfactorProposedAllWindowFenestration == N/A then result = N/A stored in the NotApplicableMessage; Else If I21_UfactorProposedAllWindowFenestration LTE I22_UFactorLimit, then result = true display term Design complies with the Maximum Allowed Fenestration U-factor; Else result = false display term Fenestration U-factor Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I24_ProposedAllWindowFenestrationSHGC" type="comp:ProposedAllWindowFenestrationSHGC">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != FixedWindow or OperableWindow result = N/A stored in the NotApplicableMessage; Else If I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage; Else If all I11_SolarHeatGainCoefficient values Or all I14_SolarHeatGainCoefficientExteriorShading values  are LTE 0.23, then result = Largest (all I11_SolarHeatGainCoefficient values, all I14_SolarHeatGainCoefficientExteriorShading values); Else enter the weighted average value from the CF1R-ENV-02 </xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I24_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != FixedWindow or OperableWindow result = N/A stored in the NotApplicableMessage; Else If I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage; Else If all I11_SolarHeatGainCoefficient values Or all I14_SolarHeatGainCoefficientExteriorShading values  are LTE 0.23, then result = Largest (all I11_SolarHeatGainCoefficient values, all I14_SolarHeatGainCoefficientExteriorShading values); Else enter the weighted average value from the CF1R-ENV-02</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I25_SHGC_Limit" type="com:SHGC_Limit">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If H08_NotApplicableMessage == N/A, result = N/A stored in NotApplicableMessage; Else result = H08_SolarHeatGainCoefficientLimit</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I25_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If H08_NotApplicableMessage == N/A, result = N/A stored in NotApplicableMessage; Else result = H08_SolarHeatGainCoefficientLimit</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I26_IsWindowFenestrationAllowedSHGC_Compliant" type="comp:IsWindowFenestrationAllowedSHGC_Compliant">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I24_NotApplicableMessage == N/A result = N/A stored in the NotApplicableMessage, Else If I24_ProposedAllWindowFenestrationSHGC LTE  I25_SolarHeatGainCoefficientLimit Or if I25_NotApplicableMessage == N/A result = true display term Design complies with the Maximum Allowed Fenestration SHGC.  Else result = false.   display term  Fenestration SHGC Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I26_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I24_NotApplicableMessage == N/A result = N/A stored in the NotApplicableMessage, Else If I24_ProposedAllWindowFenestrationSHGC LTE  I25_SolarHeatGainCoefficientLimit Or if I25_NotApplicableMessage == N/A result = true display term Design complies with the Maximum Allowed Fenestration SHGC.  Else result = false.   display term  Fenestration SHGC Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I27_UfactorProposedAllSkylightFenestration" type="comp:UfactorProposedAllSkylightFenestration">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration U-factor (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != Skylight  result = N/A stored in the NotApplicableMessage;  Else resul = Largest (All I09_U-factor values)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I27_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration U-factor (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != Skylight  result = N/A stored in the NotApplicableMessage;  Else result = Largest (All I09_U-factor values)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I28_UFactorLimitSkylight" type="com:UFactorLimitSkylight">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration U-factor (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Report value from H07_UFactorLimitSkylight</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I28_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration U-factor (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Report value from H07</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I29_IsSkylightFenestrationAllowedUFactorCompliant" type="comp:IsSkylightFenestrationAllowedUFactorCompliant">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I27_NotApplicableMessage ==   N/A  result = N/A stored in the NotApplicableMessage;  Else If I27_UfactorProposedAllSkylightFenestration LTE I28_UFactorLimitSkylight,  result = true display term  Design complies with the Maximum Allowed Fenestration U-factor;  Else result = false display term Fenestration U-factor Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I29_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I27_NotApplicableMessage ==   N/A  result = N/A stored in the NotApplicableMessage;  Else If I27_UfactorProposedAllSkylightFenestration LTE I28_UFactorLimitSkylight,  result = true display term  Design complies with the Maximum Allowed Fenestration U-factor;  Else result = false display term Fenestration U-factor Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I30_ProposedAllSkylightFenestrationSHGC" type="comp:ProposedAllSkylightFenestrationSHGC">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != Skylight  result = N/A stored in the NotApplicableMessage; Else If I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage; Else result = Largest (all I11_SolarHeatGainCoefficient values, all I14_SolarHeatGainCoefficientExteriorShading values)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I30_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Proposed Fenestration SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If all I02_FenestrationAdditionType values != Skylight  result = N/A stored in the NotApplicableMessage; Else If I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage; Else result = Largest (all I11_SolarHeatGainCoefficient values, all I14_SolarHeatGainCoefficientExteriorShading values)</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I31_SHGC_LimitSkylight" type="com:SHGC_LimitSkylight">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If H09 Or I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage Else Result =  H09_SolarHeatGainCoefficientLimit</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I31_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Fenestration SHGC (Skylights)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If H09 Or I11 Or I14 equals N/A result = N/A stored in the NotApplicableMessage Else Result =  H09_SolarHeatGainCoefficientLimit</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I32_IsSkylightFenestrationAllowedSHGC_Compliant" type="comp:IsSkylightFenestrationAllowedSHGC_Compliant">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I30_NotApplicableMessage == N/A result = N/A stored in the NotApplicableMessage, Else If I30_ProposedAllSkylightFenestrationSHGC LTE  I31_SolarHeatGainCoefficientLimitSkylight Or I31_NotApplicableMessage == N/A result = true display term Design complies with the Maximum Allowed Fenestration SHGC.  Else result = false display term  Fenestration SHGC Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I32_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If I30_NotApplicableMessage == N/A  result = N/A stored in the NotApplicableMessage, Else If I30_ProposedAllSkylightFenestrationSHGC LTE  I31_SolarHeatGainCoefficientLimitSkylight Or I31_NotApplicableMessage == N/A result = true display term Design complies with the Maximum Allowed Fenestration SHGC.  Else result = false display term  Fenestration SHGC Exceeds Allowable. Do Not Proceed.</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_J">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Opaque Swinging Doors to Exterior (Section 150.1(c)5)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required if A13__ProjectScopeAddition includes ExteriorDoorsAddition</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDoors">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="J01_DoorName" type="env:DoorName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input string (max 50 characters)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J02_DoorArea" type="env:DoorArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Area</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative xxx.xx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J03_UFactor" type="com:UFactor">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Proposed U-factor</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative x.xxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J04_DoorCertificationMethod" type="env:DoorCertificationMethod">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Proposed U-factor Source</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user selects from list: NFRCRated display term NFRC, AreaWeightedWorksheet display term Area-weighted Average Worksheet (ENV-02)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J05_UFactorLimit" type="com:UFactorLimit">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Required Maximum U-factor</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">default result = 0.20</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J06_IsValueWeightedAverage" type="comp:IsValueWeightedAverage">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Weighted average (Yes/No)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If J03_UFactor GT 0.20 result = true display term Yes; Else result = false display term No.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="J07_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="JEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Notes: 
                           <ns1:l t="*">
                               
                              <ns1:list>Any door wiht 25% or more glass is counted as a fenestration product in tables H and I. </ns1:list>
                              <ns1:list> Do not include fire-rated doors between garage or unconditioned space and conditioned space.</ns1:list>
                              <ns1:list> If using weighted average to achieve required maximum U-factor, attach CF1R-ENV-02-E.</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_K">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Space Conditioning (SC) Systems - Heating/ Cooling   (Section 150.2(b) or (Section 150.1(c)7)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable if A13_ProjectScopeAdditions  includes at least one of the following: HeatingSystemAddition, CoolingSystemAddition, or DuctSystemAddition.  Require one row of data in this table and require that a CF1R-ALT-02 is registered for the dwelling.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="K01_ResidentialDwellingUnitName" type="com:ResidentialDwellingUnitName">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Dwelling Unit Name</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: ObjectNamePermissive</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="K02_DwellingUnitConditionedFloorAreaWithAddition" type="com:DwellingUnitConditionedFloorAreaWithAddition">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Dwelling Unit Total CFA = Sum of Existing + Addition (ft
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: IntegerNonnegative</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K03_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comments</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: Text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_L">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Water Heating Systems (Section 150.2(a)1D)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required if A13_ProjectScopeAddition includes WaterHeatingAddition</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="L_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">List water heaters and boilers for both domestic hot water (DHW) heaters and hydronic space heating.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L_BeginNote2">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 2</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Options: [ 
                           <ns1:l t="#">
                              <ns1:list> A single heat pump water heater.  The storage tank shall not be located outdoors and shall be placed on an incompressible, rigid insulated surface with a minimum thermal resistance of R-10.  The water heater shall be installed with a communication interface that meets either the requirements of Section 110.12(a) or has an ANSI/CTA-2045-B communications port; or </ns1:list>
                              

                              <ns1:list>  A single heat pump water heater that meets the requirements of NEEA Advanced Water Heater Specification Tier 3 or higher;  or </ns1:list>
                              <ns1:list>For additions that are 500 square feet or less, an electric water heater with point of use distribution as specified in the Reference Appendices, Residential Appendix RA4.4.5 </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableWaterHeating">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="L01_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heating System ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L02_WaterHeatingSystemOption">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             System Option (from 
                                             <ns1:t24ref h="150.2(a)1D"/>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from this list: OptionSingleHWH display term 1, OptionTier3SingleHWH display term 2, OptionElectPointOfUse display term 3</xs:documentation>
                                          
                                          
                                          <xs:appinfo source="displayterm">
                                             
                                             
                                             <ns2:displayterm value="OptionSingleHWH">1</ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="OptionTier3SingleHWH">2</ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="OptionElectPointOfUse">3</ns2:displayterm>
                                             
                                          
                                          </xs:appinfo>
                                                                                    
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:WaterHeatingSystemOption">
                                             
                                             
                                             <xs:enumeration value="OptionElectPointOfUse"/>
                                             
                                             
                                             <xs:enumeration value="OptionSingleHWH"/>
                                             
                                             
                                             <xs:enumeration value="OptionTier3SingleHWH"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L03_WaterHeaterTotalSystemCount" type="hvac:WaterHeaterTotalSystemCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText"># of Water Heaters/Compressors in System</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer</xs:documentation>
                                                                                    
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L04_ResidentialWaterHeaterType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heater Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If  L02_WaterHeatingSystemOption == OptionElectPointOfUse result = ElectricPOUConsumer; 
Else If  L02_WaterHeatingSystemOption == OptionSingleHWH result =  HeatPumpWaterHeater

Else If L02_WaterHeatingSystemOption == OptionTier3SingleHWH   result = NEEA_Tier3HP
End If</xs:documentation>
                                          
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ResidentialWaterHeaterType">
                                             
                                             
                                             <xs:enumeration value="HeatPumpWaterHeater"/>
                                             
                                             
                                             <xs:enumeration value="ElectricPOUConsumer"/>
                                             
                                             
                                             <xs:enumeration value="NEEA_Tier3HP"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L05_WaterHeaterFuelSource">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fuel Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If L02_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH result = WaterHeatingHP
Else If L02_WaterHeatingSystemOption  == OptionElectPointOfUse result = Electricity</xs:documentation>
                                                                                    
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:WaterHeaterFuelSource">
                                             
                                             
                                             <xs:enumeration value="Electricity"/>
                                             
                                             
                                             <xs:enumeration value="WaterHeatingHP"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="L06_TankLocation">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Location</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If L02_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH
user selects from list: Conditioned Or Garage; Else result = N/A stored in NotApplicableMessage.</xs:documentation>
                                                                                          
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:TankLocation">
                                                
                                                
                                                <xs:enumeration value="Conditioned"/>
                                                
                                                
                                                <xs:enumeration value="Garage"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="L06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Location</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If L02_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH
user selects from list: Conditioned Or Garage; Else result = N/A stored in NotApplicableMessage.</xs:documentation>
                                                                                          
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="L07_ResidentialDHWDwellingUnitDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Distribution Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If L02_WaterHeatingSystemOption  == OptionElectPointOfUse result = PointOfUse Else result = StandardDistribution</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ResidentialDHWDwellingUnitDistributionType">
                                             
                                             
                                             <xs:enumeration value="PointOfUse"/>
                                             
                                             
                                             <xs:enumeration value="StandardDistribution"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
