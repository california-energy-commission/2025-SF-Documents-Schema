                                                <xs:enumeration value="R10VR7H"/>
                                                
                                                
                                                <xs:enumeration value="R4"/>
                                                
                                                
                                                <xs:enumeration value="R5"/>
                                                
                                                
                                                <xs:enumeration value="R7"/>
                                                
                                                
