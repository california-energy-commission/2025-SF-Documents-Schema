                                                Proposed West Facing Fenestration Area   ft
                                                <ns1:sup>2</ns1:sup>
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If I05_CardinalOrientation == West store result in TotalGlazingAreaWestSameTypeAndFrame; Else result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
