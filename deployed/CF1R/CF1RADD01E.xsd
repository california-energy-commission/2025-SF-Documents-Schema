                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Proposed SHGC</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Maximum Allowed SHGC in H08 or H09 equals N/A then result = N/A stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
