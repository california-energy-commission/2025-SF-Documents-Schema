                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Proposed Fenestration Area  ft
                                                <ns1:sup>2</ns1:sup>
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input;  If I05_CardinalOrientation == North, store result in TotalGlazingAreaNorthSameTypeAndFrame</xs:documentation>
                                             
                                          
