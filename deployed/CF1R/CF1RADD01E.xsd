                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Proposed SHGC Source</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Proposed SHGC in I11 equals N/A then result = N/A stored in NotApplicableMessage; Else User selects from list: Choice NFRCRated, display text: NFRC;  Choice CECDefaultPerformance, display term Tables 110.6A and 110.6B; Choice NA6Equations, display term Equations NA6-1 and NA6-2; and Choice CF1R_ENV_02 display term Area-weighted Average Worksheet (CF1R-ENV-02)</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I12_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Proposed SHGC Source</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Proposed SHGC in I11 equals N/A then result = N/A stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
