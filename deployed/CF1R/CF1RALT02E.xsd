                                          <xs:documentation source="CalculationsAndRules">Calculated field: If ResidentialCoolingSystemType == NoCooling then result = NoCoolingComponentsAltered Else 
 result =  AllNewCoolingComponents,</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ResidentialHvacCoolingComponentType">
                                             
                                             
