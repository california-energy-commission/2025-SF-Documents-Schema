   <xs:complexType name="CF1RENV05E">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Alternative Default Fenestration Procedure (NA6) Worksheet</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">General Information</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="A01_ResidentialBuildingTotalConditionedFloorArea" type="com:ResidentialBuildingTotalConditionedFloorArea">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Conditioned Floor Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Auto-filled from CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A02_ConditionedFloorArea5Percent" type="com:ConditionedFloorArea5Percent">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">5% of the Conditioned Floor Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Result = PRODUCT( A01_ResidentialBuildingTotalConditionedFloorArea, .05)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A03_FenestrationNonRatedSiteBuiltTotalAreaAllowed" type="env:FenestrationNonRatedSiteBuiltTotalAreaAllowed">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total Allowed Non-Rated Site-built Fenestration Area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Result = Largest (A02_ResidentialBuildingConditionedFloorArea5Percent, 250)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A04_FenestrationNonRatedSiteBuiltTotalAreaProposed" type="env:FenestrationNonRatedSiteBuiltTotalAreaProposed">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Proposed Area of Site-built Fenestration</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: SUM ALL (B02_GlazingArea</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Fenestration/ Glazing Area</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">If CF1R parent == CF1R-ADD, CF1R-ALT or CF1R-NCB require a row for fenestration products with Proposed U-factor or SHGC Source property,  FenestrationCertificationMethod == NA6Equations 
Else If CF1R parent == CF1R-PRF, require a row for fenestration products with M08aFenestrationCertificationMethod = NA6Equations Or M09aFenestrationCertificationMethod = NA6Equations </xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableFenestration">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="B01_FenestrationName" type="comp:FenestrationName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/Identification</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from CF1R.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B02_GlazingArea" type="env:GlazingArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Area (ft
                                             <ns1:sup>2</ns1:sup>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User entry, nonnegative decimal</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Default U-factor Using Reference Appendices, Nonresidential Appendix NA6, Equation NA6-1</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable If CF1R parent == CF1R-ADD, CF1R-ALT or CF1R-NCB and at least one fenestration product has Proposed U-factor Source property,  FenestrationCertificationMethod == NA6Equations 
Else If CF1R parent == CF1R-PRF, require a row for fenestration products with M08aFenestrationCertificationMethod = NA6Equations.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="C_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Equation NA6-1: U
                           <ns1:sub>T</ns1:sub>
                            = C
                           <ns1:sub>1</ns1:sub>
                            + (C
                           <ns1:sub>2</ns1:sub>
                            x U
                           <ns1:sub>C</ns1:sub>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableUFactor">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="C01_FenestrationName" type="comp:FenestrationName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/Identification</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list provided from B01_FenestrationName for this section</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C02_NA6FenestrationType" type="comp:NA6FenestrationType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Product Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: SiteBuiltVertical, SkylightCurb, SkylightNoCurb</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C03_FenestrationFraming">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Frame Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User picks from list: Metal with thermal break; Metal; NonMetal</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="env:FenestrationFraming">
                                             
                                             
                                             <xs:enumeration value="MetalFramingWithThermalBreak"/>
                                             
                                             
                                             <xs:enumeration value="MetalFraming"/>
                                             
                                             
                                             <xs:enumeration value="NonMetalFraming"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C04_UfactorCoefficient1" type="comp:UfactorCoefficient1">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             C
                                             <ns1:sub>1</ns1:sub>
                                              from Table NA6-5
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input decimal number from Table NA6-5</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C05_UfactorCoefficient2" type="comp:UfactorCoefficient2">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             C
                                             <ns1:sub>2</ns1:sub>
                                              from Table NA6-5
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input decimal number from Table NA6-5</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C06_UFactorCenterOfGlass" type="com:UFactorCenterOfGlass">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Center of Glass U-factor (U
                                             <ns1:sub>c</ns1:sub>
                                              )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input decimal number</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C07_NA6SourceCOG" type="comp:NA6SourceCOG">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Source</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: ManufacturerSpec, CMAST</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C08_SiteBuiltFenestrationUFactor" type="comp:SiteBuiltFenestrationUFactor">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Total Performance U-factor(U
                                             <ns1:sub>T</ns1:sub>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  Result = PRODUCT (C05_UfactorCoefficient2, C06_UFactorCenterOfGlass) + C04_UfactorCoefficient1</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
