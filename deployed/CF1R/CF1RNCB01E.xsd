                                          <xs:documentation source="CalculationsAndRules">User selects Boolean value true display term Above Grade or false display term Below Grade.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="D02After_HeadingForD03toD12">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Proposed</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for D03-D012</xs:documentation>
                                          
                                       
