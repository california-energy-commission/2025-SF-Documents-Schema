                                          <xs:documentation source="FieldText">Interior Insulation</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This is the subheading is for D07</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D07_InsulationInteriorRValue" type="env:InsulationInteriorRValue">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative;  Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table. If user enters R-value, it is stored in InsulationInteriorRValue; Else If user enters U-factor it is stored in InsulationInteriorUFactor</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D08_InsulationInteriorUFactor" type="env:InsulationInteriorUFactor">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative;  Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table. If user enters R-value, it is stored in InsulationInteriorRValue; Else If user enters U-factor it is stored in InsulationInteriorUFactor</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="D08After_HeadingD09toD12">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Required</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for D09-D12</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="D08AfterSubHeading_LabelForD09ToD10">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exterior Insulation</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This is the subheading is for D10</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D09_InsulationExteriorRValueMinimum" type="env:InsulationExteriorRValueMinimum">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative; Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table.   If user  enters R-value, it is stored in InsulationExteriorRValueMinimum; Else If user enters U-factor it is stored in InsulationExteriorUFactorLimit</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D10_InsulationExteriorUFactorLimit" type="env:InsulationExteriorUFactorLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative; Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table.   If user  enters R-value, it is stored in InsulationExteriorRValueMinimum; Else If user enters U-factor it is stored in InsulationExteriorUFactorLimit</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="D10After_SubHeadingForD11ToD12">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Interior Insulation</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This is subheading is for D11</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D11_InsulationInteriorRValueMinimum" type="env:InsulationInteriorRValueMinimum">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative; Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table.   If user  enters R-value, it is stored in InsulationInteriorRValueMinimum; Else If user enters U-factor it is stored in InsulationInteriorUFactorLimit</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D12_InsulationInteriorUFactorLimit" type="env:InsulationInteriorUFactorLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input: DecimalNonnegative; Note: Either R-value or U-factor is required, not both. The same descriptor (R-value or U-factor) should be used throughout this table.   If user  enters R-value, it is stored in InsulationInteriorRValueMinimum; Else If user enters U-factor it is stored in InsulationInteriorUFactorLimit</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="DEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Note:</ns1:b>
                            When insulation is added to the outside of a mass wall and/or when the inside is furred and insulated, the performance data may be adjusted using Equation 4-4 in the Reference Appendices Joint Appendix JA4.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Slab On Grade/Concrete Raised Floor Insulation (Table 150.1-A)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is applicable if the project has a slab floor or concrete raised floor.  If insulation is required because of slab type and project climate zone, then user is required to enter either all R-values or all U-factors in fields E02 and E03;</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableSlabs">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="E01_ExteriorFloorType" type="env:ExteriorFloorType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Floor Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: SlabOnGrade display term Slab on grade,  SlabConcreteRaised display term Slab concrete raised, SlabHeated display term Heated Slab</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="E01After_HeadingForE02toE03">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Proposed</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for E02-E03</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E02_SlabInsulationThermalResistance">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User selects from list of R-values: R0, R4, R5, R7, R8, R10 vertical, R10 vertical and R7 horizontal OR N/A stored in NotApplicableMessage.  If E01_ExteriorFloorType == SlabHeated Or If A09_ClimateZone == 16  N/A is not allowed .  Note: Either R-value or U-factor is required, not both</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="env:SlabInsulationThermalResistance">
                                                
                                                
                                                <xs:enumeration value="R0"/>
                                                
                                                
                                                <xs:enumeration value="R10Vertical"/>
                                                
                                                
                                                <xs:enumeration value="R10VR7H"/>
                                                
                                                
                                                <xs:enumeration value="R4"/>
                                                
                                                
                                                <xs:enumeration value="R5"/>
                                                
                                                
                                                <xs:enumeration value="R7"/>
                                                
                                                
                                                <xs:enumeration value="R8"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E02_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If user is entering U-factor result = N/A Else User selects from list of R-values: R0, R4, R5, R7, R8, R10 vertical, R10 vertical and R7 horizontal OR N/A stored in NotApplicableMessage.  If E01_ExteriorFloorType == SlabHeated Or If A09_ClimateZone == 16  N/A is not allowed.  Note: Either R-value or U-factor is required, not both</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E03_InsulationUFactor" type="env:InsulationUFactor">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E01_ExteriorFloorType == SlabHeated Or If A09_ClimateZone == 16 require User input: DecimalNonnegative;  Else allow N/A stored in NotApplicableMessage.  Note: Either R-value or U-factor is required, not both</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If user is entering R-value result = N/A Else If E01_ExteriorFloorType == SlabHeated Or If A09_ClimateZone == 16 require User input: DecimalNonnegative;  Else allow N/A stored in NotApplicableMessage.  Note: Either R-value or U-factor is required, not both</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="E02After_HeadingForE03">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Required</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for E04-E05</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E04_SlabInsulationRValueRequired" type="env:SlabInsulationRValueRequired">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If E02_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage; Else Switch (E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone ==  16 result = R-7; Else If A09_ClimateZone ==  InclusiveRange(1.15) result = N/A stored in NotApplicableMessage; case SlabConcreteRaised:  If A09_ClimateZone == 1, 2, 11, 13, 14 Or 16 result = R-8; Else If A09_ClimateZone ==  InclusiveRange(3,10) result = R-0; Else If A09_ClimateZone ==  12 Or 15 result = R-4;  case SlabHeated: If A09_ClimateZone ==  InclusiveRange(1,15) result =  R-5; Else If A09_ClimateZone ==  16 then user selects either R10Vertical display term R-10 vertical Or R10VR7H display term R-10 vertical and R-7 horizontal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation R-value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If E02_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage; Else Switch (E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone ==  16 result = R-7; Else If A09_ClimateZone ==  InclusiveRange(1.15) result = N/A stored in NotApplicableMessage; case SlabConcreteRaised:  If A09_ClimateZone == 1, 2, 11, 13, 14 Or 16 result = R-8; Else If A09_ClimateZone ==  InclusiveRange(3,10) result = R-0; Else If A09_ClimateZone ==  12 Or 15 result = R-4;  case SlabHeated: If A09_ClimateZone ==  InclusiveRange(1,15) result =  R-5; Else If A09_ClimateZone ==  16 then user selects either R10Vertical display term R-10 vertical Or R10VR7H display term R-10 vertical and R-7 horizontal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E05_SlabInsulationUFactorRequired" type="env:SlabInsulationUFactorRequired">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="AdditionalRequirements">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If E03_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage;Switch (E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone ==  16 result = 0.058; Else If A09_ClimateZone ==  InclusiveRange(1.15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised: If A09_ClimateZone == 1, 2, 11, 13, 14 Or 16 result = 0.092; Else If A09_ClimateZone ==  InclusiveRange(3,10) result = 0.269; Else If A09_ClimateZone ==  12 Or 15 result = 0.138;  case SlabHeated: result = N/A stored in NotApplicableMessage.  Note: Range check, value in E03 must be less than or equal to E05 in order to comply.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Insulation U-factor</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If E03_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage;Switch (E01_ExteriorFloorType) case SlabOnGrade: If A09_ClimateZone ==  16 result = 0.058; Else If A09_ClimateZone ==  InclusiveRange(1.15) result = N/A stored in NotApplicableMessage;  case SlabConcreteRaised: If A09_ClimateZone == 1, 2, 11, 13, 14 Or 16 result = 0.092; Else If A09_ClimateZone ==  InclusiveRange(3,10) result = 0.269; Else If A09_ClimateZone ==  12 Or 15 result = 0.138;  case SlabHeated: result = N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="E06_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input: Text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="EEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Note:</ns1:b>
                            
                           <ns1:l t="*">
                              <ns1:list>Heated slab floors require mandatory slab insulation (see Table 110.8-A).</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Ceiling/Roof Insulation  (Section 150.1(c)1A)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="F01_ResidentialCeilingRoofInsulationOption" type="comp:ResidentialCeilingRoofInsulationOption">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Option</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list:  RoofInsulationOptionB  display term Option B,   RoofInsulationOptionC display term Option C</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F02_OpaqueSurfaceType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Configuration</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list:  AtticVentilated  display term Ventilated Attic and CeilingCathedral display term Cathedral Ceiling</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="env:OpaqueSurfaceType">
                           
                           
                           <xs:enumeration value="AtticVentilated"/>
                           
                           
                           <xs:enumeration value="CeilingCathedral"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F03_DoesInsulationHaveAirSpace" type="comp:DoesInsulationHaveAirSpace">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Space Required?</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If F01_ResidentialCeilingRoofInsulationOption == OptionB And A09_ClimateZone == 4 Or InclusiveRange(8,16) result =  true display term Yes; Else result = false display term No</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F04_RoofBelowDeckInsulation" type="env:RoofBelowDeckInsulation">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Proposed Below Roof Deck R-value</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F05_CeilingInsulation" type="env:CeilingInsulation">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Proposed Ceiling Insul. R-value</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="F06_RoofBelowDeckInsulationRequired" type="env:RoofBelowDeckInsulationRequired">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Below Roof Deck R-value</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: 
If F01_ResidentialCeilingRoofInsulationOption == OptionC: result = N/A stored in NotApplicableMessage;  
Else  If F01_ResidentialCeilingRoofInsulationOption == OptionB Then
If A09_ClimateZone == 4 Or InclusiveRange(8,16) result = R-19; 
Else If A09_ClimateZone == 1,2,3,5,6 Or 7 result = N/A stored in NotApplicableMessage; End If End If End If</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="F06_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Below Roof Deck R-value</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F01_ResidentialCeilingRoofInsulationOption == OptionC: Or 
If F01_ResidentialCeilingRoofInsulationOption == OptionB And A09_ClimateZone == 1,2,3,5,6 Or 7 result = N/A stored in NotApplicableMessage;  End If</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="F07_CeilingInsulationRequired" type="env:CeilingInsulationRequired">
                         
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Required Ceiling Insul. R-value</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If F01_ ResidentialCeilingRoofInsulationOption == OptionB And  A09_ClimateZone == 3, 5, 6 or 7, result = R30; Else If F01_ResidentialCeilingRoofInsulationOption == OptionC And F02_OpaqueSurfaceType == AtticVentilated And A09_ClimateZone == InclusiveRange (2, 7) result = R30; Else result = R38.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F08_RadiantBarrierRequired" type="comp:RadiantBarrierRequired">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Radiant Barrier Required?</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If F01_ResidentialCeilingRoofInsulationOption == OptionC And  A09_ClimateZone == InclusiveRange( 2,15) result = true display term Yes Else If F01_ResidentialCeilingRoofInsulationOption ==  OptionB And  A09_ClimateZone =  2,3, 5, 6, Or 7 Then result  = true display term Yes;  Else result = false display term No</xs:documentation>
                        
                        
                        <xs:appinfo source="displayterm">
                           
                           
                           <ns2:displayterm value="true">Required</ns2:displayterm>
                           
                           
                           <ns2:displayterm value="false">NA</ns2:displayterm>
                           
                        
                        </xs:appinfo>
                        
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F09_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comment</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User  input text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="FEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Options:</ns1:b>
                            
                           <ns1:l t="*">
                              <ns1:list>Option A - reserved.</ns1:list>
                              .
                              <ns1:list> Option B requires below deck insulation in climate zones 4 and 8-16.  An air space is required if below deck insulation is required. </ns1:list>
                              .
                              <ns1:list> Option C requires heating and cooling ducts be located inside the conditioned space below the ceiling separating the occupiable space from the attic or within a cathedral ceiling assembly.</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Roofing Products (Cool Roof)  (Section 150.1(c).11)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required If A09_ClimateZone == 10,11, 12, 13, 14, or 15</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableRoofing">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="G01_PartitionName" type="env:PartitionName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input: ObjectNamePermissive</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G02_CoolRoofException">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exception</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from SolarOnRoof display term 1, MassRoof25Lbs display term 2 and NoException display term None. If result == SolarOnRoof or MassRoof25Lbs, inform the user that this meets cool roof requirements and  the rest of this table entry is set to N/A; Else If  result == NoExceptions, user must complete rest of table entry.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:CoolRoofException">
                                             
                                             
                                             <xs:enumeration value="MassRoof25Lbs"/>
                                             
                                             
                                             <xs:enumeration value="NoException"/>
                                             
                                             
                                             <xs:enumeration value="SolarOnRoof"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G03_IsRoofPitchGTE2Run12Rise" type="comp:IsRoofPitchGTE2Run12Rise">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Roof Pitch</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else User selects from list: Roof pitch is greater than 2:12 (Boolean true) or Roof pitch is less than or equal to 2:12. (Boolean false).</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Roof Pitch</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else User selects from list: Roof pitch is greater than 2:12 (Boolean true) or Roof pitch is less than or equal to 2:12. (Boolean false).</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G04_CoolRoofComplianceMethod">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Method of Compliance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else User selects from list: Aged Solar Reflectance and Thermal Emittance  or SRI.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="comp:CoolRoofComplianceMethod">
                                                
                                                
                                                <xs:enumeration value="AgedSolarReflectanceThermaEmittance"/>
                                                
                                                
                                                <xs:enumeration value="SolarReflectanceIndex"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Method of Compliance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G05_RoofProductType" type="env:RoofProductType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Product Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else User selects from CRRC product list.   Asphalt Shingles, Built Up Roofing, Clay Roof Tiles, Factory Applied Coating, Field Applied Coating, Fluid Applied Membrane, Metal Roof, Metal Shakes Shingles, Modified Bitumen, Polymer Composite Steep Slope, Roof  Pavers, Single Ply Thermoplastic, Single Ply Thermoset, Spray Polyurethane Foam, Stone Aggregate Ballast</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Product Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G06_CRRCProductID" type="env:CRRCProductID">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CRRC Product ID Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else User input: product ID from CRRC Directory 
Else allow user to enter N/A stored in NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CRRC Product ID Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else User input: product ID from CRRC Directory 
Else allow user to enter N/A stored in NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="G06After_HeadingForG07toG10">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Proposed</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for G07-G10</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G07_CRRC_InitialReflectance" type="env:CRRC_InitialReflectance">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Initial Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else user inputs DecimalNonnegative from CRRC Directory (0.xx value which must be GT 0  and LT 1);  
Else allow user to enter N/A.
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Initial Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else user inputs DecimalNonnegative from CRRC Directory (0.xx value which must be GT 0  and LT 1);  
Else allow user to enter N/A.
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G08_SolarReflectanceAged" type="com:SolarReflectanceAged">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else User input: DecimalNonnegative (0.xx value which must be GT 0  and LT 1).
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G08_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G09_ThermalEmittance" type="com:ThermalEmittance">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
Else User input: DecimalNonnegative (0.xx value which must be GT 0  and LT 1).
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; 
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G10_SolarReflectanceIndex" type="env:SolarReflectanceIndex">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else If G04_CoolRoofComplianceMethod != SolarRefectanceIndex  result = N/A stored in the NotApplicableMessage;  Else  user enters value from CRRC directory or from a completed SRI Worksheet.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else If G04_CoolRoofComplianceMethod != SolarRefectanceIndex  result = N/A stored in the NotApplicableMessage;  Else  user enters value from CRRC directory or from a completed SRI Worksheet.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element minOccurs="0" name="G10After_HeadingForG11toG13">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             <ns1:b>Minimum Required</ns1:b>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">This multicolumn heading is for G11-G13</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G11_SolarReflectanceAgedLimit" type="env:SolarReflectanceAgedLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else If A09_ClimateZone == 13 or 15 And  G03_IsRoofPitchGreaterThan2Run12Rise == false,  result = 0.63; Else If A09_ClimateZone == InclusiveRange (10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.20; Else for all other combinations of climate zone and roof pitch, the result = N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G11_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Aged Solar Reflectance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else If A09_ClimateZone == 13 or 15 And  G03_IsRoofPitchGreaterThan2Run12Rise == false,  result = 0.63; Else If A09_ClimateZone == InclusiveRange (10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.20; Else for all other combinations of climate zone and roof pitch, the result = N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G12_ThermalEmittanceLimit" type="com:ThermalEmittanceLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field:  If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else If A09_ClimateZone == 13 or 15 And if G03_IsRoofPitchGreaterThan2Run12Rise ==  false and  If G04_CoolRoofComplianceMethod ==  SolarRefectanceIndex  result =  0.85; Else  if G04_CoolRoofComplianceMethod ==  AgedSolarReflectanceThermaEmittance  result  0.75;  Else If A09_ClimateZone == InclusiveRange (10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.75; Else for all other combinations of climate zone and roof pitch, the result = N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G12_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Thermal Emittance</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else  If A09_ClimateZone == 13 or 15 And if G03_IsRoofPitchGreaterThan2Run12Rise ==  false and  If G04_CoolRoofComplianceMethod ==  SolarRefectanceIndex  result =  0.85; Else  if G04_CoolRoofComplianceMethod ==  AgedSolarReflectanceThermaEmittance  result  0.75;  Else If A09_ClimateZone == InclusiveRange (10, 15) and G03_IsRoofPitchGreaterThan2Run12Rise == true result = 0.75; Else for all other combinations of climate zone and roof pitch, the result = N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G13_SolarReflectanceIndexLimit" type="env:SolarReflectanceIndexLimit">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else  If CoolRoofComplianceMethod != SolarRefectanceIndex  result is N/A stored in the NotApplicableMessage;   Else If G03_IsRoofPitchGreaterThan2Run12Rise == false And A09_ClimateZone ==  13 or 15 then result = 75; Else If G03_IsRoofPitchGreaterThan2Run12Rise == true And A09_ClimateZone == InclusiveRange(10, 15) result =16;  Else for all other combinations of climate zone and roof pitch, result is N/A stored in the NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G13_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SRI (optional)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If G02_CoolRoofException != NoException result = N/A stored in NotApplicableMessage; Else  If CoolRoofComplianceMethod != SolarRefectanceIndex  result is N/A stored in the NotApplicableMessage;   Else If G03_IsRoofPitchGreaterThan2Run12Rise == false And A09_ClimateZone ==  13 or 15 then result = 75; Else If G03_IsRoofPitchGreaterThan2Run12Rise == true And A09_ClimateZone == InclusiveRange(10, 15) result =16;  Else for all other combinations of climate zone and roof pitch, result is N/A stored in the NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="GEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Notes:</ns1:b>
                            
                           <ns1:l t="*">
                              <ns1:list>Exception 1 Any roof area covered by building integrated photovoltaic (PV) panels or solar thermal panels is not required to comply with Cool Roof requirements</ns1:list>
                              

                              <ns1:list>
                                  Exception 2: Roof construction with a weight of 25 pounds per square foot (lb/ft
                                 <ns1:sup>2</ns1:sup>
                                 ) or greater are not required to comply with Cool Roof requirements. 
                              </ns1:list>
                              <ns1:list>Liquid field applied coatings must comply with installation criteria from Section 110.8(i)4</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_H">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Opaque Swinging Doors to Exterior (Section 150.1(c)5)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required if the project has any opaque swinging doors</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDoors">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="H01_DoorName" type="env:DoorName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input string (max 50 characters)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H02_DoorArea" type="env:DoorArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Area</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H03_UFactor" type="com:UFactor">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Proposed U-factor</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H04_DoorCertificationMethod" type="env:DoorCertificationMethod">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Proposed U-factor Source</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user selects from list: NFRCRated display term NFRC, AreaWeightedWorksheet display term Area-weighted Average Worksheet (ENV-02)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H05_UFactorLimit" type="com:UFactorLimit">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Required Maximum U-factor</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">default result = 0.20</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H06_IsValueWeightedAverage" type="comp:IsValueWeightedAverage">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Weighted average (Yes/No)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If H03_UFactor GT 0.20 result = true display term Yes; Else result = false display term No.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="H07_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="HEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Notes: 
                           <ns1:l t="*">
                               
                              <ns1:list>Any door with 25% or more glass is counted as a fenestration product in tables I and J. </ns1:list>
                              <ns1:list> Do not include fire-rated doors between garage or unconditioned space and conditioned space.</ns1:list>
                              <ns1:list> If using weighted average to achieve required maximum U-factor, attach CF1R-ENV-02-E.</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Fenestration/Glazing Allowed Areas and Efficiencies (Section 150.1(c)3)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="I01_GlazingAreaLimitAll" type="env:GlazingAreaLimitAll">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Maximum Allowed Fenestration Area For All Orientation (ft
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculation: result = A10_BuildingTotalConditionedFloorArea x  0.20</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I02_GlazingAreaLimitWest" type="env:GlazingAreaLimitWest">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">
                              Maximum Allowed West-Facing Fenestration Area Only  (ft
                              <ns1:sup>2</ns1:sup>
                              )
                           </xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If A09_ClimateZone== 1, 3,  or 5  result = N/A stored in NotApplicableMessage;  
Else result =  A10_BuildingTotalConditionedFloorArea  x 0.05
End If</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I02_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">
                              Maximum Allowed West-Facing Fenestration Area Only  (ft
                              <ns1:sup>2</ns1:sup>
                              )
                           </xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If A09_ClimateZone == 1, 3,  or 5 result = N/A stored in NotApplicableMessage End If</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="I03_UFactorLimit" type="com:UFactorLimit">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Allowed  U-factor (Windows)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If A09_ClimateZone == InclusiveRange( 1,5 ) Or InclusiveRange(11, 14 ) Or 16 result = 0.27 Else result =  0.30</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I04_UFactorLimitSkylight" type="com:UFactorLimitSkylight">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Allowed  U-factor (Skylight)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If A14_FenestrationUfactorSHGC150_1c3A_Exception includes  FenestrationGlazingSkylightLTE16Ft2 or FenestrationGlazingSkylightTubularLTE3Ft2, result = 0.40; Else result = 0.30 </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I05_SHGC_Limit" type="com:SHGC_Limit">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in NotApplicableMessage;  Else If A09_ClimateZone == 15 result = 0.20 result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I05_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Windows)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in NotApplicableMessage;  Else If A09_ClimateZone == 15 result = 0.20 result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="I06_SHGC_LimitSkylight" type="com:SHGC_LimitSkylight">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Skylight)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightLTE16Ft2 or FenestrationGlazingSkylightTubularLTE3Ft2, result = 0.30; Else result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="I06_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Maximum Allowed SHGC (Skylight)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field:  If A09_ClimateZone == 1, 3, 5 Or 16 result = N/A stored in NotApplicableMessage;  Else If A14_FenestrationUfactorSHGC150_1c3A_Exception includes FenestrationGlazingSkylightLTE16Ft2 or FenestrationGlazingSkylightTubularLTE3Ft2, result = 0.30; Else result = 0.23</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element minOccurs="0" name="I07_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comments</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input: Text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_J">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Fenestration Proposed Areas and Efficiencies (Section 150.1(c)3)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">Each row in the table is for a unique type of vertical fenestration or skylight in the project.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="J_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Note: 
                           <ns1:line1/>
                            If meeting Execption 1 to 150.1(c)3A, New dwelling units with a conditioed floor area of 500 square feet or less in Climate Zzone 5 may comply with a maximum U-factor of 0.30. 
                           <ns1:line1/>
                            
If meeting Exception 2 to 150.1(c)3A, Installing less than or equal to 3 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) glass in door, or less than or equal to 3 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) tubular sklight, it is assumed to meet the minimum required U-factor of 0.27 for climate zones 1 through 5, 11 through 14 and 16, and 0.30 for climate zones 6 through 10 and 15, and SHGC of 0.23 for climate zones 2, 4, 6 through 14 and 0.20 for climate zone 15. 
                           <ns1:line1/>
                           
If meeting Exception 3 to 150.1(c)3A, Installing less than or equal to 3 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) tubular skylight, or installing less than or equal to 16 square feet (ft
                           <ns1:sup>2</ns1:sup>
                           ) tubular skylight, it is assumed to meet the minimum required U-factor 0.40 and SHGC of 0.30. In Climate Zones 1, 3, 5 and 16 there is no SHGC requirement. 
                           <ns1:line1/>
                            
Doors with greater than or equal to 25 percent glazing are considered glazed doors and are treated as a fenestration product.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableFenestration">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="J01_FenestrationName" type="comp:FenestrationName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tag/ID</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input string max 50 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J02_FenestrationAdditionType" type="env:FenestrationAdditionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fenestration Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list:  FixedWindow  display text: fixed window, OperableWindow display text: operable window, Skylight display text: skylight, TubularSkylight (only allow if A14 contains FenestrationGlazingSkylightTubularLTE3Ft2)  display text: tubular skylight,   GlazedDoor (only allow if A14 contains FenestrationGlazingDoorLTE3Ft2)   display text: glass in door</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J03_FenestrationFraming">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Frame Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: Metal,  Metal Thermal Break,  Non-metal</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="env:FenestrationFraming">
                                             
                                             
                                             <xs:enumeration value="MetalFraming"/>
                                             
                                             
                                             <xs:enumeration value="MetalFramingWithThermalBreak"/>
                                             
                                             
                                             <xs:enumeration value="NonMetalFraming"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J04_DynamicGlazingType" type="env:DynamicGlazingType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dynamic Glazing</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list:  ChromogenicGlazing display term Chromogenic Glazing, IntegratedShadingDevice display term Integrated Shading Device and NoDynamicGlazing display term None</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J05_CardinalOrientation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Orientation N, S, W, E</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list:  North, South, East, West</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="com:CardinalOrientation">
                                             
                                             
                                             <xs:enumeration value="East"/>
                                             
                                             
                                             <xs:enumeration value="North"/>
                                             
                                             
                                             <xs:enumeration value="South"/>
                                             
                                             
                                             <xs:enumeration value="West"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J06_PanesPerLight">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText"># of Panes</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: Single Pane,  Double Pane,   Triple Pane</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="env:PanesPerLight">
                                             
                                             
                                             <xs:enumeration value="DoublePane"/>
                                             
                                             
                                             <xs:enumeration value="SinglePane"/>
                                             
                                             
                                             <xs:enumeration value="TriplePane"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="J07_TotalGlazingAreaEastSameTypeAndFrame" type="env:TotalGlazingAreaEastSameTypeAndFrame">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Proposed Fenestration Area  (ft
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If J05_CardinalOrientation == West, result is N/A stored in NotApplicableMessage; Else user input DecimalNonnegative and store in property appropriate for the cardinal orientation as follows:  If J05_CardinalOrientation == East, store value in TotalGlazingAreaEastSameTypeAndFrame; Else J05 == North, store  in TotalGlazingAreaNorthSameTypeAndFrame; Else If J05 == South, store in TotalGlazingAreaSouthSameTypeAndFrame;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="J07_TotalGlazingAreaNorthSameTypeAndFrame" type="env:TotalGlazingAreaNorthSameTypeAndFrame">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Proposed Fenestration Area  (ft
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If J05_CardinalOrientation == West, result is N/A stored in NotApplicableMessage; Else user input DecimalNonnegative and store in property appropriate for the cardinal orientation as follows:  If J05_CardinalOrientation == East, store value in TotalGlazingAreaEastSameTypeAndFrame; Else J05 == North, store  in TotalGlazingAreaNorthSameTypeAndFrame; Else If J05 == South, store in TotalGlazingAreaSouthSameTypeAndFrame;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="J07_TotalGlazingAreaSouthSameTypeAndFrame" type="env:TotalGlazingAreaSouthSameTypeAndFrame">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
