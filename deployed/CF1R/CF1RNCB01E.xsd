                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="L04_DirectlyVentedToOutside" type="comp:DirectlyVentedToOutside">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Directly Vented to Outside</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects Yes (result = true) or No (result = false)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="L05_AtticVentFreeAreaInstalled" type="env:AtticVentFreeAreaInstalled">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Attic Free Vent area (in
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input decimal nonnegative  Check If result GTE L07_AtticVentFreeAreaRequired result complies, Else flag as non-compliant</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L05After_HeadingForL06toL07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b>Required</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="L06_WholeHouseCoolingVentilationLimit" type="com:WholeHouseCoolingVentilationLimit">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Airflow Rate (CFM)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: result = 1.5 CFM per ft2 x A10_ BuildingTotalConditionedFloorArea</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="L07_AtticVentFreeAreaRequired" type="env:AtticVentFreeAreaRequired">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Minimum Attic Vent Free Area (in
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field:  result = L03_WholeHouseFansTotalRatedAirFlow x  0.192</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="L08_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Location/Comments</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_M">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Water Heating Systems (Section 150.1(c)8)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="M_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">List water heaters and boilers for both domestic hot water (DHW) heaters and hydronic space heating.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableWaterHeating">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="M01_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heating System ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M02_WaterHeatingSystemOption">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             System Option (from 
                                             <ns1:t24ref h="150.1(c)8"/>
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: OptionSingleHWH display term 1, OptionTier3SingleHWH display term 2, OptionSolarWH display term 3, include this option only If A10_ResidentialBuildingTotalConditionedFloorArea LTE 500 OptionElectInstantaneous display term 4</xs:documentation>
                                          
                                          
                                          <xs:appinfo source="displayterm">
                                             
                                             
                                             <ns2:displayterm value="OptionSingleHWH">1</ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="OptionTier3SingleHWH">2</ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="OptionSolarWH">3</ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="OptionElectPointOfUse">4</ns2:displayterm>
                                             
                                          
                                          </xs:appinfo>
                                                                                    
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:WaterHeatingSystemOption">
                                             
                                             
                                             <xs:enumeration value="OptionElectPointOfUse"/>
                                             
                                             
                                             <xs:enumeration value="OptionSingleHWH"/>
                                             
                                             
                                             <xs:enumeration value="OptionSolarWH"/>
                                             
                                             
                                             <xs:enumeration value="OptionTier3SingleHWH"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M03_WaterHeaterTotalSystemCount" type="hvac:WaterHeaterTotalSystemCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText"># of Water Heaters/Compressors in System</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M04_ResidentialWaterHeaterType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heater Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If  M02_WaterHeatingSystemOption == OptionElectPointOfUse 
result = ElectricPOUConsumer; 
 
Else If  M02_WaterHeatingSystemOption == OptionSingleHWH result =  HeatPumpWaterHeater 
Else If M02_WaterHeatingSystemOption == OptionTier3SingleHWH   result = NEEA_Tier3HP 
Else If M02_WaterHeatingSystemOption == OptionSolarWH result = SolarElectBackup End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ResidentialWaterHeaterType">
                                             
                                             
                                             <xs:enumeration value="HeatPumpWaterHeater"/>
                                             
                                             
                                             <xs:enumeration value="ElectricPOUConsumer"/>
                                             
                                             
                                             <xs:enumeration value="NEEA_Tier3HP"/>
                                             
                                             
                                             <xs:enumeration value="SolarElectBackup"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M05_WaterHeaterFuelSource">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fuel Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If M02_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH result = WaterHeatingHP; Else If M02_WaterHeatingSystemOption  == OptionSolarWH Or OptionElectPointOfUse result = Electricity </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                                                              
				       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:WaterHeaterFuelSource">
                                             
                                             
                                             <xs:enumeration value="Electricity"/>
                                             
                                             
                                             <xs:enumeration value="WaterHeatingHP"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="M06_TankLocation">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Location</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If M03_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH
 user selects from list: Conditioned Or Garage; Else result = N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:TankLocation">
                                                
                                                
                                                <xs:enumeration value="Conditioned"/>
                                                
                                                
                                                <xs:enumeration value="Garage"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="M06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Location</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If M03_WaterHeatingSystemOption  == OptionSingleHWH Or OptionTier3SingleHWH
 user selects from list: Conditioned Or Garage; Else result = N/A stored in NotApplicableMessage.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="M07_ResidentialDHWDwellingUnitDistributionType" type="hvac:ResidentialDHWDwellingUnitDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Distribution Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If A09_ClimateZone == 1 If M02_WaterHeatingSystemOption  == OptionSingleHWH result = CompactHotWaterDistributionSystemBasic End If
Else If  A09_ClimateZone == 16 If M02_WaterHeatingSystemOption  == OptionSingleHWH result = CompactDistributionDrainHeatRecoveryHERS Else M02_WaterHeatingSystemOption  == OptionTier3SingleHWH result = DrainWaterHeatRecoveryHERS End If
Else If A10_ BuildingTotalConditionedFloorArea LTE 500 If M02_WaterHeatingSystemOption  == OptionElectPointOfUse result = PointOfUse End If
Else User selects from StandardDistribution Or DemandRecirculationManualControl End If</xs:documentation>
                                                   
					
                                       </xs:annotation>
                                                                        
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="M08_WaterHeatingSolarFraction" type="hvac:WaterHeatingSolarFraction">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Minimum Solar Savings Fraction</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If M02_WaterHeatingSystemOption ==   OptionSolarWH result = 0.70 Else result = N/A stored in NotApplicableMessage. End If</xs:documentation>
                                                       
					  
                                          </xs:annotation>
                                                                             
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="M08_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Minimum Solar Savings Fraction</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If M02_WaterHeatingSystemOption ==   OptionSolarWH result = 0.70 Else result = N/A stored in NotApplicableMessage. End If</xs:documentation>
                                                                                          
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="MEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Options: 
                           <ns1:l t="#">
                              <ns1:list>
                                  A single 240 volt heat pump water heater (HPWH).  Installed in conditioned space or garage.
                                 <ns1:line1/>
                                 <ns1:tab2/>
                                 A. In climate zone 1, compact hot water distribution is required. 
                                 <ns1:line1/>
                                 <ns1:tab2/>
                                 B. In climate zone 16, compact hot water distribution and a drain water heat recovery (ECC) is required. 
                              </ns1:list>
                              

                              <ns1:list>
                                   A single 240 volt HPWH rated Tier 3 or higher by Northwest Energy Efficiency Alliance (NEEA). Installed in conditioned space or garage.
                                 <ns1:line1/>
                                 <ns1:tab2/>
                                 a.  In climate zone 16, a drain water heat recovery (ECC) is required. 
                              </ns1:list>
                              

                              <ns1:list>A solar water-heating system with a minimum annual solar savings fraction of 0.7 and an electric backup meeting the installation criteria specified in Reference RA4. </ns1:list>
                              <ns1:list>In new dwelling units that are 500 square feeet of less, an electric water heater with point of use distribution. </ns1:list>
                           </ns1:l>
                            
                           <ns1:line2/>
                           Notes 
                           <ns1:line1/>
                           <ns1:tab1/>
                           A single 120V HPWH may be installed in place of a 240V HPWH for new dwelling units with 1 bedroom or less.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_N">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Photovoltaic (PV) Requirements (Section 150.1(c)14)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TablePV">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="Pv01_ArrayName" type="hvac:ArrayName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">PV Array ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Pv02_PV_AdjustmentFactorA" type="comp:PV_AdjustmentFactorA">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Value A from Table 150.1-C</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: assigning value A for project climate zone 
Switch (A09_ClimateZone)
case 1: result = 0.793
case 2: result = 0.621
case 3: result = 0.628
case 4: result = 0.586
case 5: result = 0.585
case 6: result = 0.594
case 7: result = 0.572
case 8: result = 0.586
case 9: result = 0.613
case 10: result = 0.627
case 11: result = 0.836
case 12: result = 0.613
case 13: result = 0.894
case 14: result = 0.741
case 15: result = 1.56
case 16: result = 0.59
End Switch</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Pv03_PV_AdjustmentFactorB" type="comp:PV_AdjustmentFactorB">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Value B from Table 150.1-C</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: assigning value B for project climate zone 
Switch (A09_ClimateZone)
case 1: result =1.27
case 2: result = 1.22
case 3: result = 1.12
case 4: result = 1.21
case 5: result = 1.06
case 6: result = 1.23
case 7: result = 1.15
case 8: result = 1.37
case 9: result = 1.36
case 10: result = 1.41
case 11: result = 1.44
case 12: result = 1.40
case 13: result = 1.51
case 14: result = 1.26
case 15: result = 1.47
case 16: result = 1.22
End Switch</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Pv04_PV_MinimumSize" type="comp:PV_MinimumSize">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Minimum PV Size from Equation 150.1-C</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: result = ( (A10_ResidentialBuildingTotalConditionedFloorArea x Pv02_PV_AdjustmentFactorA) / 1000)  +  Pv03_PV_AdjustmentFactorB)</xs:documentation>
                                          
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Pv05_PhotoVoltaicExceptionRes">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">PV System Sizing Exception Applies</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: LimitedSolarAccess display term 1, LT1_8kWdcRequired display term 2, SnowLoad display term 3, PlansBefore2020 display term 4, BatteryStorage display term 5 or NoExceptionsNA display term NA</xs:documentation>
                                          
                                          
                                          <xs:appinfo source="displayterm">
                                             
                                             
                                             <ns2:displayterm value="LimitedSolarAccess">1 </ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="LT1_8kWdcRequired">2 </ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="SnowLoad">3 </ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="PlansBefore2020">4 </ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="BatteryStorage">5 </ns2:displayterm>
                                             
                                             
                                             <ns2:displayterm value="NoExceptionsNA">NA
</ns2:displayterm>
                                             
                                          
                                          </xs:appinfo>
                                          
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:PhotoVoltaicExceptionRes">
                                             
                                             
                                             <xs:enumeration value="BatteryStorage"/>
                                             
                                             
                                             <xs:enumeration value="LimitedSolarAccess"/>
                                             
                                             
                                             <xs:enumeration value="LT1_8kWdcRequired"/>
                                             
                                             
                                             <xs:enumeration value="NoExceptionsNA"/>
                                             
                                             
                                             <xs:enumeration value="PlansBefore2020"/>
                                             
                                             
                                             <xs:enumeration value="SnowLoad"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="Pv06_PV_AdjustedMinimumSize" type="comp:PV_AdjustedMinimumSize">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Adjusted  PV Size from Exception</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Pv05_PhotoVoltaicExceptionRes ==  BatteryStorage result = Pv04_PV_MinimumSize x 0.75 Else If Pv05_PhotoVoltaicExceptionRes == NoExceptionsNA result =  Pv04_PV_MinimumSize;
Else result =  N/A stored in NotApplicableMessage End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="Pv06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Adjusted  PV Size from Exception</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Pv05_PhotoVoltaicExceptionRes ==  BatteryStorage result = Pv04_PV_MinimumSize x 0.75 Else If Pv05_PhotoVoltaicExceptionRes == NoExceptionsNA result =  Pv04_PV_MinimumSize;
Else result =  N/A stored in NotApplicableMessage End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="Pv07_PV_MaxSizeSARA" type="comp:PV_MaxSizeSARA">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Solar Access Roof Area (SARA)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="Pv07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Solar Access Roof Area (SARA)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Pv05_PhotoVoltaicExceptionRes !=  BatteryStorage And Pv05_PhotoVoltaicExceptionRes != NoExceptionsNA result =  NotApplicableMessage
Else result =  N/A stored in NotApplicableMessage End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="Pv08_RoofSlope" type="env:RoofSlope">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Roof Slope Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from LowSlope and SteepSlope </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                   
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="Pv09_PV_MaxSizeSARA" type="comp:PV_MaxSizeSARA">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Adjusted PV System Size</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Pv06_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage; Else If Pv08_RoofSlope == LowSlope result1 = Pv06_PV_AdjustedMinimumSize x 14 Else result1 = Pv06_PV_AdjustedMinimumSize x 18 End If;
If result1 less than Pv06_PV_AdjustedMinimumSize then result = result1 Else result = Pv06_PV_AdjustedMinimumSize</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="Pv09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Adjusted PV System Size</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If Pv06_NotApplicableMessage == N/A result = N/A stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                   
                                    <xs:element minOccurs="0" name="Pv10_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PvEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Exceptions: 
                           <ns1:l t="#">
                              <ns1:list>Solar Access Roof Area (SARA) is less than 80 contiguous sqare feet. </ns1:list>
                              <ns1:list>No PV system is required when the mnimum PV system size specified by Section 150.1c(14) is less than 1.8kWdc. </ns1:list>
                              

                              <ns1:list>Enforcement authority determines it is not possible for PV system to meet the requirements of the American Society of Civil Engineers, Standard 7-16, Chapter 7, Snow Loads. </ns1:list>
                              <ns1:list>Buildings approved prior to January 1, 2020 </ns1:list>
                              

                              <ns1:list>PV system size is reduced by 25% when installed with a BESS (battery storage system) meeting the Joint Appendix JA12 requirements with a minimum cycling capacity of 7.5kWh. </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_O">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Indoor Air Quality (IAQ) Fan Information</xs:documentation>
                             
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableFansIAQ">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="Fan01_FanName" type="hvac:FanName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fan Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user iput</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Fan02_VentilationSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">IAQ Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: SupplyVent display term Supply, Balanced display term Balanced, BalancedERV display term Balanced ERV, BalancedHRV display term Balanced HRV, 
CentralFanIntegrated display term Central Fan Integrated (CFI), SupplyCentralVent display term Central Ventilation System - Supply, BalancedCentralVent display term Central Ventilation System - Balanced</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:VentilationSystemType">
                                             
                                             
                                             <xs:enumeration value="SupplyVent"/>
                                             
                                             
                                             <xs:enumeration value="Balanced"/>
                                             
                                             
                                             <xs:enumeration value="BalancedERV"/>
                                             
                                             
                                             <xs:enumeration value="BalancedHRV"/>
                                             
                                             
                                             <xs:enumeration value="CentralFanIntegrated"/>
                                             
                                             
                                             <xs:enumeration value="SupplyCentralVent"/>
                                             
                                             
                                             <xs:enumeration value="BalancedCentralVent"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element minOccurs="0" name="Fan03_ComplianceDocumentTableComments" type="comp:ComplianceDocumentTableComments">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Comments</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_P">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Field Verification Summary</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="PBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The enforcement agency shall pay special attention to the ECC Measures specified in this checklist below.  A registered Certificate of Verification for all the measures specified shall be submitted to the building inspector before final inspection.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Quality Insulation Installation - Section 150.1(c)1E</ns1:b>
                             
                           <ns1:l t="*">
                              <ns1:list>The dwelling unit shall meet all of the requirements of Quality Insulation Installation (QII) as specified in Reference Appendices Residential Appendix RA3.5 and be verified by a ECC rater.  </ns1:list>
                           </ns1:l>
                           .
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote2">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Duct Leakage Verification- Section 150.0(m)11</ns1:b>
                           <ns1:l t="*">
                              <ns1:list>Duct leakage testing is required (Reference Appendices, Residential Appendix RA3.1) in all climate zones for ducted heating and cooling systems.</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote3">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Zonally Controlled Systems - Bypass Dampers - Section 150.1(c)13</ns1:b>
                              
                           <ns1:l t="*">
                              <ns1:list>If system is zonally controlled, no bypass ducts are allowed, as confirmed by field verification  (Reference Appendices, Residential Appendix RA 3.4.1.6)</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote4">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Refrigerant Charge Verification Section 150.1(c)7a</ns1:b>
                             
                           <ns1:l t="*">
                              <ns1:list>Refrigerant Charge Testing is required (Reference Appendices, Residential Appendix RA3.2) in climate zones 2 and 8-15 for all air-cooled air conditioners and air source heat pumps.</ns1:list>
                               
                              <ns1:list>Some exceptions apply to factory charged package systems</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote5">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Central System Air Handlers - Air Flow and Fan Efficacy Verification  - Section 150.0(m)13</ns1:b>
                             
                           <ns1:l t="*">
                              <ns1:list>Airflow (minimum 350 cfm/ton) and Fan Efficacy (max 0.58 Watts/cfm for air handlers that are not gas furnace) on systems with ducted air conditioning as field verified by a ECC rater or Return Duct and Filter System Design according to Tables 150.0-C/D will be ECC verified.</ns1:list>
                              

                              <ns1:list>Heat-only systems with Central Fan Integrated (CFI) ventilation are required to have less than 0.45 Watts/ cfm as verified by a ECC rater. </ns1:list>
                              <ns1:list> Small duct high velocity systems: airflow (minimum 250 cfm/ton) and fan efficacy (max 0.62 Watts/cfm) as verified by a ECC rater. </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote6">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Indoor Air Quality (IAQ) Mechanical Ventilation - Section 150.0(o) </ns1:b>
                             
                           <ns1:l t="*">
                              <ns1:list>Mechanical ventilation airflow rate according to American Society for Heating, Refrigerating, and Air-Conditioning Engineers (ASHRAE) 62.2 is required to be verified by a ECC rater (Reference Appendices, Residential Appendix RA3.7)</ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="PNote7">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Ventilation System Fault Indicator Display (FID) - Section 150.1(c)15 </ns1:b>
                             
                           <ns1:l t="*">
                              <ns1:list>All HRV/ERV systems serving individual dwelling units shall have a Fault Indicator Display (FID) as confirmed be field verification Reference Appendices, Joint Appendix JA17. </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
		    
                     </xs:annotation>
                     
                 
                  </xs:element>
                                 
		
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
      
      </xs:sequence>
      
   
   </xs:complexType>
   
   
