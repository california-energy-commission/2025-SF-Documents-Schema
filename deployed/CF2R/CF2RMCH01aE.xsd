                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage == NotApplicable, result = N/A stored in the  NotAppplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
