                                       <xs:element name="E06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference to the C02_EfficiencyType values of  AFUE, COP, HSPF, HSPF2 Or  C02_NotApplicableMessage value of NotApplicable</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E07_EfficiencyInstalledValueAFUE" type="hvac:EfficiencyInstalledValueAFUE">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage == NotApplicable, result = N/A stored in the  NotAppplicableMessage; Else user input numeric  in InclusiveRange (0.0, 100.0); Result value is stored as fraction but displayed as percent.  If result GTE C03_EfficiencyMinimumValueAFUE result complies Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E07_EfficiencyInstalledValueCOP" type="hvac:EfficiencyInstalledValueCOP">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage == NotApplicable, result = N/A stored in the  NotAppplicableMessage; Else user input numeric in InclusiveRange (0.0, 100.0); Result value is stored as fraction but displayed as percent.  If result GTE C03_EfficiencyMinimumValueCOP result complies Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E07_EfficiencyHSPF" type="hvac:EfficiencyHSPF">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage == NotApplicable, result = N/A stored in the  NotAppplicableMessage; Else user input numeric in InclusiveRange (0.0, 100.0); Result value is stored as fraction but displayed as percent.  If result GTE C03_EfficiencyMinimumValueHSPF result complies Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E07_EfficiencyHSPF2" type="hvac:EfficiencyHSPF2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage == NotApplicable, result = N/A stored in the  NotAppplicableMessage; Else user input numeric in InclusiveRange (0.0, 100.0); Result value is stored as fraction but displayed as percent.  If result GTE C03_EfficiencyMinimumValueHSPF2 result complies Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
