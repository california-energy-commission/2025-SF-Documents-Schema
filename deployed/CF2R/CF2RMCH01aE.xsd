         <xs:element minOccurs="0" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Heat Pump System -Efficiency and Performance Compliance Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only if at least one system in section D has D04_ResidentialHeatingSystemType 
Or  D05_ResidentialCoolingSystemType ==  CentralLargePackagedHP, CentralPackagedHP, CentralSplitHP,  DuctlessSplitHP (display term Ductless mini-split HP), DuctedMiniSplitHP, 
AirToWaterHeatPump, GroundSourceHeatPump, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessVRF_HP, SmallDuctHighVelocityHP, HydronicHP, 
HydronicHP_ForcedAir, RoomHP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, VCHP_IndoorUnitDuctedAndDuctless Or HeatPumpDHWCombo.   Require one row of data in this table for each of the SC Systems listed in Section B that is in this list.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHeatPumpPerf">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="I01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled D01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="I03_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference to the C02_EfficiencyType values of  AFUE, COP, HSPF, HSPF2 Or  C02_NotApplicableMessage value of NotApplicable</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="AFUE"/>
                                                
                                                
                                                <xs:enumeration value="COP"/>
                                                
                                                
                                                <xs:enumeration value="HSPF"/>
                                                
                                                
                                                <xs:enumeration value="HSPF2"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference to the C02_EfficiencyType values of  AFUE, COP, HSPF2 Or  C02_NotApplicableMessage value of NotApplicable</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="I04_EfficiencyInstalledValueAFUE" type="hvac:EfficiencyInstalledValueAFUE">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage ==NotApplicable, result = N/A stored in the  NotAppplicableMessage;  Else user input numeric result stored as fraction in InclusiveRange ( 0.00, 1.0) and displayed as percent (result * 100);   For all systems except D04__ResidentialHeatingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, check that result GTE C03_EfficiencyMinimumValueAFUE to comply, Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I04_EfficiencyInstalledValueCOP" type="hvac:EfficiencyInstalledValueCOP">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage ==NotApplicable, result = N/A stored in the  NotAppplicableMessage;  Else user input numeric result stored as fraction in InclusiveRange ( 0.00, 1.0) and displayed as percent (result * 100);   For all systems except D04__ResidentialHeatingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, check that result GTE C03_EfficiencyMinimumValueCOP to comply, Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I04_EfficiencyHSPF" type="hvac:EfficiencyHSPF">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage ==  NotApplicable result =  N/A stored in the  NotAppplicableMessage;  Else user input numeric result stored as fraction in InclusiveRange ( 0.00, 1.0) and displayed as percent (result * 100);   For all systems except D04__ResidentialHeatingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, check that result GTE C03_EfficiencyMinimumValueHSPF to comply, Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I04_EfficiencyHSPF2" type="hvac:EfficiencyHSPF2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage ==  NotApplicable result =  N/A stored in the  NotAppplicableMessage;  Else user input numeric result stored as fraction in InclusiveRange ( 0.00, 1.0) and displayed as percent (result * 100);   For all systems except D04__ResidentialHeatingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, check that result GTE C03_EfficiencyMinimumValueHSPF2 to comply, Else flag non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="I04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C03_NotApplicableMessage ==  NotApplicable result =  N/A stored in the  NotAppplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
