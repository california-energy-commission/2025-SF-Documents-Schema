         <xs:element maxOccurs="1" minOccurs="0" name="Section_J">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Duct System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent CF1R-PRF Certificate of Compliance (CC)
 
This Section is applicable only if  one or more systems in section D has  value for D07_DuctLocation != Ductless.  Require one row in this table for each space conditioning system in section E field E02 that meets the following two conditions: D04_ResidentialHeatingSystemType == GasPackagedFurnace And D07 != Ductless.  
Also require one row in this table for each indoor unit in section E field E03 that meets the following two conditions: D04_ResidentialHeatingSystemType == GasPackagedFurnace  And value in E03 != G03
Also require one row in this table for each space conditioning system in section F field F02 that meets the following three conditions: D05_ResidentialCoolingSystemType = CentralPackagedAC Or CentralLargePackagedAC And E02 != F02 (the same packaged unit is not already listed in section E) And D07_DuctLocation !=DuctsNone.  
Also require one row in this table for each space conditioning system in Section H field H02 that meets the following three conditions: D05_ResidentialCoolingSystemType = CentralPackagedHP Or CentralLargePackagedHP And E02 != F02 (the same packaged unit is not already listed in section E) And D07_DuctLocation != DuctsNone.  
Also require one row of data to be entered for each indoor unit in E03_IndoorUnitName where E05_IndoorUnitDucts == DuctsGT10Ft Or  DuctsLTE10Ft; Also require one row of data for each indoor unit in G03_IndoorUnitName where G05_IndoorUnitDucts ==  DuctsGT10Ft Or  DuctsLTE10Ft;</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDuctSystem">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="J01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference to one of the ResidentialSpaceConditioningSystemName listed in section B</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">From section B  the ResidentialHvacSystemAreaServed for this system</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D04_ResidentialHeatingSystemType ==GasPackagedFurnace result = D02_ResidentialHvacSystemAreaServed; Else if D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP result = D02_ResidentialHvacSystemAreaServed;  Else reference applicable values in E03_IndoorUnitName and G03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J04_SupplyDuctLocation" type="hvac:SupplyDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Supply Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D07_DuctLocation  == DuctedAndDuctlessIndoorUnits, user selects value from list below; Else reference value from D07_DuctLocation as default and allow user to overwrite only the following default values from D07: UnconditionedAttic, UnconditionedGarage , or Outdoors.  If overriding, user picks from this list: ConditionedSpace, ConditionedSpaceDuctsVLL, ConditionedSpaceExcep12ft,  ControlledVentilationCrawlSpace, DuctsInMultipleLocations, Outdoors, UnconditionedAttic, UnconditionedBasement, UnconditionedCrawlSpace, UnconditionedGarage.  Flag non-default values and report in project status notes field.  a revised parent CC-PRF  may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J05_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Supply Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If C10_DuctRValueLimit  == RvalueVerifiedDuctSystem then result is RvalueVerifiedDuctSystem; Else user selects from list of R-values: R0, R2.1, R4.2, R6, R8, R10 or R12. Check that result GTE  C10_DuctRValueLimit value  to comply subject to these exceptions: If D07_DuctLocation ==  ConditionedSpaceDuctsVLL Or J08_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned  Then R0, R2.1, Or R4.2 complies.  Else flag it as non-compliant value and do not allow registration to proceed.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                             
                                             <xs:enumeration value="RvalueVerifiedDuctSystem"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J06_ReturnDuctLocation" type="hvac:ReturnDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Return Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D07_DuctLocation  == DuctedAndDuctlessIndoorUnits, user selects value from list below; Else reference value from D07 as default.  Allow user to overwrite only the following default values from D07: UnconditionedAttic, UnconditionedGarage , or Outdoors.  If overriding, user selects from list: ConditionedSpace, ConditionedSpaceDuctsVLL, ConditionedSpaceExcep12ft,  ControlledVentilationCrawlSpace, DuctsInMultipleLocations, Outdoors, UnconditionedAttic, UnconditionedBasement, UnconditionedCrawlSpace, UnconditionedGarage.  Flag non-default values and report in project status notes field.  a revised parent CC-PRF may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J07_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Return Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If C10_DuctRValueLimit  == RvalueVerifiedDuctSystem then result is RvalueVerifiedDuctSystem; Else user selects from list of R-values:   R0, R2.1, R4.2, R6, R8, R10 or R12. Check that result GTE  C10_DuctRValueLimit value  to comply subject to these exceptions: If D07_DuctLocation ==  ConditionedSpaceDuctsVLL Or J08_DuctMinimumRValueExceptions ==  RValueLT6EntirelyInConditioned  Then R0, R2.1, Or R4.2 complies.  Else flag it as non-compliant value and do not allow registration to proceed.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                             
                                             <xs:enumeration value="RvalueVerifiedDuctSystem"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J08_DuctMinimumRValueExceptions">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exception from Min R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">default result = NoException; Allow user to override and select one from list;  
UninsulatedInDirectConditioning display term Portions of Ducts uninsulated  or less than R-6 in conditioned space
 
If J04_SupplyDuctLocation And J06_ReturnDuctLocation == ConditionedSpace add to list   
RValueLT6EntirelyInConditioned display term Ducts uninsulated or less than R-6 entirely in Conditioned Space</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctMinimumRValueExceptions">
                                             
                                             
                                             <xs:enumeration value="NoException"/>
                                             
                                             
                                             <xs:enumeration value="RValueLT6EntirelyInConditioned"/>
                                             
                                             
                                             <xs:enumeration value="UninsulatedInDirectConditioning"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J09_DuctFilterGrilleSizingComplianceMethod">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Method of compliance with Airflow and Fan Efficacy Req's in 150.0(m)13</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D05_ResidentialCoolingSystemType == NoCooling, then result = ExemptNoCooling, display term: Exempt - No Cooling,  
Else If  D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == EvaporativeDirect,  EvaporativeIndirect, EvaporativeIndirectDirect, result = ExemptEvaporativeSystem display term Exempt - Evaporative System
Else If  D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless  then result = ExemptVCHP  display term Exempt - VCHP System 
Else If J12_CanRA3_3AirflowProtocolsTestSystem == false Then result = ExemptRA3_3Protocols display term: Exempt - Approved Protocols are N/A;    
 
Else If parent CC-PRF indicates ECC Verification = required, If one or more of the following conditions are true: 
(1) C09_ MaximumCoolingWperCFM LT 0.58 And D04_ResidentialHeatingSystemType != CentralGasFurnace, GasPackagedFurnace Or  
(2) C09_ MaximumCoolingWperCFM LT 0.62 And D05_ResidentialCoolingSystemType == SmallDuctHighVelocityAC Or SmallDuctHighVelocityHP  
(3) C09_ MaximumCoolingWperCFM LT 0.45 And D04_ResidentialHeatingSystemType == CentralGasFurnace, GasPackagedFurnace Or   
(4) C08_AirflowPerUnitCoolingCapacity GT 350 And D05_ResidentialCoolingSystemType != SmallDuctHighVelocityAC Or SmallDuctHighVelocityHP  
(5) C08_AirflowPerUnitCoolingCapacity GT 250 And D05_ResidentialCoolingSystemType == SmallDuctHighVelocityAC Or SmallDuctHighVelocityHP 
(6) D09_ResidentialCoolingZoneType == ZoneControlled, 
(7) If E04 Or G06 == true  then 
result = HERS_FanEfficacyAirflowRate, display term: ECC Verified Fan Efficacy and Airflow Rate; 
 
Else (none of previous conditions are true) 
user selects from  list: 
 HERS_FanEfficacyAirflowRate, display text: ECC Verified Fan Efficacy and Airflow Rate, or HERS_ReturnDuctDesignTable150, display text:  ECC verified Return Duct Design per Table 150.0-B,C; 
End If</xs:documentation>
                                          
                                          
                                          <xs:appinfo source="displayterm">
                                             
                                             
                                             <ns2:displayterm value="ExemptRA3_3Protocols">Exempt - Approved Protocols are N/A</ns2:displayterm>
                                             
                                          
                                          </xs:appinfo>
                                          
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctFilterGrilleSizingComplianceMethod">
                                             
                                             
                                             <xs:enumeration value="ExemptEvaporativeSystem"/>
                                             
                                             
                                             <xs:enumeration value="ExemptNoCooling"/>
                                             
                                             
                                             <xs:enumeration value="ExemptRA3_3Protocols"/>
                                             
                                             
                                             <xs:enumeration value="ExemptVCHP"/>
                                             
                                             
                                             <xs:enumeration value="HERS_FanEfficacyAirflowRate"/>
                                             
                                             
                                             <xs:enumeration value="HERS_ReturnDuctDesignTable150"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J10_HasBypassDuct" type="hvac:HasBypassDuct">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Bypass Duct Status</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated  field: reference value from B10_HasBypassDuct as default; Allow user to override the default and pick one from list: For Boolean true value display text: Has Bypass Duct; For Boolean false value display text: None.  Flag non-default values and report in project status notes field; a revised parent CC-PRF may be required</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J11_DuctSystemAirFilterDeviceCount" type="hvac:DuctSystemAirFilterDeviceCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Number of Air Filter Devices on Indoor Unit</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer value which determines number or rows per indoor unit in next section</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J12_CanRA3_3AirflowProtocolsTestSystem" type="comp:CanRA3_3AirflowProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Airflow Protocols be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If system type in D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = false display term No.  
 
Else If system type in D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == CentralSplitAC, CentralSplitHP,   CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC, CentralLargePackagedHP, VCHP_IndoorUnitDucted, Or VCHP_IndoorUnitDuctedAndDuctless 
result = true display term Yes; 
 
Else 
user selects from list: Yes (Boolean true display text) or No  (Boolean false display text).  
End If
 
Check: If result == false, report in project status notes field that exemption from mandatory ECC verification of system airflow has been claimed. Enforcement agency confirmation is recommended.  Also report in project status notes field that better than minimum EER or SEER cannot not be claimed for performance compliance credit if the system cannot comply with the required ECC verification; a revised parent CC-PRF may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J13_CanFanEfficacyProtocolsTestSystem" type="comp:CanFanEfficacyProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Fan Efficacy Protocol be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If  D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless  then  
result = ExemptSystem; 
 
Else If system type in D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = CanNotTest  display term No.  
 
Else  If system type in D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == CentralSplitAC, CentralSplitHP,   CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP 
result = CanTest display term Yes; 
 
Else user selects from list: CanTest display term Yes or CanNotTest  display term No. 
End If 
 
Check: if result == CanNotTest, report in project status notes field that exemption from mandatory ECC verification of system airflow has been claimed. Enforcement agency confirmation is recommended.  Also report in project status notes field that better than minimum EER or SEER cannot not be claimed for performance compliance credit if the system cannot comply with the required ECC verification; a revised parent CC-PRF may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J14_IndoorUnitDucts" type="hvac:IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Total Duct Length</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If applicable value in E05_IndoorUnitDucts or G05_IndoorUnitDucts == DuctsGT10Ft result = DuctsGT10Ft; Else If applicable value in E05_IndoorUnitDucts or G05_IndoorUnitDucts == DuctsLTE10Ft result = DuctsLTE10Ft; Else user selects from list: DuctsLTE10Ft, DuctsGT10Ft</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="J14a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_K">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Air Filter Device Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent CF1R-PRF Certificate of Compliance (CC)
 
This section is required If at least one system in section D has D07_DuctLocation != Ductless And in section J has J14_IndoorUnitDucts == DuctsGT10Ft.  Require one row of data for each in the quantity of air filter devices in J11_DuctSystemAirFilterDeviceCount for each duct system in J03 for which J14_IndoorUnitDucts == DuctsGT10Ft</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="K_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory requirements for air filter devices are specified in Section 150.0(m)12.  The installer shall place a sticker in or near each filter grille that displays the design airflow rate for that filter grille/rack and the maximum allowed clean filter pressure drop at the design airflow rate.  This will inform the occupant of the airflow vs pressure drop performance required for replacement air filters.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableAirFilterDevice">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="K01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from  J03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K04_DuctSystemAirFilterDeviceName" type="hvac:DuctSystemAirFilterDeviceName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Device Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input text maximum 20 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K05_DuctSystemAirFilterDeviceType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Rack Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user select from list:  FilterGrille, Mounted, MountedInline</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctSystemAirFilterDeviceType">
                                             
                                             
                                             <xs:enumeration value="FilterGrille"/>
                                             
                                             
                                             <xs:enumeration value="Mounted"/>
                                             
                                             
                                             <xs:enumeration value="MountedInline"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K06_AirFilterDeviceAirflowRate" type="hvac:AirFilterDeviceAirflowRate">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Airflow Rate for Air Filter Device (cfm)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input numeric xxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K07_AirFilterDeviceDepth" type="hvac:AirFilterDeviceDepth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Depth (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input integer GTE 1</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K08_AirFilterDeviceLength" type="hvac:AirFilterDeviceLength">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Length (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K09_AirFilterDeviceWidth" type="hvac:AirFilterDeviceWidth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Width (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K10_AirFilterDeviceFaceArea" type="hvac:AirFilterDeviceFaceArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Air Filter Calculated Nominal Face Area (inch
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: PRODUCT (K08_AirFilterDeviceLength, K09_AirFilterDeviceWidth )</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="K11_AirFilterDeviceFaceAreaRequiredMin" type="hvac:AirFilterDeviceFaceAreaRequiredMin">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If K07_AirFilterDeviceDepth == 1 result = PRODUCT(K06_AirFilterDeviceAirflowRate / 150, 144) Else If D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or  VCHP_IndoorUnitDuctedAndDuctless result = PRODUCT(K06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="K11_AirFilterDeviceFaceAreaMessage" type="comp:AirFilterDeviceFaceAreaMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If K07_AirFilterDeviceDepth == 1 result = PRODUCT(K06_AirFilterDeviceAirflowRate / 150, 144) Else If D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or  VCHP_IndoorUnitDuctedAndDuctless result = PRODUCT(K06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="K12_AirFilterDeviceFaceAreaCompliance" type="comp:AirFilterDeviceFaceAreaCompliance">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Face Area  Compliance</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If K11_AirFilterDeviceFaceAreaMessage == SpecifiedByDesigner result = SpecifiedByDesigner Else if K10_AirFilterDeviceFaceArea GTE  K11_AirFilterDeviceFaceAreaRequiredMin result = FaceAreaComplies display term Complies esle result = FaceAreaDoesNotComply display term Does Not Comply</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K13_DuctSystemAirFilterDevicePressureDrop" type="hvac:DuctSystemAirFilterDevicePressureDrop">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Allowable Pressure Drop for Air Filter Device (inch W.C.)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or  VCHP_IndoorUnitDuctedAndDuctless result = 0.1 Else If K07__AirFilterDeviceDepth == 1 result = 0.1 Else  user input numeric x.xx in inclusiveRange(0.01,1.5)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K13a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_L">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required If section K is required</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="LBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory Air Filter Device Requirements can be found in Section 150.0(m)12A-E.  Some mandatory requirements may apply in addition to those listed below.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Recirculated and outdoor air filtering</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All recirculated air and all outdoor air (including make up air) supplied to the occupiable space is filtered before passing through the system's thermal conditioning components.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The space conditioning system shall be designed to accommodate the clean-filter pressure drop imposed by the system air filter device(s). The design airflow rate and maximum allowable clean-filter pressure drop at the design airflow rate applicable to each air filter shall be determined by the system designer.  The system installer shall affix a sticker/label to each system air filter grille/rack location that  discloses the filter's design airflow rate and the filter's maximum allowable clean-filter pressure drop at the design airflow rate.  The sticker/labels shall be permanently affixed to the air filter  grille/rack, readily legible, and visible to a person replacing the air filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter access and regular service</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All system air filter devices shall be located and installed in such a manner as to allow access and regular service by the system owner.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media efficiency</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The system shall be provided with air filter media having a designated efficiency equal to or greater than MERV 13 when tested in accordance with ASHRAE Standard 52.2, or a particle size efficiency rating equal to or greater than 50% in the 0.30 to 1.0 
                           <ns1:micron/>
                           m range and equal to or greater than 85 percent in the 1.0 - 3.0 
                           <ns1:micron/>
                           m range when tested in accordance with AHRI Standard 680.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media manufacturer label</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The system shall be provided with air filters that have been labeled by the manufacturer to disclose efficiency and pressure drop ratings that conform to the efficiency and pressure drop requirements for the air filter grilles/racks..</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Prevent air bypassing filter</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Filter racks or grilles shall use gaskets, sealing, or other means to close gaps around inserted filters and prevent air from bypassing the filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="LEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_M">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">ECC Verification Requirements For Duct Systems</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent LMCC-PRF Certificate of Compliance (CC) 
 
This section is required if at least one system in section D has D07_DuctLocation != Ductless.  Require one row or data for each of the indoor units listed in J03</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSDucts">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="M01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from  J03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M04_DuctLeakageTestRequired" type="comp:DuctLeakageTestRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-20  
                                             <ns1:line3/>
                                             Duct Leakage Test
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  
If D04_ResidentialHeatingSystemType  Or D05_ResidentialCoolingSystemType  == VCHP_IndoorUnitDucted Or  VCHP_IndoorUnitDuctedAndDuctless result = true display term Yes; Else reference information from the parent CC-PRF;  If parent CC-PRF flags the requirement for ECC verification of duct leakage for system in M01 then result = true Else result = false. Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M05_DuctsInConditionedSpaceVerification" type="comp:DuctsInConditionedSpaceVerification">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-21 
                                             <ns1:line2/>
                                             Duct Location Verification
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If J08_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned Or UninsulatedInDirectConditioning 
result = true
Else If B06_DuctLocation == ConditionedSpace or ConditionedSpaceExcept12ft  
result = true, 
Else result = false.  
End If
Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M06_AHU_FanEfficacyVerificationRequired" type="comp:AHU_FanEfficacyVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-22 
                                             <ns1:line2/>
                                             AHU Fan Efficacy (W/cfm)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If J13_CanFanEfficacyProtocolsTestSystem == false result = false;  Else If J09_DuctFilterGrilleSizingComplianceMethod == HERS_FanEfficacyAirflowRate then result = true;  Else If E04_DoesUnitProvideCFI_IAQ or G06_DoesUnitProvideCFI_IAQ == true then result = true;  Else result = false.  Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M07_AHU_AirflowRateVerificationRequired" type="comp:AHU_AirflowRateVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-23 
                                             <ns1:line2/>
                                             AHU Airflow Rate (cfm/ton)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: D04_ ResidentialHeatingSystemType Or D05_ ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless result = true;  Else If J09_DuctFilterGrilleSizingComplianceMethod == HERS_FanEfficacyAirflowRate then result = true; Else If  N03_RefrigerantChargeVerificationRequired == true, then  If  M08_ReturnDuctDesignVerificationRequired == false,  then result = true; Else If E04_DoesUnitProvideCFI_IAQ or G06_DoesUnitProvideCFI_IAQ == true then result = true;  Else result = false.  Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M08_ReturnDuctDesignVerificationRequired" type="comp:ReturnDuctDesignVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-28 
                                             <ns1:line1/>
                                             Return Duct Design Table 150.0-B or C
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If  J09_DuctFilterGrilleSizingComplianceMethod == HERS_ReturnDuctDesignTable150   then result = true, Else result = false. Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M09_SupplyDuctSurfaceBuriedRValueVerificationRequired" type="comp:SupplyDuctSurfaceBuriedRValueVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-29 
                                             <ns1:line1/>
                                             Supply Duct Surface Area R-Value Buried Ducts
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If D04_ResidentialHeatingSystemType  Or D05_ResidentialCoolingSystemType  == VCHP_IndoorUnitDucted Or  VCHP_IndoorUnitDuctedAndDuctless result = false display term No; Else reference information from the parent CC-PRF; 
 
Else If the parent CC-PRF flags the requirement for ECC verified duct design ( Supply Duct Surface Area R-Value or Buried Ducts), then result = true; else result = false. Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M10_VentilationCoolingCreditVerificationRequired" type="comp:VentilationCoolingCreditVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH30 
                                             <ns1:line2/>
                                             Central Fan Ventilation Cooling Credit
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: I B05_CFVCS_Type == FixedCFVCS Or VariableCFVCS then result = true; else If B05_NotApplicableMessage == N/A  result = false. Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="M10a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_N">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">ECC Verification Requirements For Space Conditioning Equipment</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent CF1R-PRF Certificate of Compliance (CC) 
 
This section is required If Section_F has data Or If Section H has data.  Require one row of data for each SC System listed in F01_ResidentialSpaceConditioningSystemName and H01_ResidentialSpaceConditioningSystemName</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSEquipment">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="N01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="N02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="N03_RefrigerantChargeVerificationRequired" type="comp:RefrigerantChargeVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-25 
                                             <ns1:line3/>
                                             Refrigerant Charge
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated Field: If the parent CC-PRF flags the requirement for ECC verification of Refrigerant Charge; then result = true; Else If B04_ResidentialCoolingSystemType != D05_ResidentialCoolingSystemType And A02_ClimateZone == 2 Or InclusiveRange(8,15) then result = true;  Else result = false. Display Yes and No to represent Boolean values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="N04_SEER_EER_VerificationRequired" type="comp:SEER_EER_VerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-26 
                                             <ns1:line1/>
                                             Rated SC System Equipment Verification
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  
If N01_ResidentialSpaceConditioningSystemName is one of the HP systems listed in H01 result = true; 
Else If B03_ResidentialHeatingSystemType Or B04_ResidentialCoolingSystemType == DuctedMiniSplitAC, DuctlessMultiSplitAC, DuctlessSplitAC, DuctlessVRF_AC result = false;  
Else If B04_ResidentialCoolingSystemType == SmallDuctHighVelocityAC And C06_EfficiencyMinimumValueSEER2 GT 12 result = true;  
Else If C06_EfficiencyMinimumValueSEER2 IsPresent And GT 14.3  result = true; 
Else If B04_ResidentialCoolingSystemType == CentralPackagedAC And C07_ EfficiencyMinimumValueEER2 IsPresent And GT 11.0 result = true; 
Else If B04_ResidentialCoolingSystemType == CentralSplitAC And C06a_EfficiencyType == EER2 or EER2SEER2 Then 
Else If C07_EfficiencyMinimumValueEER2  GT 11.2 And F10_CondenserRatedCoolingCapacity GTE 45000 result = true; 
Else If C07_EfficiencyMinimumValueEER2  GT 11.7 And F10_CondenserRatedCoolingCapacity LT 45000 result = true; End If
Else result = false; End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="N05_VCHP_CreditVerificationRequired" type="comp:VCHP_CreditVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-33 
                                             <ns1:line1/>
                                             VCHP Compliance Credit
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If  D04_ResidentialHeatingSystemType Or D05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless,  VCHP_IndoorUnitDuctedAndDuctless, result = true display term Yes, Else result = false display term No</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="N05a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_O">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Space Conditioning Systems, Ducts and Fans -Mandatory Requirements and Additional Measures</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="O_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Additional mandatory requirements from Section 150.0 that are not listed here may be applicable to some systems.  These requirements may be applicable to only newly installed equipment or portions of the system that are altered.  Existing equipment may be exempt from these requirements.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O00_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Heating Equipment</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Equipment Efficiency</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Equipment Efficiency: All heating equipment must meet the minimum efficiency requirements of Section 110.1 and Section 110.2(a) and the Appliance Efficiency Regulations.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Controls</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Controls:  All unitary heating systems, including heat pumps, must be controlled by a setback thermostat.  These thermostats must be capable of allowing the occupant to program the temperature set points for at least four different periods in 24 hours. See Sections 150.0(i), 110.2(c).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Sizing:</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Sizing:  Heating load calculations must be done on portions of the building served by new heating systems to prevent inadvertent undersizing or oversizing. See sections 150.0(h)1 and 2 and the exception.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Furnace Temperature Rise</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Furnace Temperature Rise: Central forced-air heating furnace installations must be configured to operate at or below the furnace manufacturer's maximum inlet-to-outlet temperature rise specification. See Section 150.0(h)4.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Standby Losses and Pilot Lights</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Standby Losses and Pilot Lights: Fan-type central furnaces may not have a continuously burning pilot light. Section 110.5 and Section 110.2(d).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O05After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Cooling Equipment</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Equipment Efficiency:</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Equipment Efficiency:  All cooling equipment must meet the minimum efficiency requirements of Section 110.1 and Section 110.2(a) and the Appliance Efficiency Regulations.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Refrigerant Line Insulation</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Refrigerant Line Insulation:  All refrigerant line insulation in split system air conditioners and heat pumps must meet the R-value and protection requirements of Section 150.0(j)1 and 2, and Section 150.0(m)9.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O08">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Condensing Unit Location</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Condensing Unit Location:  Condensing units shall not be placed within five (5) feet of a dryer vent outlet. See Section 150.0(h)3A.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O09">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Liquid Line Filter Drier</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Liquid Line Filter Drier: A liquid line filter drier shall be installed according to the manufacturer's specifications  150.0(h)3B</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O10">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Sizing</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Sizing: Cooling load calculations must be done on portions of the building served by new cooling systems to prevent inadvertent undersizing or oversizing. See Section 150.0(h)1 and 2 and exception.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O10After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Cooling and Heating Equipment (Additional Requirements)</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O11">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">System Selection Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>System Selection:</ns1:b>
                            See Section 150.0(h)5 
                           <ns1:line1/>
                            A. Equipment sizing and selection shall meet the cooling and heating loads of Section 150.0(h) 1 and 2

                           <ns1:line1/>
                           B. Systems shall be sized based on ACCA Manual S-2023 in accordance with these requirements: 
                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>Cooling Capacity:</ns1:b>
                            There is no limit on the minimum capacity. 
                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>urnaces:</ns1:b>
                            Heating capacity shall be sized based on ACCA Manual S-2023, Table N2.5

                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>Heat Pump Heating Capacity:</ns1:b>
                            
                           <ns1:line1/>
                           <ns1:tab2/>
                            a. Minimum: Heating systems are required to have a heating capacity meeting the minimum requirements of the CBC not including any supplemental heating. 
                           <ns1:line1/>
                           <ns1:tab2/>
                            b. Maximum: There is no limit on the maximum heating capacity.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O12">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Defrost Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Defrost:</ns1:b>
                            See Section 150.0(h)6 
                           <ns1:line1/>
                            A. If a heat pump is equipped with an installer adjustable defrost delay timer, the delay timer shall be set to greater than or equal to 90 minutes.

                           <ns1:line1/>
                           B. The installer shall certify on the Certificate of Installation (CF2R) that the control configuration has been tested in accordance with the testing procedure in the CF2R.
                           <ns1:line1/>
                            
                           <ns1:b>Exception 1 to Section 150.0(h)6. </ns1:b>
                            Dwelling units in Climate Zones 6 and 7. 

                           <ns1:line1/>
                            
                           <ns1:b>Exception 1 to Section 150.0(h)6. </ns1:b>
                            Dwelling units with a conditioned floor area of 500 square feet or less in Climate Zones 3, 5 through 10 and 15.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O13">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Supplemental Heating Controls</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Supplementary heating control configuration:</ns1:b>
                            See Section 150.0(h)7 
                           <ns1:line1/>
                            Heat pumps with supplementary heating, including but not limited to, electric resistance heaters or gas furnace supplementary heating, shall comply with the following requirements: 
                           <ns1:b>See Section 150.0(h)7 for exceptions </ns1:b>
                           

                           <ns1:line1/>
                            A. Lock out supplementary heating above an outdoor air temperature of no greater than 35
                           <ns1:deg/>
                           F. There are additional thermostat requirements in Section 150.0(i).

                           <ns1:line1/>
                            B. The installer shall certify on the Certificate of Installation (CF2R) that the control configuration has been tested in accordance with the testing procedure in the CF2R. 

                           <ns1:line1/>
                            C. The controls may allow supplementary heater operation above 35
                           <ns1:deg/>
                           F only during defrost; or when the user selects emergency operation.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O14">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Electric Resistance Sizing</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Sizing of electric resistance supplementary heat:</ns1:b>
                            See Section 150.0(h)8 
                           <ns1:line1/>
                            For heat pumps with electric resistance heating, the capacity of electric resistance heat shall not exceed the heat pump nominal cooling capacity (at 95
                           <ns1:deg/>
                           F ambient conditions) multiplied by 2.7 kW per ton, rounded up to the closest kW.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O15">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Third-party Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Capacity variation with third-party thermostats</ns1:b>
                            See Section 150.0(h)9 
                           <ns1:line1/>
                            Variable or multi-speed systems shall comply with the following requirements: 
                           <ns1:line1/>
                            A. The space conditioning system and thermostat together shall be capable of responding to heating and cooling loads by modulating system compressor speed, and meet thermostat requirements in Section 150.0(i)2
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O15After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Air Distribution System Ducts, Plenums and Fans</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O16">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Insulation</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Insulation: The minimum duct insulation value is R-6 or ducts can be uninsulated if the duct system is located entirely in conditioned space. Note that higher values may be required by the prescriptive or performance requirements. See Section 150.0(m)1B for exceptions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O17">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Connections and Closures</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Connections and Closures: All installed air-distribution system ducts and plenums must be, sealed and insulated to meet the requirements of CMC Sections 601.0, 602.0, 603.0, 604.0, 605.0 and ANSI/SMACNA-006-2006.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O17After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Heat Pump Thermostat</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O18">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Requirements of Section 110.2(b) and (c)</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">A thermostat shall be installed that meets the requirements of Section 110.2(b) and Section 110.2(c).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O19">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Manufacturers published installation specifications</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The thermostat shall be installed in accordance with the manufacturers published installation specifications</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O20">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">First stage of heating</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">First stage of heating shall be assigned to heat pump heating.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O21">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Second stage back up heating</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Second stage back up heating shall be set to come on only when the indoor set temperature cannot be met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O22">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Setback Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Setback Thermostats:  All heating or cooling systems, including heat pumps, not controlled by a central energy management control system (EMCS) shall have a setback thermostat, as specified in Section 110.2(c).  See Section 150.0(i)1</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="O23">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Supplemental Heating Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Thermostats that are applied to heat pumps with supplementary heating . See Section 150.0(i)2 
                           <ns1:line1/>
                            The thermostats controlling heat pumps with electric resistance supplementary heat or gas furnace supplementary heat shall comply with the following requirements: See Section 150.0((i)2 for exceptions. 

                           <ns1:line1/>
                            A. The thermostat shall receive outdoor air temperature from an outdoor air temperature sensor or from an internet weather service.
                           <ns1:line1/>
                            B. The thermostat shall display the outdoor air temperature. 
                           <ns1:line1/>
                            C. As described in 150.0(h)7, the thermostat and heat pump shall lock out supplementary heat when the outdoor air temperature is above 35
                           <ns1:deg/>
                           F.

                           <ns1:line1/>
                            D. The thermostat shall have an indicator to notify when supplementary heat or emergency heat is in use. 
                           <ns1:line1/>
                            E. During defrost or when the user selects emergency heating, supplementary heat operation is permitted above 35
                           <ns1:deg/>
                           F. 
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="OEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_P">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Test of Defrost Delay Timer Setting (Section 150.0(h)6)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="PBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The installing contractor shall confirm that a heat pump's installer-adjustable Defrost Delay Timer Setting (if it exists) is set to no less than 90 minutes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="P01_DefrostDelayTimerTestApplies" type="comp:DefrostDelayTimerTestApplies">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test Applicability. Select the statement describing test applicability for this project:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from TestApplies display term 1. Test applies and no exceptions, NoAdjustDefrostDelayTimer display term 2 Test does not apply because no adjustable Defrost Delay Timer Setting, 
Exception1TestNA display term 3 Test does not apply because of Exception 1 Dwelling units in Climate Zones 6 and 7, Exception2TestNA display term  Test does not apply because of Exception 2 Dwelling units with conditioned floor area of 500 square feet or less in Climate Zones 3, 5 through 10 and 15</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="P01a_DefrostDelayTimerTestMessage" type="comp:DefrostDelayTimerTestMessage">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This field is required and displayed If P01_DefrostDelayTimerTestApplies != TestApplies If P01_DefrostDelayTimerTestApplies == NoAdjustDefrostDelayTimer result = NoTimerMessage; Else If P01_DefrostDelayTimerTestApplies == Exception1TestNA result = Exception1Message; Else If P01_DefrostDelayTimerTestApplies == Exception2TestNA result = Exception2Message;</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="1" minOccurs="0" name="DefrostDelayTimerTestData">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test of Defrost Delay Timer Setting (Section 150.0(h)6)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This subsection is required and displayed If P01_DefrostDelayTimerTestApplies == TestApplies</xs:documentation>
                        
                        
                        <xs:documentation source="MinOccurs">If this subsection is not required, nothing is displayed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element name="P02_DefrostDelayTimerControls" type="comp:DefrostDelayTimerControls">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record Configuration of Controls.  Specify the mechanism for setting the Defrost Delay Timer Setting</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">(for example, the name of the defrost delay timer in the thermostat setup, or the location and number of the specific dip switch, jumper, or dial that adjusts the Defrost Delay timer)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="P03_DefrostDelayTimerMaxMinutes" type="comp:DefrostDelayTimerMaxMinutes">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record heat pump's Maximum Available Defrost Delay Timer Setting (minutes)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements"/>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input IntegerNonnegative</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="P04_DefrostDelayTimerSetting" type="comp:DefrostDelayTimerSetting">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record where you set the the Defrost Delay Timer Setting</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">(for example, the numeric timer setting, dip switch position, jumper configuration, or dial setting)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="P05_DefrostDelayTimerMinutes" type="comp:DefrostDelayTimerMinutes">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record where you set the Defrost Delay Timer Setting in minutes</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements"/>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input IntegerNonnegative</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="P06_DefrostDelayTimerCompliance" type="comp:DefrostDelayTimerCompliance">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Confirming Configuration of Controls.  If possible, the Defrost Delay Timer Setting must be 90 minutes or greater.  Confirm the Defrost Delay Timer Setting is at least 90 minutes</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User selects from Yes (Boolean true) or No - Do Not Proceed (Boolean false)</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                       
                        </xs:sequence>
                        
                    
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
                       
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_Q">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Test of Supplementary Heating Lockout</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="QBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The installing contractor shall confirm that the heat pump or thermostat is configured to lock out supplementary heating anytime the outdoor temperature is above 35
                           <ns1:deg/>
                           F
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="Q01_SupplementHeatLockoutTestApplies" type="comp:SupplementHeatLockoutTestApplies">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test Applicability. Select the statement describing test applicability for this project:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from TestApplies display term 1. The test applies because the heating system is a heat pump with supplementary heating and there are no exceptions, NoSupplementHeat 2. Test does not apply because heating system does not include heat pump with auxiliary heating, 
Exception1TestNA display term 3 Test does not apply because of Exception 1 Heat pump being installed in a single family dwelling unit in Climate Zones 7 or 15, Exception2TestNA display term  Test does not apply because of Exception 2 Heat pump being installed in a single family dwelling unit with conditioned floor area of 500 square feet or less.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="Q01a_SupplementHeatLockoutTestMessage" type="comp:SupplementHeatLockoutTestMessage">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This field is required and displayed If Q01_SupplementHeatLockoutTestApplies != TestApplies If Q01_SupplementHeatLockoutTestApplies == NoSupplementHeat result = NoSupplementHeatMessage; Else If Q01_SupplementHeatLockoutTestApplies == Exception1TestNA result = Exception1Message; Else If 01_SupplementHeatLockoutTestApplies == Exception2TestNA result = Exception2Message;</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="1" minOccurs="0" name="SupplementalHeatingLockout">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test of Supplementary Heating Lockout</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This subsection is required and displayed If Q01_SupplementHeatLockoutTestApplies == TestApplies</xs:documentation>
                        
                        
                        <xs:documentation source="MinOccurs">If this subsection is not required, nothing is displayed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
			   
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Q02_ElectricResistanceHeatingCapacity" type="hvac:ElectricResistanceHeatingCapacity">
                                 
                                   
                                 <xs:annotation>
                                    
                                      
                                    <xs:documentation source="FieldText">If supplementary heating is electric resistance, what is its rated capacity (kW)? </xs:documentation>
                                    
                                      
                                    <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative; Units kW</xs:documentation>
                                    
                                  
                                 </xs:annotation>
                                 
                               
                              </xs:element>
                              
                               
                              <xs:element name="Q02_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                  
                                 <xs:annotation>
                                    
                                     
                                    <xs:documentation source="FieldText">If supplementary heating is electric resistance, what is its rated capacity (kW)?</xs:documentation>
                                    
                                     
                                    <xs:documentation source="CalculationsAndRules">If supplementary heating is not electric resistance heating result = NotApplicable stored in NotApplicablemessage; </xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
                              <xs:element name="Q03_HeatingSupplementalCapacity" type="hvac:HeatingSupplementalCapacity">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">If supplementary heating is gas, what is its rated input capacity (kBtu/hr)?</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">User input Integer; Units kBtu/hr</xs:documentation>
                                    
                                
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                               
                              <xs:element name="Q03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                  
                                 <xs:annotation>
                                    
                                     
                                    <xs:documentation source="FieldText">If supplementary heating is gas, what is its rated input capacity (kBtu/hr)?</xs:documentation>
                                    
                                     
                                    <xs:documentation source="CalculationsAndRules">If supplementary heating is not gas heating result = NotApplicable stored in NotApplicablemessage; </xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:element name="Q04_SupplementHeatLockoutControls" type="comp:SupplementHeatLockoutControls">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record Configuration of Controls.  Specify the mechanism for locking out supplementary heating</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">
                                    (for example, the name of the supplementary heating lockout setting in the thermostat setup, or the location and number of the specific dip switch, jumper, or dial that adjusts the lockout temperature)
If there is not mechanism to lockout supplementary heating above a temperature no greater than 35
                                    <ns1:deg/>
                                    F, this test fails.
                                 </xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="Q05_SupplementHeatLockoutSetting" type="comp:SupplementHeatLockoutSetting">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record supplementary heating lockout setting</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">(for example, the numeric thermostat lock-out setpoint, dip switch position, jumper configuration, or dial setting)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="Q06_SupplementHeatLockoutTemp" type="comp:SupplementHeatLockoutTemp">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">
                                    At what Outdoor Air Temperature (OAT) are the controls configured to bgin locking out supplementary heating?  If this number is above 35
                                    <ns1:deg/>
                                    F this test fails
                                 </xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User enters temperature xx.x; Units: degrees F.  If result GT 35, Do Not Proceed</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                       
                        </xs:sequence>
                        
                    
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
                       
            
            </xs:complexType>
            
         
         </xs:element>
         
      
      </xs:sequence>
      
   
   </xs:complexType>
   
   
   <xs:element name="cF2RMCH01aE" type="CF2RMCH01aE">
      
      
      <xs:annotation>
         
         
         <xs:documentation>This element contains all of the data and text required to generate the CF2RMCH01aE compliance report.</xs:documentation>
         
      
      </xs:annotation>
      
   
   </xs:element>
   

</xs:schema>
