                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C11_AirflowRequiredMinimumTarget" type="hvac:AirflowRequiredMinimumTarget">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Central Fan Ventilation Cooling Airflow</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If B05_NotApplicableMessage == N/A then result = N/A stored in the  NotAppplicableMessage;  Else If B05_CFVCS_Type == FixedCFVCS result = parent CC-PRF  fixed cooling vent airflow Else If B05_CFVCS_Type == VariableCFVCS result = parent CC-PRF maximum cooling vent airflow</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C11_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Central Fan Ventilation Cooling Airflow</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If B05_NotApplicableMessage == N/A then result = N/A stored in the  NotAppplicableMessage;  Else If B05_CFVCS_Type == FixedCFVCS result = parent CC-PRF  fixed cooling vent airflow Else If B05_CFVCS_Type == VariableCFVCS result = parent CC-PRF  maximum cooling vent airflow</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C12_VentilationCoolingFanEfficacy" type="comp:VentilationCoolingFanEfficacy">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Central Fan Ventilation Cooling Fan Efficacy</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If B05_NotApplicableMessage == N/A then result = N/A stored in the  NotAppplicableMessage; Else reference value from parent CC-PRF for this system</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C12_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Central Fan Ventilation Cooling Fan Efficacy</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field: If B05_NotApplicableMessage == N/A then result = N/A stored in the  NotAppplicableMessage;  Else reference value from parent CC-PRF for this system</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C12a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_D">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Space Conditioning (SC) System Component Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent CF1R-PRF Certificate of Compliance (CC)
 
Require one row of data to be entered in this table for each space conditioning system in the count field A04, ResidentialDwellingUnitSpaceConditioningCount.  If SC system names from CBECC are installed more than once in this dwelling unit, then duplicate SC system names are allowed in D01; Require each entry in D02 to be unique in this dwelling unit</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableComponents">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="D01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User select applicable system name from a list comprised of the systems identified in section B, field B01.  If SC system names from CBECC are installed more than once in this dwelling unit, then duplicate SC system names are allowed in this field.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text; 15 characters maximum; Require each entry to be unique in this dwelling unit i.e. unique within the scope of this instance of the MCH-01</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D03_ResidentialHvacSystemConditionedArea" type="hvac:ResidentialHvacSystemConditionedArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Conditioned Floor Area Served by the System (ft
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input, numeric, xxxx;   Require the sum of the values in this column to be equal to the value in A03 as condition of completion of this doc</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D04_ResidentialHeatingSystemType" type="hvac:ResidentialHeatingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B03_ResidentialHeatingSystemType as default;  If B03_ResidentialHeatingSystemType == DuctedMiniSplitHP, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessSplitHP (display term Ductless mini-split HP), DuctlessVRF_HP, RoomHP;   SmallDuctHighVelocityHP,  VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless,  VCHP_IndoorUnitDuctedAndDuctless,  AirToWaterHeatPump Or GroundSourceHeatPump do not allow user to override;  Else allow user to override the default and select one from list:  
BoilerSystem,  CentralGasFurnace   CentralLargePackagedHP,  CentralPackagedHP, CentralSplitHP,  CombinedHydronic, CombinedHydronicForcedAir,  Electric, GasPackagedFurnace, GasSpaceHeater,  GasWallFurnace, HeatPumpDHWCombo, Hydronic, HydronicForcedAir, HydronicHP, HydronicHP_ForcedAir, SPVHP, PTHP, and WoodHeat.  Flag non-default values and report in project status notes field; a revised parent CC-PRF may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D05_ResidentialCoolingSystemType" type="hvac:ResidentialCoolingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Cooling System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled text: Reference value from B04_ResidentialCoolingSystemType as defult; do not allow user to override value.
 
Note: Allowed values for B04 may include: CentralLargePackagedAC, CentralLargePackagedHP, CentralPackagedAC, CentralPackagedHP, CentralSplitAC, CentralSplitHP, DuctedMultiSplitAC, DuctlessMultiSplitAC, DuctedDuctlessMultiSplitAC, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessSplitAC (display term Ductless mini-split AC), DuctlessSplitHP (display term Ductless mini-split HP), DuctlessVRF_AC, DuctlessVRF_HP, DuctedMiniSplitAC, DuctedMiniSplitHP, AirToWaterHeatPump, GroundSourceHeatPump, EvaporativeDirect, EvaporativeIndirect, EvaporativeIndirectDirect, EvaporativelyCooledCondenser, GasAbsorptionAC, HydronicHP, HydronicHP_ForcedAir, IceStorageAC, NoCooling, RoomAC, RoomHP, SmallDuctHighVelocityAC, SmallDuctHighVelocityHP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctedAndDuctless, VCHP_IndoorUnitDuctless, SPVAC, SPVHP, PTAC, PTHP.
 
Note: NoCooling value is the flag for heating-only systems.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D06_IndoorUnitsCount" type="hvac:IndoorUnitsCount">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Number of Indoor Units for this System</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If D04 Or D05  == any of the following: RoomAC, RoomHP, GasSpaceHeater,  GasWallFurnace, WoodHeat, Electric, GasPackagedFurnace, CentralLargePackagedAC, CentralLargePackagedHP, CentralPackagedAC, CentralPackagedHP, EvaporativeDirect, EvaporativeIndirect, Or EvaporativeIndirectDirect  result = N/A stored in the  NotAppplicableMessage;   Else If B05_CFVCS_Type == FixedCFVCS Or VariableCFVCS result = 1 Else If parent CC-PRF VentilationSystemType == CentralFanIntegrated And IAQ_VentilationVerificationRequired == true, result = 1, Else result = 1 as default.  Allow the user to overwrite with either integer GT 1 or N/A stored in the  NotAppplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Number of Indoor Units for this System</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If D04 Or D05  == any of the following: RoomAC, RoomHP, GasSpaceHeater,  GasWallFurnace, WoodHeat, Electric, GasPackagedFurnace, CentralLargePackagedAC, CentralLargePackagedHP, CentralPackagedAC, CentralPackagedHP, EvaporativeDirect, EvaporativeIndirect, Or EvaporativeIndirectDirect  result = N/A stored in the  NotAppplicableMessage;  Else If B05_CFVCS_Type == FixedCFVCS Or VariableCFVCS result = 1 Else If parent CC-PRF VentilationSystemType == CentralFanIntegrated And IAQ_VentilationVerificationRequired == true, result = 1, Else result = 1 as default.  Allow the user to overwrite with either integer GT 1 or N/A stored in the  NotAppplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="D07_DuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Distribution System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D04_ ResidentialHeatingSystemType == VCHP_IndoorUnitDucted 
result = ConditionedSpaceDuctsVLL; 
Else If D04_ ResidentialHeatingSystemType ==  VCHP_IndoorUnitDuctless;
 result = Ductless; 
Else If D04_ ResidentialHeatingSystemType == VCHP_IndoorUnitDuctedAndDuctless: 
result = DuctedAndDuctlessIndoorUnits; 
 
Else reference value for B6_DuctSystemTypePerf  as default;  
End If
 
allow user to only override these default values from B06_DuctSystemTypePerf: UnconditionedAttic, UnconditionedGarage, Outdoor or B06_NotApplicableMessage value.  
Choices for override:  
ConditionedSpace display term HVAC system(s) with all HVAC ducts located in conditioned space,  
ConditionedSpaceDuctsVLL display term Verified low-leakage ducts in conditioned space, 
ConditionedSpaceExcept12ft display term Ducts located within the conditioned space (except less than 12 lineal ft),   
Ductless display term Air distribution systems without ducts,   
DuctsInMultipleLocations display term  Ducts located in multiple places,  
DuctedAndDuctlessIndoorUnits display term  Multiple split Indoor Units combined Ducted and Ductless,  
Outdoors display term Ducts located in exposed outdoor locations,  
UnconditionedAttic display term Ducts located overhead in unconditioned attic, 
UnconditionedCrawlSpace display term Ducts located underfloor in unconditioned crawl space, 
UnconditionedGarage display term Ducts located in an unconditioned garage.  
 
Flag non-default values and report in project status notes field; a revised parent CC-PRF may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                             
                                             
                                             <xs:enumeration value="ConditionedSpaceDuctsVLL"/>
                                             
                                             
                                             <xs:enumeration value="ConditionedSpaceExcept12ft"/>
                                             
                                             
                                             <xs:enumeration value="DuctedAndDuctlessIndoorUnits"/>
                                             
                                             
                                             <xs:enumeration value="Ductless"/>
                                             
                                             
                                             <xs:enumeration value="DuctsInMultipleLocations"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D08_ThermostatType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Thermostat Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B07 as default;   allow user to override the default and select one from list. Choices for ThermostatType: SetbackThermostat , NonSetbackThermostat, OccupantControlledSmartThermostat,  EnergyManagementSystem</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ThermostatType">
                                             
                                             
                                             <xs:enumeration value="EnergyManagementSystem"/>
                                             
			                     
                                             <xs:enumeration value="NonSetbackThermostat"/>
                                             
                                             
                                             <xs:enumeration value="OccupantControlledSmartThermostat"/>
                                             
                                             
                                             <xs:enumeration value="SetbackThermostat"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D09_ResidentialCoolingZoneType" type="hvac:ResidentialCoolingZoneType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Zoning Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field:  Reference value from B10 as default, which may be in B10_ResidentialCoolingZoneType or B10_NotApplicableMessage; however, If D05_CoolingSystemType == NoCooling then result = N/A stored in the  NotAppplicableMessage; Else allow user to override default and pick from list: ZoneControlled display term Zonally Controlled, NotZoneControlled display term Not Zonal.   Flag non-default values and report in project status notes field, a revised parent CC-PRF  may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Zoning Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field:  Reference value from B10 as default, which may be in B10_ResidentialCoolingZoneType or B10_NotApplicableMessage; however, If D05_CoolingSystemType == NoCooling then result = N/A stored in the  NotAppplicableMessage; Else allow user to override default and pick from list: ZoneControlled display term Zonally Controlled, NotZoneControlled display term Not Zonal.   Flag non-default values and report in project status notes field, a revised parent CC-PRF may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D10_CondenserSpeedType" type="hvac:CondenserSpeedType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling System Compressor Speed Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field:  Reference value from B11 as default;  Else If CoolingSystemType (D05) ==  NoCooling, then result = N/A stored in the  NotAppplicableMessage and display text:  N/A;  Else allow user to override the default and pick from list.  Choices for CompressorSpeedType: MultiSpeed display term Multi-speed, SingleSpeed display term Single Speed.  Flag non-default values and report in project status notes field; a revised parent CC-PRF may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling System Compressor Speed Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field:  Reference value from B11 as default;  Else If CoolingSystemType (D05) ==  NoCooling, then result = N/A stored in the  NotAppplicableMessage and display text:  N/A;  Else allow user to override the default and pick from list.  Choices for CompressorSpeedType: MultiSpeed display term Multi-speed, SingleSpeed display term Single Speed.      Flag non-default values and report in project status notes field; a revised parent CC-PRF may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="D11a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Heating System Equipment Information (not heat pumps)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC-PRF refers to the parent CF1R-PRF Certificate of Compliance (CC) 
 
This Section is applicable only if at least one row in D04_ResidentialHeatingSystemType != one of these Heat Pump types: CentralLargePackagedHP, CentralPackagedHP, 
CentralSplitHP,  DuctedMiniSplitHP, AirToWaterHeatPump, GroundSourceHeatPump, DuctlessSplitHP (display term Ductless mini-split HP), DuctedMultiSplitHP, DuctlessMultiSplitHP,  
DuctedDuctlessMultiSplitHP, DuctlessVRF_HP, SmallDuctHighVelocityHP, HydronicHP, HydronicHP_ForcedAir, RoomHP, HeatPumpDHWCombo, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless . 
For each SC that satisfies this condition, do one of the following:  If SC system in D02 has D06_NotApplicableMessage value, require one row of data; Else If  SC System has D06_IndoorUnitsCount GTE 1 And D04 == CentralGasFurnace require one row of data for each of the quantity of indoor units specified in D06 for that system.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHeating">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="E01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC-PRF</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference to D01, ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="E02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from D02</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E03_IndoorUnitName" type="hvac:IndoorUnitName">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If D06_NotApplicableMessage has a value result = N/A stored in the  NotAppplicableMessage;  Else If D06_IndoorUnitsCount = 1 result = D02_ResidentialHvacSystemAreaServed Else user input maximum 15 characters;  As default require value to be unique in this dwelling unit (i.e. unique within the scope of the MCH-01) except for the case when all of the following conditions are true:  E01 == G01 And E02 == G02 And D04_ResidentialHeatingSystemType == CentralGasFurnace.   Allow user to override this uniqueness rule if necessary.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If D06_NotApplicableMessage has a value result = N/A stored in the  NotAppplicableMessage; Else If D06_IndoorUnitsCount = 1 result = D02_ResidentialHvacSystemAreaServed Else user input maximum 15 characters;  As default require value to be unique in this dwelling unit (i.e. unique within the scope of the MCH-01) except for the case when all of the following conditions are true:  E01 == G01 And E02 == G02 And D04_ResidentialHeatingSystemType == CentralGasFurnace.   Allow user to override this uniqueness rule if necessary.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="E04_DoesUnitProvideCFI_IAQ" type="comp:DoesUnitProvideCFI_IAQ">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does Indoor Unit Provide CFI IAQ Ventilation?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If D06_IndoorUnitsCount  GT 1   Or 
CF1R-PRF  IAQ_VentilationType for this dwelling unit  == Balanced, BalancedERV or BalancedHRV  
result = false display term No;  
 
Else If D06_NotApplicableMessage has a value And D04_ResidentialHeatingSystemType == CentralGasFurnace 
user selected Yes (true value) or No (false value); 
Else 
user selected Yes (true value) or No (false value).
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="E05_IndoorUnitDucts" type="hvac:IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Duct Status</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">
                                             If D07_DuctLocation == Ductless: result = Ductless; Else If  D07_DuctLocation == UnconditionedAttic, UnconditionedGarage, UnconditionedCrawlSpace, Outdoor, ConditionedSpaceExcept12ft, ConditionedSpace, ConditionedSpaceDuctsVLL, Or DuctsInMultipleLocations, user selects from DuctsGT10Ft display term Ducted 
                                             <ns1:gt/>
                                              10ft length and DuctsLTE10Ft display term Ducted less than or equal to 10ft length; Else If D07_DuctLocation == DuctedAndDuctlessIndoorUnits  user selects from DuctsGT10Ft display term Ducted greater than 10ft length, DuctsLTE10Ft display term Ducted less than or equal to 10ft length and Ductless
                                          </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
