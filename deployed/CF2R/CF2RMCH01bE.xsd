<?xml version="1.0" ?>
<xs:schema xmlns:ns1="http://www.lmonte.com/besm/d" xmlns:ns2="http://www.lmonte.com/besm/dtyp" xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF2RMCH01bE" version="2025.0.000">
   
   
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   
   
   <xs:element name="ComplianceDocumentPackage">
      
      
      <xs:complexType>
         
         
         <xs:sequence>
            
            
            <xs:element minOccurs="0" name="DocID">
               
               
               <xs:complexType>
                  
                  
                  <xs:attribute fixed="CF2RMCH01bE" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                  
                  <xs:attribute fixed="CERTIFICATE OF INSTALLATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                  
                  <xs:attribute fixed="Space Conditioning Systems, Ducts, and Fans" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
                  
                  <xs:attribute fixed="MCH01b Prescriptive Alterations" name="docVariantSubtitle" type="comp:ComplianceDocumentVariantSubtitle"/>
                  
                  
                  <xs:attribute fixed="b" name="docVariantLetter" type="comp:ComplianceDocumentVariant"/>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Payload" type="comp:Payload"/>
            
            
            <xs:element name="DocumentData">
               
               
               <xs:complexType>
                  
                  
                  <xs:sequence>
                     
                     
                     <xs:element name="Header" type="comp:HeaderHERS"/>
                     
                     
                     <xs:element ref="cF2RMCH01bE"/>
                     
                     
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                     
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF2R_E"/>
                     
                     
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                  
                  </xs:sequence>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Report" type="xsd:base64Binary"/>
            
         
         </xs:sequence>
         
         
         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF2RMCH01bE" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF2RMCH01bE">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Space Conditioning Systems, Ducts, and Fans - MCH01b Prescriptive Alterations</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">General Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="ABeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Notes: 
                           <ns1:l t="#">
                              <ns1:list>
                                 The outdoor design temperatures for heating shall be 
                                 <ns1:gte/>
                                  to 99.0% Heating Dry Bulb or the Heating Winter Median of Extremes values 
                              </ns1:list>
                              

                              <ns1:list>
                                 The outdoor design temperatures for cooling shall be 
                                 <ns1:lte/>
                                  1.0% Cooling Dry Bulb and Mean Coincident Wet Bulb values. 
                              </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A01_DwellingUnitName" type="com:DwellingUnitName">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Dwelling Unit Name</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference text from parent CC</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A02_ClimateZone" type="com:ClimateZone">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Climate Zone</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference text from parent CC</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A03_DwellingUnitConditionedFloorArea" type="com:DwellingUnitConditionedFloorArea">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Dwelling Unit Total Conditioned Floor Area (ft
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Value is numeric: xxxxx  
If parent  CC is CF1R-PRF, then 
If project scope = Newly Constructed (Addition Alone) 
prompt user to enter a value equal to dwelling unit existing CFA + addition CFA, 
Else reference the value from CF1R PRF 
End If        
 
Else If parent  CC is CF1R-NCB-01, then 
If project scope =  AdditionGT1000 then 
prompt user to enter a value equal to dwelling unit existing CFA + addition CFA, 
Else If project scope = NewBuildingConstruction, then 
If ResidentialLowriseBuildingType = SingleFamily,   
reference value from CF1R-NCB field A10, 
End If
End If
 
Else If parent  CC  is CF1R-ADD-01, then 
If ResidentialLowriseBuildingType = SingleFamily 
reference value from field A08 from the CF1R-ALT-02 that is required for the dwelling unit according to CF1R-ADD-01 Section J,  
End If
 
Else If parent  CC is CF1R-ALT-01, then 
If ResidentialLowriseBuildingType = SingleFamily,  
reference value from field A08 from the CF1R-ALT-02 that is required for the dwelling unit according to CF1R-ALT-01 Section G 
End If
Else If parent  CC is CF1R-ALT-02, then reference value from CF1R-ALT-02 field A08.  
End If   
 
 Allow user to override default and input value; flag overridden values and report in project status notes field</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A04_ResidentialDwellingUnitSpaceConditioningCount" type="hvac:ResidentialDwellingUnitSpaceConditioningCount">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Number of Space Conditioning Systems in this Dwelling Unit.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If parent CC is CF1R-ALT-02, use value from parent Section A A10 as default Or allow user to override default value and flag non-default values and report in project status notes field
Else 
user input the integer value xx
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A05_ComplianceMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Certificate of Compliance Type</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference document type property from CF1R; For choice Performance display text: performance (CF1R-PRF); for choice PrescriptiveAdditions display text:  prescriptive additions (CF1R-ADD)    For choice PrescriptiveAlterations display text: prescriptive alterations (CF1R-ALT);   For choice PrescriptiveNewConstruction display text: prescriptive newly constructed (CF1R-NCB)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="comp:ComplianceMethod">
                           
                           
                           <xs:enumeration value="Performance"/>
                           
                           
                           <xs:enumeration value="PrescriptiveAdditions"/>
                           
                           
                           <xs:enumeration value="PrescriptiveAlterations"/>
                           
                           
                           <xs:enumeration value="PrescriptiveNewConstruction"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A06_HvacLoadCalculationMethod" type="comp:HvacLoadCalculationMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Method Used to Calculate HVAC Loads (See Section 150.0(h))</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input;  Choices to display: ASHRAE Handbook;  SMACNA Residential Comfort System Installation Standards Manual, ACCA Manual J, Not applicable - equipment change out, like-for-like; and Exception 1 to Section 150.0(h)1: Block loads for system sizing for additions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="unbounded" name="A07_HvacOutdoorDesignCondSource" type="comp:HvacOutdoorDesignCondSource">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Outdoor Design Condition Source (See Section 150.0((h)2</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User select all that apply; Reference Joint Appendix JA2; ASHRAE Handbook; ACCA Manual J </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A08_DesignCoolingOutdoorTemp" type="hvac:DesignCoolingOutdoorTemp">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Cooling Outdoor Design Temperature Selected (
                           <ns1:deg/>
                           F)
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User enters temperature in degrees F</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A09_DesignHeatingOutdoorTemp" type="hvac:DesignHeatingOutdoorTemp">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Heating Outdoor Design Temperature Selected (
                           <ns1:deg/>
                           F)
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User enters temperature in degrees F</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A10_DesignSensibleCoolingLoad" type="hvac:DesignSensibleCoolingLoad">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Sensible Cooling Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = NotApplicable stored in the  NotAppplicableMessage Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A10_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Sensible Cooling Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = NotApplicable stored in the  NotAppplicableMessage Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A11_DwellingUnitDesignHeatingLoad" type="hvac:DwellingUnitDesignHeatingLoad">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Heating Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = NotApplicable stored in the  NotAppplicableMessage Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A11_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Heating Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = NotApplicable stored in the  NotAppplicableMessage Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="A12_BedroomCount" type="com:BedroomCount">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Dwelling Unit Number of Bedrooms</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: integer xx;  If A05_ComplianceMethod == Performance Then use as default the value referenced from the parent CC Or allow user to override  default and input a new value, constrained to be GTE to default value from parent CC, flag non-default values and report of change in the project status notes field.  
Else If ComplianceMethod != Performance  then user inputs integer value.
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="A12After">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Variant MCH-01b</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">MCH-01b - Space Conditioning Systems Ducts and Fans - Prescriptive Alterations</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: 
If A05_ComplianceMethod  == Performance, 
If CF1R-PRF project scope == Addition and/or Alteration Or Newly Constructed (Addition Alone) then display doc variation MCH-01d ;   
Else If  CF1R-PRF project scope == Newly Constructed display doc variation  MCH-01a 
End If     
Else If A05_ComplianceMethod == PrescriptiveAlterations, Or  PrescriptiveAddiitions, then display doc variation MCH-01b;  
Else If A05_ComplianceMethod  == PrescriptiveNewConstruction  then display doc variation MCH-01c  
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="AdditionsOnlyInformation">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                           
                        <xs:documentation source="CalculationsAndRules">This group of fields are required If A05_ComplianceMethod  == Performance And CF1R-PRF project scope == Addition and/or Alteration Or Newly Constructed (Addition Alone) Or If A05_ComplianceMethod == PrescriptiveAddiitions</xs:documentation>
                        
			   
                        <xs:documentation source="MinOccurs">If fields A13-A16 don't apply, display only  the statement 'Fields A13-A16 do not apply.'</xs:documentation>
                        
                        
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                  
                           <xs:element minOccurs="0" name="AddBeginNote1">
                              
                     
                              <xs:annotation>
                                 
                        
                                 <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                                 
                        
                                 <xs:documentation source="AdditionalRequirements">
                                    Notes: In fields A13 and A14 
                                    <ns1:l t="#">
                                       <ns1:list>If the airflow is verified to be 350 CFM/ton or higher there is no maximum capacity (Section 150.2(a)1Eii) and user should enter N/A.</ns1:list>
                                       

                                       <ns1:list>If the space conditioning system is ductless (Exception 1 to Section 150.2(a)1Eii) user should enter N/A.</ns1:list>
                                    </ns1:l>
                                 </xs:documentation>
                                 
                     
                              </xs:annotation>
                              
                  
                           </xs:element>
                           
                           
                           <xs:choice>
                              
                              
                              <xs:element name="A13_HeatingCapacity" type="hvac:HeatingCapacity">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Maximum Heating Capacity According to Table 150.2-A (Btu/h)</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">User enters a numeric value or N/A stored in NotAppicableMessage; If result == N/A because airflow is verified to be 350 CFM/ton or higher, the system cannot be ductless and a MCH-23 is required.  </xs:documentation>
                                    
                                
                                 </xs:annotation>
                                 
                             
                              </xs:element>
                              
                             
                              <xs:element name="A13_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                
                                 <xs:annotation>
                                    
                                   
                                    <xs:documentation source="FieldText">Maximum Heating Capacity According to Table 150.2-A (Btu/h)</xs:documentation>
                                    
                                   
                                    <xs:documentation source="CalculationsAndRules">User enters a numeric value or N/A stored in NotAppicableMessage; If result == N/A because airflow is verified to be 350 CFM/ton or higher, the system cannot be ductless and a MCH-23 is required. </xs:documentation>
                                    
                               
                                 </xs:annotation>
                                 
                            
                              </xs:element>
                              
                         
                           </xs:choice>
                            
                           
                           <xs:choice>
                              
                              
                              <xs:element name="A14_CoolingCapacity" type="hvac:CoolingCapacity">
                                 
                                 
                                 <xs:annotation>
                                    
                                    
                                    <xs:documentation source="FieldText">Maximum Cooling Capacity According to Table 150.2-A (Btu/h)</xs:documentation>
                                    
                                    
                                    <xs:documentation source="CalculationsAndRules">User enters a numeric value or N/A stored in NotAppicableMessage; If result == N/A because airflow is verified to be 350 CFM/ton or higher, the system cannot be ductless and a MCH-23 is required. </xs:documentation>
                                    
                                
                                 </xs:annotation>
                                 
                             
                              </xs:element>
                              
                             
                              <xs:element name="A14_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                
                                 <xs:annotation>
                                    
                                   
                                    <xs:documentation source="FieldText">Maximum Heating Capacity According to Table 150.2-A (Btu/h)</xs:documentation>
                                    
                                   
                                    <xs:documentation source="CalculationsAndRules">User enters a numeric value or N/A stored in NotAppicableMessage; If result == N/A because airflow is verified to be 350 CFM/ton or higher, the system cannot be ductless and a MCH-23 is required. </xs:documentation>
                                    
                               
                                 </xs:annotation>
                                 
                            
                              </xs:element>
                              
                         
                           </xs:choice>
                           
                         
                           <xs:element name="A15_ACH50" type="comp:ACH50">
                              
                            
                              <xs:annotation>
                                 
                               
                                 <xs:documentation source="FieldText">Envelope Leakage Specified in Load Calculation (ACH)</xs:documentation>
                                 
                               
                                 <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative, allow value from Table 150.2-C if result LTE values in table,  or value from Field Verification and Diagnostic Testing</xs:documentation>
                                 
                           
                              </xs:annotation>
                              
                         
                           </xs:element>
                            
                         
                           <xs:element name="A16_LeakageInLoadCalcSource" type="comp:LeakageInLoadCalcSource">
                              
                            
                              <xs:annotation>
                                 
                               
                                 <xs:documentation source="FieldText">Source of Envelope Leakage Specified in Load Calculation</xs:documentation>
                                 
                               
                                 <xs:documentation source="CalculationsAndRules">User selects from Table 150-C and Field Verification and Diagnostic Testing</xs:documentation>
                                 
                           
                              </xs:annotation>
                              
                         
                           </xs:element>
                                                     
                      
                        </xs:sequence>
                        
                    
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Space Conditioning (SC) System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
Require a row of dat for each of the quantity of space conditioning systems in A04
For this table every field except the last should reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised parent CC may be required</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableSystemInformation">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="B01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value; flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value; flag non-default values and report in project status notes field; a revised parent CC may be required.  Require each entry to be unique in this dwelling unit i.e. unique within the scope of this instance of the MCH-01</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B03_ResidentialHvacSystemConditionedArea" type="hvac:ResidentialHvacSystemConditionedArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             CFA served by this SC System (ft
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B04_DuctedSystem" type="comp:DuctedSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Is the SC system a ducted system?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required; Display Yes and No to represent Boolean values true and false</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B05_IncludesComponentWithRefrigerant" type="comp:IncludesComponentWithRefrigerant">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does work include installing a refrigerant containing component?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required 
Display Yes and No to represent Boolean values true and false</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B06_InstallingNewComponents" type="comp:InstallingNewComponents">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does work include installing new SC system components?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required   
Display Yes and No to represent Boolean values true and false</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B07_Installing25PlusLinearFeetDucts" type="comp:Installing25PlusLinearFeetDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does work include installing more than 25 feet of ducts?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required;   Display Yes and No to represent Boolean values true and false</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B08_DuctSystemAllAccessibleForSealingWithPlus75PercentNewReplaced" type="comp:DuctSystemAllAccessibleForSealingWithPlus75PercentNewReplaced">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does work include installing an "entirely new duct system"?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required;   Display Yes and No to represent Boolean values true and false</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B09_AllNewOrReplacedHvacSystem" type="comp:AllNewOrReplacedHvacSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does work include installing an "entirely new SC system"?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC as default; Display Yes and No to represent Boolean values true and false; allow user to override the default and input a new value;  flag non-default values and report in project status notes field; a revised CF1R may be required; 
If result == true And A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then do not allow user to proceed.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B10_ResidentialHvacAlterationType" type="hvac:ResidentialHvacAlterationType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Alteration Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Provide controls for user input to either 1) determine the correct result for alteration type for entry in this field by prompting the user to respond with any data input needed for use of the logic in Logic Table for Determining Alteration Type and ECC Verification Requirements which is provided in the Residential Compliance Documents workbook.  Constrain user input for fields B04-B09 to allow only the available combinations of responses given in the Logic Table in rows a through s;   or 2) allow the user to pick an alteration type from ResidentialHvacAlterationType values.  For choice DuctSystemExistingExtended display text: Extension of Existing Duct System;   For choice SpaceConditioningSystemAltered display text: Altered Space Conditioning System;   For choice DuctSystemEntirelyNewReplacement display text: Entirely New or Complete Replacement Duct System with or without Equipment Changeout; For choice SpaceConditioningSystemEntirelyNewReplacement display text: Entirely New or Complete Replacement Space Conditioning System; For choice NoAlterationsPerformed display text: No Alteration Performed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="B10a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Space Conditioning (SC) System Alterations Compliance Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
Require one row of data in this table for each of the SC Systems listed in Section B for which B10_ResidentialHvacAlterationType != NoAlterationsPerformed</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableAlterations">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="C01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C03_ResidentialHeatingSystemType" type="hvac:ResidentialHeatingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">&gt;Reference value from CF1R as default; allow user to override the default and pick one from list: CentralGasFurnace, CentralSplitHP, CentralPackagedHP, CentralLargePackagedHP, DuctlessSplitHP (display term Ductless mini-split HP), RoomHP, Boiler, Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  HydronicHP_ForcedAir, GasPackagedFurnace, GasWallFurnace , GasSpaceHeater, Electric, NonAirSourceHP, WoodHeat, SmallDuctHighVelocityHP, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessVRF_HP,  VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctedAndDuctless, VCHP_IndoorUnitDuctless, DuctedMiniSplitHP, SPVHP, PTHP  and NoHeating.  
                                             
                                             If result == NoHeating then check: there must be at least one heating system entered in this section C04 to comply, 
                                             
                                             Else flag noncompliant condition (no heating installed) and do not allow registration to continue.   Flag non-default values and report in project status notes field; a revised CF1R may be required
                                             End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element maxOccurs="unbounded" name="C04_ResidentialHvacHeatingComponentType" type="hvac:ResidentialHvacHeatingComponentType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Altered Heating Component</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from parent CC as default; allow user to override the default and pick as many as are applicable from list: GasFurnaceAHU, FancoilAHU, OutdoorCondensingUnit, IndoorCoil, Boiler, TXV_EXV, Compressor, RefrigerantLineset, NoHeatingComponentsAltered.  Flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C05_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C04_ResidentialHvacHeatiingComponentType == NoHeatingComponentsAltered result = NotApplicable stored in NotApplicablemessage; 
Else If C03_ResidentialHeatingSystemType == Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  Or HydronicHP_ForcedAir  result = NotApplicable stored in NotApplicableMessage; 
Else reference value from parent CC as default but allow user to override the default and pick one from list:  AFUE, HSPF, HSPF2, COP.  
 
Flag non-default values and report in project status notes field; a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="AFUE"/>
                                                
                                                
                                                <xs:enumeration value="COP"/>
                                                
                                                
                                                <xs:enumeration value="HSPF"/>
                                                
                                                
                                                <xs:enumeration value="HSPF2"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C04_ResidentialHvacHeatiingComponentType == NoHeatingComponentsAltered result = NotApplicable stored in NotApplicablemessage; 
Else If C03_ResidentialHeatingSystemType == Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  Or HydronicHP_ForcedAir  result = NotApplicable stored in NotApplicableMessage; 
Else reference value from parent CC as default but allow user to override the default and pick one from list:  AFUE, HSPF, HSPF2, COP.  
 
Flag non-default values and report in project status notes field; a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C06_EfficiencyMinimumValueAFUE" type="hvac:EfficiencyMinimumValueAFUE">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Minimum Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_NotApplicableMessage IsPresent
result = NotApplicable stored in NotApplicablemessage
Else If C05_EfficiencyType == AFUE
 reference AFUE value from parent CC as default; but allow user to override the default to enter numeric value xx.x;  
End If
Check: default minimum value for AFUE= 80 display term 80; Flag non-default values and report in project status notes field a revised parent CC may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C06_EfficiencyMinimumValueCOP" type="hvac:EfficiencyMinimumValueCOP">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Minimum Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_NotApplicableMessage IsPresent
result = NotApplicable stored in NotApplicablemessage
Else If C05_EfficiencyType == COP; 
reference COP value from parent CC as default; but allow user to override the default to enter numeric value xx.x;  
End If
Flag non-default values and report in project status notes field a revised parent CC may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C06_EfficiencyMinimumValueHSPF" type="hvac:EfficiencyMinimumValueHSPF">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Minimum Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_NotApplicableMessage IsPresent
result = NotApplicable stored in NotApplicablemessage
Else If C05_EfficiencyType == HSPF; 
reference HSPF value from parent CC as default; but allow user to override the default to enter numeric value xx.x;  
End If
Check: default minimum value  for HSPF=8.0  Flag non-default values and report in project status notes field a revised parent CC may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C06_EfficiencyMinimumValueHSPF2" type="hvac:EfficiencyMinimumValueHSPF2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Minimum Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_NotApplicableMessage IsPresent
result = NotApplicable stored in NotApplicablemessage
Else If C05_EfficiencyType == HSPF2 
reference HSPF2 value from parent CC as default; but allow user to override the default to enter numeric value xx.x;  
End If
Check: default minimum value for HSPF2 = 6.7  Flag non-default values and report in project status notes field a revised parent CC may be required.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Minimum Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_NotApplicableMessage IsPresent
result = NotApplicable stored in NotApplicablemessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="C07_ResidentialCoolingSystemType" type="hvac:ResidentialCoolingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Cooling System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from CF1R as default; allow user to override the default and pick one from list: CentralLargePackagedAC, CentralLargePackagedHP, CentralPackagedAC, CentralPackagedHP, CentralSplitAC, CentralSplitHP, DuctedMultiSplitAC, DuctedMultiSplitHP, DuctlessMultiSplitAC, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitAC, DuctedDuctlessMultiSplitHP, DuctlessSplitAC (display term Ductless mini-split AC) , DuctlessSplitHP (display term Ductless mini-split HP), DuctlessVRF_AC, DuctlessVRF_HP, EvaporativeDirect, EvaporativeIndirect, EvaporativeIndirectDirect, EvaporativelyCooledCondenser, GasAbsorptionAC, GroundSourceHeatPump, Hydronic, HydronicHP, HydronicHP_ForcedAir, IceStorageAC, NoCooling, NonAirCooledAC, NonAirSourceHP, RoomAC, RoomHP, SmallDuctHighVelocityHP, SmallDuctHighVelocityAC, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctedAndDuctless, VCHP_IndoorUnitDuctless. DuctedMiniSplitAC, DuctedMiniSplitHP, SPVAC, SPVHP, PTAC, PTHP.    Flag non-default values and report in project status notes field; a revised CF1R may be required;</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element maxOccurs="unbounded" name="C08_ResidentialHvacCoolingComponentType" type="hvac:ResidentialHvacCoolingComponentType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Altered Cooling Component</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from parent CC as default; allow user to override the default and pick as many as are applicable from list: OutdoorCondensingUnit, FancoilAHU,  IndoorCoil, TXV_EXV, Compressor, RefrigerantLineset, NoCoolingComponentsAltered. Flag non-default values and report in project status notes field; a revised parent CC may be required</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C09_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from parent CC as default; If C08_ResidentialHvacCoolingComponentType == NoCoolingComponentsAltered, then result is NotApplicable stored in NotApplicableMessage, Else allow user to override the default by picking from list:  EER, EER2, CEER, EERSEER, EER2SEER2.  Flag non-default values and report in project status notes field; a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="CEER"/>
                                                
                                                
                                                <xs:enumeration value="EER"/>
                                                
                                                
                                                <xs:enumeration value="EER2"/>
                                                
                                                
                                                <xs:enumeration value="SEER"/>
                                                
                                                
                                                <xs:enumeration value="SEER2"/>
                                                
                                                
                                                <xs:enumeration value="EER2SEER2"/>
                                                
                                                
                                                <xs:enumeration value="EERSEER"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from parent CC as default; If C08_ResidentialHvacCoolingComponentType == NoCoolingComponentsAltered, then result is NotApplicable stored in NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C10_EfficiencyMinimumValueSEER" type="hvac:EfficiencyMinimumValueSEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent
result  is NotApplicable stored in NotApplicableMessage
Else If C09_EfficiencyType == SEER  Or EERSEER Reference SEER value from parent CC as default and allow user to override the default to enter SEER value: xx.x;  default minimum value for SEER=14;  allow user to overwrite default value, but flag non-default values and report in project status notes field a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10_EfficiencyMinimumValueSEER2" type="hvac:EfficiencyMinimumValueSEER2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent
result  is NotApplicable stored in NotApplicableMessage
Else If C09_EfficiencyType == SEER2   Or EER2SEER2 Reference SEER2 value from parent CC as default andallow user to override the default to enter SEER2 value: xx.x;   default minimum value for SEER2=14.3;  allow user to overwrite default value, but flag non-default values and report in project status notes field a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent Or C09_EfficiencyType == CEER Or EER2 result  is NotApplicable stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C10b_EfficiencyMinimumValueEER" type="hvac:EfficiencyMinimumValueEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent
result  is NotApplicable stored in NotApplicableMessage
Else If C09_EfficiencyType == EER2 Else If C09_EfficiencyType == EER  Or EERSEER Reference EER value from parent CC as default and allow user to override the default to enter EER value: xx.x;;  default minimum value for EER=11.7;  allow user to overwrite default value, but flag non-default values and report in project status notes field a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10b_EfficiencyMinimumValueEER2" type="hvac:EfficiencyMinimumValueEER2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent
result  is NotApplicable stored in NotApplicableMessage
Else If C09_EfficiencyType == EER2  Or EER2SEER2 Reference EER2 value from parent CC as default and allow user to override the default to enter EER2 value: xx.x;;  default minimum value for EER2=11.2;  allow user to overwrite default value, but flag non-default values and report in project status notes field a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10b_EfficiencyMinimumValueCEER" type="hvac:EfficiencyMinimumValueCEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent result  is NotApplicable stored in NotApplicableMessage; Else If C09_EfficiencyType ==CEER Reference CEER value from parent CC as default;  The default minimum for CEER = 8.7; allow user to overwrite default value, but flag non-default values and report in project status notes field a revised parent CC may be required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10b_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Minimum Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C09_NotApplicableMessage IsPresent result = NotApplicable stored in NotApplicableMessage;</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C11_ThermostatType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Required Thermostat Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B10_ResidentialHvacAlterationType == DuctSystemExistingExtended Then result = NotApplicable stored in NotApplicableMessage. Else result =  SetbackThermostat; Allow user to override the default and select one from list. Choices for ThermostatType: SetbackThermostat , OccupantControlledSmartThermostat,  EnergyManagementSystem</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:ThermostatType">
                                                
                                                
                                                <xs:enumeration value="EnergyManagementSystem"/>
                                                
                                                
                                                <xs:enumeration value="OccupantControlledSmartThermostat"/>
                                                
                                                
                                                <xs:enumeration value="SetbackThermostat"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C11_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Required Thermostat Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B10_ResidentialHvacAlterationType == DuctSystemExistingExtended Then result = NotApplicable stored in the C11_NotApplicableMessage. Else result =  SetbackThermostat stored in C11_ThermostatType</xs:documentation>
                                             
                                          
