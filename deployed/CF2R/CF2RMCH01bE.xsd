         <xs:element maxOccurs="1" minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed New or Complete Replacement Duct System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only if  one or more systems in section B has  B08_ DuctSystemAllAccessibleForSealingWithPlus75PercentNewReplaced == true; For SC systems that satisfy this condition, do the following:  A. Require one row of data for each SC system in section D D02 for which  C03_ResidentialHeatingSystemType  == GasPackagedFurnace.  B. Require one row of data for each SC system in section E E02 where C07_ResidentialCoolingSystemType  == CentralPackagedAC, CentralPackagedHP CentralLargePackagedAC, Or  CentralLargePackagedHP  And same packkaged unit is not already listed in section D thus D02 !- E02.     C. If C12_IndoorUnitsCount GTE 1 require one row of data to be entered in this table for each of that quantity.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDuctSystem">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="G01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If any of these conditions are true: C03_ResidentialHeatingSystemType == GasPackagedFurnace; C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType  == CentralPackagedAC, CentralPackagedHP CentralLargePackagedAC, Or  CentralLargePackagedHP;  Or C12_IndoorUnitsCount = 1 then result = B02_ResidentialHvacSystemAreaServed; Else If C12_IndoorUnitsCount GT 1 And D10_IndoorUnitDucts  IsPresent and D10_IndoorUnitDucts == DuctsLTE10Ft Or  DuctsGT10Ft result = D09_IndoorUnitName;  Else user input maximum 15 characters;  Do not allow duplicate values for indoor unit names in this Mch01 as listed in F03 and G03</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G04_IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Total Duct Length</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: DuctsLTE10Ft  display term Ducted less than or equal to 10ft length, DuctsGT10Ft display term Ducted greater than 10ft length</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:IndoorUnitDucts">
                                             
                                             
                                             <xs:enumeration value="DuctsGT10Ft"/>
                                             
                                             
                                             <xs:enumeration value="DuctsLTE10Ft"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G05_DuctRValueLimit">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Required New Duct R-Value (Unconditioned Space)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  
If A02_ClimateZone  == 3, 5, 6, or 7 result = R6,  
Else If A02_ClimateZone == 1, 2, 4 or Inrange (8, 16) result = R8
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValueLimit">
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G06_SupplyDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Supply Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: ConditionedSpace display term Conditioned space-entirely, ConditionedSpaceExcept12ft display term Conditioned space - except 12ft, UnconditionedCrawlSpace display term Unconditioned crawl space, ControlledVentilationCrawlSpace display term Controlled ventilation crawl space, UnconditionedAttic display term Unconditioned attic, UnconditionedBasement display term Unconditioned basement, UnconditionedGarage display term Unconditioned garage, Outdoors display term Outdoors</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:SupplyDuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                             
			                     
                                             <xs:enumeration value="ConditionedSpaceExcept12ft"/>
                                                                                         
                                             
                                             <xs:enumeration value="ControlledVentilationCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedBasement"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                        
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G07_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">New Supply Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user selects from list: 
R-0.0, R-2.1, R4.2, R-6,  R-8, R-10 and R-12.  
End If
 
Check value for compliance:  
If result == R-0.0, R-2.1, R4.2 And G10_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned 
result complies; 
Else If result  GTE G05_DuctRvaluelimit 
result complies; 
Else 
Flag result as non-compliance and do not allow registration to proceed if not in compliance;
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G08_ReturnDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Return Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: ConditionedSpace display term Conditioned space-entirely, ConditionedSpaceExcept12ft display term Conditioned space - except 12ft, UnconditionedCrawlSpace display term Unconditioned crawl space, ControlledVentilationCrawlSpace display term Controlled ventilation crawl space, UnconditionedAttic display term Unconditioned attic, UnconditionedBasement display term Unconditioned basement, UnconditionedGarage display term Unconditioned garage, Outdoors display term Outdoors</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ReturnDuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                             
			                     
                                             <xs:enumeration value="ConditionedSpaceExcept12ft"/>
                                                                                          
                                             
                                             <xs:enumeration value="ControlledVentilationCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedBasement"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                        
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G09_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">New Return Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user selects from list: 
R-0.0, R-2.1, R4.2, R-6,  R-8, R-10 and R-12.  
End If
 
Check value for compliance:  
If result == R-0.0, R-2.1, R4.2 And G10_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned 
result complies; 
Else If result  GTE G05_DuctRvaluelimit 
result complies; 
Else 
Flag result as non-compliance and do not allow registration to proceed if not in compliance;
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G10_DuctMinimumRValueExceptions">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exception from Minimum R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Default result = NoException;  Allow user to override the default and select one from list:,  UninsulatedInDirectConditioning display term  Portions of ducts uninsulated  or less than R-6 in conditioned space
 
Also 
If G06_SupplyDuctLocation And G08_ReturnDuctLocation  == ConditionedSpace, allow user to select RValueLT6EntirelyInConditioned display term Ducts uninsulated or less than R-6 entirely in Conditioned Space
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctMinimumRValueExceptions">
                                             
                                             
                                             <xs:enumeration value="NoException"/>
                                             
                                             
                                             <xs:enumeration value="RValueLT6EntirelyInConditioned"/>
                                             
                                             
                                             <xs:enumeration value="UninsulatedInDirectConditioning"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G11_DuctFilterGrilleSizingComplianceMethod">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Method of compliance with Airflow and Fan Efficacy Req's in 150.0(m)13</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C07_ResidentialCoolingSystemType == NoCooling Then result = ExemptNoCooling, display text: Exempt - No Cooling,  
Else If  C07_ResidentialCoolingSystemType == EvaporativeDirect,  EvaporativeIndirect, or EvaporativeIndirectDirect,  then  result = ExemptEvaporativeSystem, display text :Exempt - Evaporative System, 
 
Else if G13_CanRA3_3AirflowProtocolsTestSystem == false Then result is ExemptRA3_3Protocols display text: Exempt - Approved Protocols are N/A;   
 
Else If B08_AllNewOrReplacedHvacSystem == true And C14_IsVentilationSystemCFI == true then result = HERS_FanEfficacyAirflowRate display text, ECC verified fan efficacy (W/cfm) and airflow rate (cfm/ton);  
 
Else user selects  from the following values: HERS_FanEfficacyAirflowRate display text, ECC Verified Fan Efficacy (W/cfm) And Airflow Rate (cfm/ton) or HERS_ReturnDuctDesignTable150BC display text, ECC Verified Return Duct Design per Table 150 B and C</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctFilterGrilleSizingComplianceMethod">
                                             
                                             
                                             <xs:enumeration value="ExemptEvaporativeSystem"/>
                                             
                                             
                                             <xs:enumeration value="ExemptNoCooling"/>
                                             
                                             
                                             <xs:enumeration value="ExemptRA3_3Protocols"/>
                                             
                                             
                                             <xs:enumeration value="HERS_FanEfficacyAirflowRate"/>
                                             
                                             
                                             <xs:enumeration value="HERS_ReturnDuctDesignTable150"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G12_DuctSystemAirFilterDeviceCount" type="hvac:DuctSystemAirFilterDeviceCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Number of Air Filter Devices on Indoor Units</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input numeric integer;  Note: this value will determine the number of rows per indoor unit in next section.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G13_CanRA3_3AirflowProtocolsTestSystem" type="comp:CanRA3_3AirflowProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Airflow Protocols be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType  == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = false display term No; Else If C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType  == CentralSplitAC, CentralSplitHP, CentralPackagedAC, CentralPackagedHP CentralLargePackagedAC, Or  CentralLargePackagedHP 
result = true display term Yes;  Else user selects from list: Yes (Boolean true value), No (Boolean false value).  End If 
Compliance check: If result == false then report in project status notes field that exemption from mandatory ECC verification of system airflow has been claimed.  Enforcement agency confirmation is recommended.  .</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="G14_CanFanEfficacyProtocolsTestSystem" type="comp:CanFanEfficacyProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Fan Efficacy Protocol be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If system type in C03_ResidentialHeatingSystemType Or C04_ResidentialCoolingSystemType == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = CanNotTest display term No; Else If system type in C03_ResidentialHeatingSystemType Or C04_ResidentialCoolingSystemType == CentralSplitAC, CentralSplitHP,   CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP 
result = CanTest display term Yes; Else user selects from list: CanTest display term Yes  or CanNotTest display term No; End if 
Check: if result == CanNotTest, report in project status notes field that exemption from mandatory ECC verification of system airflow has been claimed. Enforcement agency confirmation is recommended.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="G15_IndoorUnitNominalCoolingCapacity" type="hvac:IndoorUnitNominalCoolingCapacity">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Nominal Cooling capacity (tons)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C12_IndoorUnitsCount GT 1 And C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType   == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless   
And one of the following is true: (G13_CanRA3_3AirflowProtocolsTestSystem == true And K03_RefrigerantChargeVerificationRequired == true) 
Or (Responses in B04, B05, B06, B07. B08 and B09 result in "DctLk" in the ECC column of the Logic Table for Determining Alteration type and ECC Verfication Requirements) 
 Then user input numeric value x.xx; Else result = NotApplicable stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="G15_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Nominal Cooling capacity (tons)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C12_IndoorUnitsCount GT 1 And C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType   == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless   
And one of the following is true: (G13_CanRA3_3AirflowProtocolsTestSystem == true And K03_RefrigerantChargeVerificationRequired == true) 
Or (Responses in B04, B05, B06, B07. B08 and B09 result in "DctLk" in the ECC column of the Logic Table for Determining Alteration type and ECC Verfication Requirements) 
 Then user input numeric value x.xx; Else result = NotApplicable stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="G15a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_H">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Air Filter Device Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only If section G is applicable And at  least one indoor unit has G04_IndoorUnitDucts == DuctsGT10Ft .  Require one row of data for each of the air filter devices included in G12_DuctSystemAirFilterDeviceCount   for each indoor unit listed in G03_IndoorUnitName where G04_IndoorUnitDucts == DuctsGT10Ft</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="H_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory requirements for air filter devices are specified Section 150.0(m)12.  The installer shall place a sticker in or near each filter grille that displays the design airflow rate for that filter grille/rack and the maximum allowed clean filter pressure drop at the design airflow rate.  This will inform the occupant of the airflow vs pressure drop performance required for replacement air filters.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableAirFilterDevice">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="H01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Identification or Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Location or Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B02_ResidentialHvacSystemAreaServed for this system</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from G03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H04_DuctSystemAirFilterDeviceName" type="hvac:DuctSystemAirFilterDeviceName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Name or  Description of  Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text maximum 20 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H05_DuctSystemAirFilterDeviceType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Rack Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: Mounted display term Mounted at air handler, FilterGrille display term Filter Grille, MountedInline display term Mounted inline between return grille and air handler</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctSystemAirFilterDeviceType">
                                             
                                             
                                             <xs:enumeration value="FilterGrille"/>
                                             
                                             
                                             <xs:enumeration value="Mounted"/>
                                             
                                             
                                             <xs:enumeration value="MountedInline"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H06_AirFilterDeviceAirflowRate" type="hvac:AirFilterDeviceAirflowRate">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Airflow Rate for Air Filter Device (cfm)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input numeric xxxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H07_AirFilterDeviceDepth" type="hvac:AirFilterDeviceDepth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Depth (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input integer GTE 1</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H08_AirFilterDeviceLength" type="hvac:AirFilterDeviceLength">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Length (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H09_AirFilterDeviceWidth" type="hvac:AirFilterDeviceWidth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Width (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H10_AirFilterDeviceFaceArea" type="hvac:AirFilterDeviceFaceArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Air Filter Calculated Nominal Face Area (inch
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: PRODUCT (H08_AirFilterDeviceLength, H09_AirFilterDeviceWidth )</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="H11_AirFilterDeviceFaceAreaRequiredMin" type="hvac:AirFilterDeviceFaceAreaRequiredMin">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If H07_AirFilterDeviceDepth == 1 result = PRODUCT(H06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="H11_AirFilterDeviceFaceAreaMessage" type="comp:AirFilterDeviceFaceAreaMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If H07_AirFilterDeviceDepth == 1 result = PRODUCT(H06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="H12_AirFilterDeviceFaceAreaCompliance" type="comp:AirFilterDeviceFaceAreaCompliance">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Face Area  Compliance</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If H11_AirFilterDeviceFaceAreaMessage == SpecifiedByDesigner result = SpecifiedByDesigner Else if H10_AirFilterDeviceFaceArea GTE H11_AirFilterDeviceFaceAreaRequiredMin result = FaceAreaComplies display term Complies Else result = FaceAreaDoesNotComply display term Does Not Comply</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="H13_DuctSystemAirFilterDevicePressureDrop" type="hvac:DuctSystemAirFilterDevicePressureDrop">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Allowable Pressure Drop for Air Filter Device (inch W.C.)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If H07_AirFilterDeviceDepth == 1 result = 0.1 Else user input numeric x.xx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H13a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only if  section H applies</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="IBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory Air Filter Device Requirements can be found in Section 150.0(m)12A-E.  Some mandatory requirements may apply in addition to those listed below.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Recirculated and outdoor air filtering</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All recirculated air and all outdoor air (including make up air) supplied to the occupiable space is filtered before passing through the system's thermal conditioning components.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The space conditioning system shall be designed to accommodate the clean-filter pressure drop imposed by the system air filter device(s). The design airflow rate and maximum allowable clean-filter pressure drop at the design airflow rate applicable to each air filter shall be determined by the system designer.  The system installer shall affix a sticker/label to each system air filter grille/rack locations that discloses the filter's design airflow rate and the filter's maximum allowable clean-filter pressure drop at the design airflow rate.  The sticker/labels shall be permanently affixed to the air filter grille/rack, readily legible, and visible to a person replacing the air filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter access and regular service</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All system air filter devices shall be located and installed in such a manner as to allow access and regular service by the system owner.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media efficiency</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The system shall be provided with air filter media having a designated efficiency equal to or greater than MERV 6 when tested in accordance with ASHRAE Standard 52.2, or a particle size efficiency rating equal to or greater than 50% in the 0.30 to1.0 
                           <ns1:micron/>
                           m range and equal to or greater than 85 percent in the 1.0 - 3.0 
                           <ns1:micron/>
                           m range when tested in accordance with AHRI Standard 680.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media manufacturer label</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The system shall be provided with air filters that have been labeled by the manufacturer to disclose efficiency and pressure drop ratings that conform to the efficiency and pressure drop requirements for the air filter grilles/racks..</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Prevent air bypassing filter</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Filter racks or grilles shall use gaskets, sealing, or other means to close gaps around inserted filters and prevent air from bypassing the filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="IEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_J">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">ECC Verification Requirements for Duct Systems</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section applies if either section F or section G applies. In that case require one row of data in this table for each of the indoor units listed in F03_IndoorUnitName and require one row of data for each indoor unit listed in G03_IndoorUnitName</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSDucts">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="J01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Identification or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference B01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference B02_ResidentialHvacSystemAreaServed for this system</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from F03_IndoorUnitName or G03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J04_DuctLeakageTestExemption" type="comp:DuctLeakageTestExemption">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exemption From Duct Leakage Requirements</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  Default result for DuctLeakageTestExemption = NoExemptions;  Allow user to override the default and select one of the following exemptions:  DuctsSealedTested_HERSCertified display text: Ducts have previously been sealed, tested, and certified by a ECC rater,   DuctLessThan40Feet display text: Duct system has less than 40 ft of duct.  For choice DuctSystemAsbestos display text: Duct system is insulated or sealed with asbestos.  Flag non-default values and report in project status notes field; The enforcement agency may require additional documentation as validation.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J05_DuctLeakageTestRequired" type="comp:DuctLeakageTestRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-20  
                                             <ns1:line4/>
                                             Duct Leakage Test
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If  J04_DuctLeakageTestExemption !=  NoExemptions Then result = false;   Else determine the  result for this field by the user responses in B04, B05 , B06, B07, B08, B09 and use of Logic Table for Determining Alteration Type and ECC Verification Requirements. Constrain user  input for B04-B09 to allow only available combinations of responses given in the Logic Table.   If the term DctLk appears in the ECC column, Then result is true (duct leakage test required);
 Else If DctLk does not appear in the ECC column, then result is false.  Display Yes if result ==  true and No if result == false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J06_DuctsInConditionedSpaceVerification" type="comp:DuctsInConditionedSpaceVerification">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-21 
                                             <ns1:line2/>
                                             Duct Location Verification
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If applicable value in F10 Or G10 DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned Or UninsulatedInDirectConditioning result = true; Else result = false.  Display Yes if result ==  true and No if result == false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J07_AHU_FanEfficacyVerificationRequired" type="comp:AHU_FanEfficacyVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-22 
                                             <ns1:line3/>
                                             AHU Fan Efficacy (W/cfm)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If G14_CanFanEfficacyProtocolsTestSystem == false result = false;  Else if G11_DuctFilterGrilleSizingComplianceMethod = HERS_FanEfficacyAirflowRate then result = true; else if B09_AllNewOrReplacedHvacSystem = true And C07_ResidentialCoolingSystemType = NoCooling  And C14 IsVentialationSystemCFI == true, And G13_CanRA3_3AirflowProtocolsTestSystem == true And, G14_CanFanEfficacyProtocolsTestSystem== true then result = true;  Else result = false.  Display Yes if result ==  true and No if result == false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J08_AHU_AirflowRateVerificationRequired" type="comp:AHU_AirflowRateVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-23 
                                             <ns1:line2/>
                                             AHU Airflow Rate (cfm/ton)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:   If G13_CanRA3_3AirflowProtocolsTestSystem
 == false Or F11_CanRA3_3AirflowProtocolsTestSystem == false  
result = false
 
Else If G11_DuctFilterGrilleSizingComplianceMethod == HERS_FanEfficacyAirflowRate result = true;  
 
Else If K03_RefrigerantChargeVerificationRequired  == true And J09_ReturnDuctDesignVerificationRequired == false 
result = true;  
 
Else If B09 AllNewOrReplacedHvacSystem == true And C07_ResidentialCoolingSystemType == NoCooling  And C14 IsVentialationSystemCFI == true, And G13_CanRA3_3AirflowProtocolsTestSystem == true And, G14_CanFanEfficacyProtocolsTestSystem== true 
result = true;  
 
Else result is false. 
 
Display Yes if result ==  true and No if result == false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J09_ReturnDuctDesignVerificationRequired" type="comp:ReturnDuctDesignVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-28 
                                             <ns1:line2/>
                                             Return Duct Design - Table 150 B or C
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If G11_DuctFilterGrilleSizingComplianceMethod == HERS_ReturnDuctDesignTable150 then result = true;  Else result = false.   Display Yes if result ==  true and No if result == false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="J09a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_K">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText"> Field Verification Requirements For Space Conditioning Equipment</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">Require one row of data for each SC System listed in C01_ResidentialSpaceConditioningSystemName</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSEquipment">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="K01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from B01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from B02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="K03_RefrigerantChargeVerificationRequired" type="comp:RefrigerantChargeVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH-25 
                                             <ns1:line3/>
                                             Refrigerant Charge
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated Field: If C03_ResidentialHeatingSystemType Or C07_ResidentialCoolingSystemType  ==  NonAirSourceHP Or NonAirCooledAC result = false Else  determine the  result for this field by the user responses in B04, B05 , B06, B07, B08, B09 and use of Logic Table for Determining Alteration Type and ECC Verification Requirements. Constrain user  input for B04-B09 to allow only available combinations of responses given in the Logic Table.  If "RC" appears in the ECC column And  If  A02_ClimateZone == 2 Or InclusiveRange(8,15) then result = true;  Else result = false. Display Yes and No to represent Boolean values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K03a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_L">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Space Conditioning Systems, Ducts and Fans Mandatory Requirements and Additional Measures</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="L_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Additional mandatory requirements from Section 150.0 that are not listed here may be applicable to some systems.  These requirements may be applicable to only newly installed equipment or portions of the system that are altered.  Existing equipment may be exempt from these requirements.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L00_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Heating Equipment</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Equipment Efficiency</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Equipment Efficiency: All heating equipment must meet the minimum efficiency requirements of Section 110.1 and Section 110.2(a) and the Appliance Efficiency Regulations.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Controls</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Controls:  All unitary heating systems, including heat pumps, must be controlled by a setback thermostat.  These thermostats must be capable of allowing the occupant to program the temperature set points for at least four different periods in 24 hours. See Sections 150.0(i), 110.2(b).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Sizing:</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Sizing:  Heating load calculations must be done on portions of the building served by new heating systems to prevent inadvertent undersizing or oversizing. See sections 150.0(h)1 and 2, and the exceptions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Furnace Temperature Rise</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Furnace Temperature Rise: Central forced-air heating furnace installations must be configured to operate at or below the furnace manufacturer's maximum inlet-to-outlet temperature rise specification. See Section 150.0(h)4.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Standby Losses and Pilot Lights</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Standby Losses and Pilot Lights: Fan-type central furnaces may not have a continuously burning pilot light. Section 110.5 and Section 110.2(d).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L05After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Cooling Equipment</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Equipment Efficiency:</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Equipment Efficiency:  All cooling equipment must meet the minimum efficiency requirements of Section 110.1 and Section 110.2(a) and the Appliance Efficiency Regulations.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Refrigerant Line Insulation</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Refrigerant Line Insulation:  All refrigerant line insulation in split system air conditioners and heat pumps must meet the R-value and protection requirements of Section 150.0(j)2 and 3, and Section 150.0(m)9.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L08">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Condensing Unit Location</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Condensing Unit Location:  Condensing units shall not be placed within five (5) feet of a dryer vent outlet. See Section 150.0(h)3A.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L09">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Liquid Line Filter Drier</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Liquid Line Filter Drier: A  liquid line filter drier shall be installed according to the manufacturer's specifications 150.0(h)3B</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L10">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Sizing</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Sizing: Cooling load calculations must be done on portions of the building served by new cooling systems to prevent inadvertent undersizing or oversizing. See Section 150.0(h)1 and 2, and the exceptions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L10After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Cooling and Heating Equipment (Additional Requirements)</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L11">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">System Selection Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>System Selection:</ns1:b>
                            See Section 150.0(h)5 
                           <ns1:line1/>
                            A. Equipment sizing and selection shall meet the cooling and heating loads of Section 150.0(h) 1 and 2

                           <ns1:line1/>
                           B. Systems shall be sized based on ACCA Manual S-2023 in accordance with these requirements: 
                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>Cooling Capacity:</ns1:b>
                            There is no limit on the minimum capacity. 
                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>urnaces:</ns1:b>
                            Heating capacity shall be sized based on ACCA Manual S-2023, Table N2.5

                           <ns1:line1/>
                           <ns1:tab1/>
                            i. 
                           <ns1:b>Heat Pump Heating Capacity:</ns1:b>
                            
                           <ns1:line1/>
                           <ns1:tab2/>
                            a. Minimum: Heating systems are required to have a heating capacity meeting the minimum requirements of the CBC not including any supplemental heating. 
                           <ns1:line1/>
                           <ns1:tab2/>
                            b. Maximum: There is no limit on the maximum heating capacity.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L12">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Defrost Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Defrost:</ns1:b>
                            See Section 150.0(h)6 
                           <ns1:line1/>
                            A. If a heat pump is equipped with an installer adjustable defrost delay timer, the delay timer shall be set to greater than or equal to 90 minutes.

                           <ns1:line1/>
                           B. The installer shall certify on the Certificate of Installation (CF2R) that the control configuration has been tested in accordance with the testing procedure in the CF2R.
                           <ns1:line1/>
                            
                           <ns1:b>Exception 1 to Section 1550.0(h)6. </ns1:b>
                            Dwelling units in Climate Zones 6 and 7. 

                           <ns1:line1/>
                            
                           <ns1:b>Exception 1 to Section 1550.0(h)6. </ns1:b>
                            Dwelling units with a conditioned floor area of 500 square feet or less in Climate Zones 3, 5 through 10 and 15.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L13">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Supplemental Heating Controls</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Supplementary heating control configuration:</ns1:b>
                            See Section 150.0(h)7 
                           <ns1:line1/>
                            Heat pumps with supplementary heating, including but not limited to, electric resistance heaters or gas furnace supplementary heating, shall comply with the following requirements: 
                           <ns1:b>See Section 150.0(h)7 for exceptions </ns1:b>
                           

                           <ns1:line1/>
                            A. Lock out supplementary heating above an outdoor air temperature of no greater than 35
                           <ns1:deg/>
                           F. There are additional thermostat requirements in Section 150.0(i).

                           <ns1:line1/>
                            B. The installer shall certify on the Certificate of Installation (CF2R) that the control configuration has been tested in accordance with the testing procedure in the CF2R. 

                           <ns1:line1/>
                            C. The controls may allow supplementary heater operation above 35
                           <ns1:deg/>
                           F only during defrost; or when the user selects emergency operation.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L14">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Electric Resistance Sizing</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Sizing of electric resistance supplementary heat:</ns1:b>
                            See Section 150.0(h)8 
                           <ns1:line1/>
                            For heat pumps with electric resistance heating, the capacity of electric resistance heat shall not exceed the heat pump nominal cooling capacity (at 95
                           <ns1:deg/>
                           F ambient conditions) multiplied by 2.7 kW per ton, rounded up to the closest kW.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L15">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Third-party Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Capacity variation with third-party thermostats</ns1:b>
                            See Section 150.0(h)9 
                           <ns1:line1/>
                            Variable or multi-speed systems shall comply with the following requirements: 
                           <ns1:line1/>
                            A. The space conditioning system and thermostat together shall be capable of responding to heating and cooling loads by modulating system compressor speed, and meet thermostat requirements in Section 150.0(i)2
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L15After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Air Distribution System Ducts, Plenums and Fans</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L16">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Insulation</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Insulation: The minimum duct insulation value is R-6 or ducts can be uninsulated if the duct system is located entirely in conditioned space. Note that higher values may be required by the prescriptive or performance requirements. See Section 150.0(m)1B for exceptions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L17">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Connections and Closures</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Connections and Closures: All installed air-distribution system ducts and plenums must be, sealed and insulated to meet the requirements of CMC Sections 601.0, 602.0, 603.0, 604.0, 605.0 and ANSI/SMACNA-006-2006.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L17After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Heat Pump Thermostat</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L18">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Requirements of Section 110.2(b) and (c)</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">A thermostat shall be installed that meets the requirements of Section 110.2(b) and Section 110.2(c).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L19">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Manufacturers published installation specifications</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The thermostat shall be installed in accordance with the manufacturers published installation specifications</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L20">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">First stage of heating</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">First stage of heating shall be assigned to heat pump heating.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L21">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Second stage back up heating</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Second stage back up heating shall be set to come on only when the indoor set temperature cannot be met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L22">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Setback Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Setback Thermostats:  All heating or cooling systems, including heat pumps, not controlled by a central energy management control system (EMCS) shall have a setback thermostat, as specified in Section 110.2(c).  See Section 150.0(i)1</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L23">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Supplemental Heating Thermostats</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Thermostats that are applied to heat pumps with supplementary heating . See Section 150.0(i)2 
                           <ns1:line1/>
                            The thermostats controlling heat pumps with electric resistance supplementary heat or gas furnace supplementary heat shall comply with the following requirements: See Section 150.0((i)2 for exceptions. 

                           <ns1:line1/>
                            A. The thermostat shall receive outdoor air temperature from an outdoor air temperature sensor or from an internet weather service.
                           <ns1:line1/>
                            B. The thermostat shall display the outdoor air temperature. 
                           <ns1:line1/>
                            C. The thermostat and heat pump shall lock out supplementary heat when the outdoor air temperature is above 35
                           <ns1:deg/>
                           F.

                           <ns1:line1/>
                            D. The thermostat shall have an indicator to notify when supplementary heat or emergency heat is in use. 
                           <ns1:line1/>
                            E. During defrost or when the user selects emergency heating, supplementary heat operation is permitted above 35
                           <ns1:deg/>
                           F. 
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L23After_Heading">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           <ns1:b> Space Conditioning Load Calculations and System Capacity for Additions</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L24">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Minimum Capacity</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Minimum capacity limits and suppementary heating requirements are as described in Section 150.0(h)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L25">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Maximum Capacity</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The maximum capacity depends on the relative sizes of the calculated heating design load (HL) and cooling design load (CL), the type of space conditioning system, and the duct sizing. 
                           <ns1:b>See Section 150.2(a)1Eii for exceptions </ns1:b>
                           

                           <ns1:line1/>
                            a. In situations where airflow is field verified to be at least 350 cfm/ton, there is no maximum capacity limit. 
                           <ns1:line1/>
                            b. In situations where airflow is NOT field verified to be at least 350 cfm/ton, the system capacities shall be no larger than indicated in Table 150.2-A for heating and Table 150.2-B for cooling.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L26">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Envelope Leakage</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           For additions, envelope leakage specified in the load calculation shall be no greater than the values shown in Table 150.2-C 
                           <ns1:b>See Section 150.2(a)1Eiii for exceptions </ns1:b>
                            
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="LEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_M">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Test of Defrost Delay Timer Setting (Section 150.0(h)6)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="MBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The installing contractor shall confirm that a heat pump's installer-adjustable Defrost Delay Timer Setting (if it exists) is set to no less than 90 minutes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="M01_DefrostDelayTimerTestApplies" type="comp:DefrostDelayTimerTestApplies">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test Applicability. Select the statement describing test applicability for this project:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from TestApplies display term 1. Test applies and no exceptions, NoAdjustDefrostDelayTimer display term 2 Test does not apply because no adjustable Defrost Delay Timer Setting, 
Exception1TestNA display term 3 Test does not apply because of Exception 1 Dwelling units in Climate Zones 6 and 7, Exception2TestNA display term  Test does not apply because of Exception 2 Dwelling units with conditioned floor area of 500 square feet or less in Climate Zones 3, 5 through 10 and 15</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="M01a_DefrostDelayTimerTestMessage" type="comp:DefrostDelayTimerTestMessage">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This field is required and displayed If M01_DefrostDelayTimerTestApplies != TestApplies If M01_DefrostDelayTimerTestApplies == NoAdjustDefrostDelayTimer result = NoTimerMessage; Else If M01_DefrostDelayTimerTestApplies == Exception1TestNA result = Exception1Message; Else If M01_DefrostDelayTimerTestApplies == Exception2TestNA result = Exception2Message;</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="1" minOccurs="0" name="DefrostDelayTimerTestData">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test of Defrost Delay Timer Setting (Section 150.0(h)6)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This subsection is required and displayed If M01_DefrostDelayTimerTestApplies == TestApplies</xs:documentation>
                        
                        
                        <xs:documentation source="MinOccurs">If this subsection is not required, nothing is displayed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element name="M02_DefrostDelayTimerControls" type="comp:DefrostDelayTimerControls">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record Configuration of Controls.  Specify the mechanism for setting the Defrost Delay Timer Setting</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">(for example, the name of the defrost delay timer in the thermostat setup, or the location and number of the specific dip switch, jumper, or dial that adjusts the Defrost Delay timer)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="M03_DefrostDelayTimerMaxMinutes" type="comp:DefrostDelayTimerMaxMinutes">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record heat pump's Maximum Available Defrost Delay Timer Setting (minutes)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements"/>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input IntegerNonnegative</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="M04_DefrostDelayTimerSetting" type="comp:DefrostDelayTimerSetting">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record where you set the Defrost Delay Timer Setting</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements">(for example, the numeric timer setting, dip switch position, jumper configuration, or dial setting)</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="M05_DefrostDelayTimerMinutes" type="comp:DefrostDelayTimerMinutes">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Record where you set the Defrost Delay Timer Setting in minutes</xs:documentation>
                                 
                                 
                                 <xs:documentation source="AdditionalRequirements"/>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User input IntegerNonnegative</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                           
                           <xs:element name="M06_DefrostDelayTimerCompliance" type="comp:DefrostDelayTimerCompliance">
                              
                              
                              <xs:annotation>
                                 
                                 
                                 <xs:documentation source="FieldText">Confirming Configuration of Controls.  If possible, the Defrost Delay Timer Setting must be 90 minutes or greater.  Confirm the Defrost Delay Timer Setting is at least 90 minutes</xs:documentation>
                                 
                                 
                                 <xs:documentation source="CalculationsAndRules">User selects from Yes (Boolean true) or No - Do Not Proceed (Boolean false)</xs:documentation>
                                 
                             
                              </xs:annotation>
                              
                          
                           </xs:element>
                           
                       
                        </xs:sequence>
                        
                    
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
                       
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_N">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Test of Supplementary Heating Lockout</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="NBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The installing contractor shall confirm that the heat pump or thermostat is configured to lock out supplementary heating anytime the outdoor temperature is above 35
                           <ns1:deg/>
                           F
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="N01_SupplementHeatLockoutTestApplies" type="comp:SupplementHeatLockoutTestApplies">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test Applicability. Select the statement describing test applicability for this project:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from TestApplies display term 1. The test applies because the heating system is a heat pump with supplementary heating and there are no exceptions, NoSupplementHeat 2. Test does not apply because heating system does not include heat pump with auxiliary heating, 
Exception1TestNA display term 3 Test does not apply because of Exception 1 Heat pump being installed in a single family dwelling unit in Climate Zones 7 or 15, Exception2TestNA display term  Test does not apply because of Exception 2 Heat pump being installed in a single family dwelling unit with conditioned floor area of 500 square feet or less.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="N01a_SupplementHeatLockoutTestMessage" type="comp:SupplementHeatLockoutTestMessage">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This field is required and displayed If N01_SupplementHeatLockoutTestApplies != TestApplies If N01_SupplementHeatLockoutTestApplies == NoSupplementHeat result = NoSupplementHeatMessage; Else If N01_SupplementHeatLockoutTestApplies == Exception1TestNA result = Exception1Message; Else If N01_SupplementHeatLockoutTestApplies == Exception2TestNA result = Exception2Message;</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
