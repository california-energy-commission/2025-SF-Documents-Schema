                                    <xs:documentation source="FieldText">If supplementary heating is electric resistance, what is its rated capacity (kW)? </xs:documentation>
                                    
                                      
                                    <xs:documentation source="CalculationsAndRules">User input DecimalNonnegative; Units kW</xs:documentation>
                                    
                                  
                                 </xs:annotation>
                                 
                               
                              </xs:element>
                              
                               
                              <xs:element name="N02_NotApplicableMessage" type="comp:NotApplicableMessage">
                                 
                                  
                                 <xs:annotation>
                                    
                                     
                                    <xs:documentation source="FieldText">If supplementary heating is electric resistance, what is its rated capacity (kW)?</xs:documentation>
                                    
                                     
                                    <xs:documentation source="CalculationsAndRules">If supplementary heating is not electric resistance heating result = NotApplicable stored in NotApplicablemessage; </xs:documentation>
                                    
                                 
                                 </xs:annotation>
                                 
                              
                              </xs:element>
                              
                           
                           </xs:choice>
                           
                           
                           <xs:choice maxOccurs="1">
                              
                              
