                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Test of Supplementary Heating Lockout</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">This subsection is required and displayed If N01_SupplementHeatLockoutTestApplies == TestApplies</xs:documentation>
                        
                        
                        <xs:documentation source="MinOccurs">If this subsection is not required, nothing is displayed.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
