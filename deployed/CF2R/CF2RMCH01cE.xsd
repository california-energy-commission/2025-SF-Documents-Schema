         <xs:element minOccurs="0" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Split System Indoor Unit (Coil or Fan Coil) Equipment Information - applicable to DX or hydronic, heating or cooling, coils and fan coil units.</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
This Section is applicable only if one or more systems in section C has C04_ResidentialHeatingSystemType  Or C05_ResidentialCoolingSystemType  == CentralSplitAC, CentralSplitHP, DuctedMultiSplitAC, DuctlessMultiSplitAC, DuctedDuctlessMultiSplitAC, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessSplitAC (display term Ductless mini-split AC), DuctedMiniSplitAC, DuctedMiniSplitHP, AirToWaterHeatPump, GroundSourceHeatPump,  DuctlessSplitHP (display term Ductless mini-split HP), DuctlessVRF_AC, DuctlessVRF_HP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless, VCHP_IndoorUnitDuctedAndDuctless, EvaporativelyCooledCondenser, GasAbsorptionAC, CombinedHydronicForcedAir, HydronicForcedAir, HydronicHP_ForcedAir, IceStorageAC, SmallDuctHighVelocityHP, SmallDuctHighVelocityAC.   For each SC system in section C with C04 Or C05 == a type in this list, require one row of data for each of the quantity of indoor units in C11_IndoorUnitCount for that system.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="F_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Systems with more than one indoor coil or fan coil unit (e.g. multi-split systems) shall provide information for each of the system indoor unit coils or fan coil units.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableCoilEquipment">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="F01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C02</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C11_IndoorUnitsCount  GTE 1 And all of the following conditions are true:  D01 == F01 And D02 == F02 And C04 == CentralGasFurnace result = D03; Else If C11_IndoorUnitsCount = 1 result = C02_ResidentialHvacSystemAreaServed Else user input maximum 15 characters;  As default require all entries to be unique in this dwelling unit; (i.e. unique within the scope of the MCH-01) except for the case when all of the following conditions are true:   D01 == F01 And D02 == F02 And C04  == CentralGasFurnace.   Allow user to override default  uniqueness rule if necessary.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F04_IndoorUnitType" type="hvac:IndoorUnitType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User selects from list: CoilAC Display term AC Coil, CoilAndNonfurnaceAH display term Non-furnace Airhandler + Coil, CoilHP display term HP Coil, FancoilAHU display term Fancoil AHU</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F05_IndoorUnitDucts" type="hvac:IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Duct Status</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C11_IndoorUnitsCount  GTE 1 And all of the following conditions are true:  D01 == F01 And D02 == F02 And C04 == CentralGasFurnace result = D05; Else If C06_DucSystemType == Ductless: result = Ductless; Else If  C06_DucSystemType == Ducted, user selects from DuctsGT10Ft display term Ducted greater than 10ft length and DuctsLTE10Ft display term Ducted less than or equal to 10ft length; Else If C06_DucSystemType  == DuctedAndDuctlessIndoorUnits  user selects from Ductless, DuctsGT10Ft display term Ducted  greater than 10ft length, DuctsLTE10Ft display term Ducted less than or equal to 10ft length</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F06_DoesUnitProvideCFI_IAQ" type="comp:DoesUnitProvideCFI_IAQ">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does Indoor Unit Provide CFI IAQ Ventilation?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C11_IndoorUnitsCount  GTE 1 And all of the following conditions are true:  D01 == F01 And D02 == F02 And C04 == CentralGasFurnace result = D04; 
Else If any of these conditions are true:  C11_IndoorUnitsCount  GT 1 Or parent CC   VentilationSystemType for this dwelling unit  == Balanced Or parent CC building type == Multifamily 
result = false display term No;  
Else user selects Yes (true value) or No (false value)
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="F07_IndoorCoilManufacturer" type="comp:IndoorCoilManufacturer">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Manufacturer</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="F07_FanCoilUnitManufacturer" type="comp:FanCoilUnitManufacturer">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Manufacturer</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
