         <xs:element minOccurs="1" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Space Conditioning (SC) System Component Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
Require one row of data to be entered in this table for each space conditioning system in the count field A04, ResidentialDwellingUnitSpaceConditioningCount</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableComponents">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="C01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User select applicable system name from a list comprised of the systems identified in section B, field B01.  If SC system names from parent CC are installed more than once in this dwelling unit, then duplicate SC System names are allowed in this field.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input text 15 characters maximum.  Require each entry to be unique in this dwelling unit, i.e. unique within the scope of this instance of the MCH-01</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C03_ResidentialHvacSystemConditionedArea" type="hvac:ResidentialHvacSystemConditionedArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Conditioned Floor Area Served by the System (ft
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input numeric xxxx; Require the sum of the values in this column to be equal to the value in A03 as condition of completion of the document.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C04_ResidentialHeatingSystemType" type="hvac:ResidentialHeatingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B02 as default;   allow user to override the default and select one from choices for ResidentialHeatingSystemType:   CentralGasFurnace, CentralSplitHP, CentralPackagedHP, CentralLargePackagedHP, DuctlessSplitHP (display term Ductless mini-split HP), RoomHP, Boiler, Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  HydronicHP_ForcedAir, GasPackagedFurnace, GasWallFurnace , GasSpaceHeater, Electric, NonAirSourceHP, WoodHeat, SmallDuctHighVelocityHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessVRF_HP, DuctedMiniSplitHP, DuctedMultiSplitHP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless,  VCHP_IndoorUnitDuctedAndDuctless, SPVHP, PTHP and NoHeating.  If result == NoHeating check that there is at least one heating system entered in this section in C04 to comply; Else flag non-compliant condition (no heating installed) and do not allow registration to continue.     Flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C05_ResidentialCoolingSystemType" type="hvac:ResidentialCoolingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Cooling System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B05 as default;   allow user to override the default and select one from choices for ResidentialCoolingSystemType:  CentralLargePackagedAC, CentralLargePackagedHP, CentralPackagedAC, CentralPackagedHP, CentralSplitAC, CentralSplitHP, DuctedMultiSplitAC, DuctlessMultiSplitAC, DuctedDuctlessMultiSplitAC, DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessSplitAC (display term Ductless mini-split AC) , DuctlessSplitHP (display term Ductless mini-split HP), DuctlessVRF_AC, DuctlessVRF_HP, EvaporativeDirect, EvaporativeIndirect, EvaporativeIndirectDirect, EvaporativelyCooledCondenser, GasAbsorptionAC, GroundSourceHeatPump, Hydronic, HydronicHP, HydronicHP_ForcedAir, IceStorageAC, NoCooling, NonAirCooledAC, NonAirSourceHP, RoomAC, RoomHP, SmallDuctHighVelocityHP, SmallDuctHighVelocityAC.  DuctedMiniSplitAC, DuctedMiniSplitHP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless,  VCHP_IndoorUnitDuctedAndDuctless SPVAC, SPVHP, PTAC, PTHP;  Note: NoCooling value indicates a heating-only system.  Flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C06_DuctSystemType" type="hvac:DuctSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Distribution System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from B08 DuctSystemType; Allow user to override and pick from list. DuctedSystem display term Ducted System, Ductless display term System has no ducts, DuctedAndDuctlessIndoorUnits display term Multiple split Indoor Units combined Ducted and Ductless</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C07_DuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value for DuctLocation from B09 as default;   Allow user to override and pick from list.  Choices for DuctLocation and display text:   ConditionedSpace display text: HVAC system(s) with all HVAC ducts located in conditioned space.      DuctsInMultipleLocations display text: Ducts located in multiple places.   Outdoors display text: Ducts located in exposed outdoor locations.  UnconditionedAttic display text: Ducts located overhead in unconditioned attic.  UnconditionedCrawlSpace display text: Ducts located underfloor in unconditioned crawl space.  UnconditionedGarage display text: Ducts located in an unconditioned garage.  Flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                             
                                             
                                             <xs:enumeration value="Ductless"/>
                                             
                                             
                                             <xs:enumeration value="DuctsInMultipleLocations"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedBasement"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C08_ThermostatType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SC System Thermostat Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B11 as default;   allow user to override the default and select one from list. OccupantControlledSmartThermostat display term OCST per JA5, SetbackThermostat display term Setback, EnergyManagementSystem display term Energy Management System (EMS); Allow N/A value If B11 is N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:ThermostatType">
                                                
                                                
                                                <xs:enumeration value="EnergyManagementSystem"/>
                                                
                                                
                                                <xs:enumeration value="OccupantControlledSmartThermostat"/>
                                                
                                                
                                                <xs:enumeration value="SetbackThermostat"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C08_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">SC System Thermostat Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B11 as default;   allow user to override the default and select one from list. OccupantControlledSmartThermostat display term OCST per JA5, SetbackThermostat display term Setback, EnergyManagementSystem display term Energy Management System (EMS); Allow N/A value If B11 is N/A</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C09_ResidentialCoolingZoneType" type="hvac:ResidentialCoolingZoneType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Zoning Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_CoolingSystemType ==  NoCooling, then result = NotApplicable stored in the NotApplicableMessage and display text:  N/A;  Else allow user to pick from list.     Choices are ZoneControlled,  display term Zonally Controlled;  NotZoneControlled, display term NotZonal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C09_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Zoning Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_CoolingSystemType ==  NoCooling, then result = NotApplicable stored in the NotApplicableMessage and display text:  N/A;  Else allow user to pick from list.     Choices are ZoneControlled,  display term Zonally Controlled;  NotZoneControlled, display term NotZonal</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C10_CondenserSpeedType" type="hvac:CondenserSpeedType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling System Compressor Speed Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_CoolingSystemType ==  NoCooling, then result =  NotApplicable stored in the NotApplicableMessage and display text:  N/A;  Else  user picks from list.  Choices for CompressorSpeedType: MultiSpeed display term Multi-speed,   SingleSpeed display term Single Speed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling System Compressor Speed Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C05_CoolingSystemType ==  NoCooling, then result =  NotApplicable stored in the NotApplicableMessage and display text:  N/A;  Else  user picks from list.  Choices for CompressorSpeedType: MultiSpeed display term Multi-speed,   SingleSpeed display term Single Speed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C11_IndoorUnitsCount" type="hvac:IndoorUnitsCount">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Number of Indoor Units for this System</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C04 Or C05 ==  RoomAC, RoomHP, GasWallFurnace , GasSpaceHeater, Electric, WoodHeat, GasPackagedFurnace, CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC, CentralLargePackagedHP, EvaporativeDirect, EvaporativeIndirect, EvaporativeIndirectDirect, EvaporativelyCooledCondenser result = N/A stored in NotApplicableMessage; 
 
Else If parent CC requires CFI IAQ Ventilation system, result = 1, Else result = 1 as default  but allow user to overwrite with integer GT 1 Or N/A stored as NotApplicable in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="C11_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Number of Indoor Units for this System</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C04 Or C05 ==  RoomAC, RoomHP, GasWallFurnace , GasSpaceHeater, Electric, WoodHeat, GasPackagedFurnace, CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC, CentralLargePackagedHP, EvaporativeDirect, EvaporativeIndirect, EvaporativeIndirectDirect, EvaporativelyCooledCondenser result = N/A stored in NotApplicableMessage; 
 
Else If parent CC requires CFI IAQ Ventilation system, result = 1, Else result = 1 as default  but allow user to overwrite with integer GT 1 Or N/A stored as NotApplicable in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C11a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_D">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Heating Equipment Information (not heat pumps)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
This Section is applicable only if at least one row in C04_ResidentialHeatingSystemType != one of these Heat Pump types: CentralLargePackagedHP, CentralPackagedHP, CentralSplitHP,  DuctlessSplitHP (display term Ductless mini-split HP),  DuctedMultiSplitHP, DuctlessMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctlessVRF_HP, SmallDuctHighVelocityHP, HydronicHP, HydronicHP_ForcedAir, RoomHP, DuctedMiniSplitHP, AirToWaterHeatPump, GroundSourceHeatPump, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, SPVHP, PTHP . For each SC that satisfies this condition, do one of the following:  If SC system in C02 has C11_NotApplicableMessage value, require one row of data; Else If  SC System has C11_IndoorUnitsCount GTE 1 And C04 == CentralGasFurnace require one row of data for each of the quantity of indoor units specified in C11 for that system.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHeating">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="D01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference to C01, ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C02</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D03_IndoorUnitName" type="hvac:IndoorUnitName">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C11_NotApplicableMessage == N/A then result = N/A  stored in NotApplicableMessage; Else If C11_IndoorUnitsCount = 1 result = C02_ResidentialHvacSystemAreaServed Else user input maximum 15 characters;  As default require value to be unique in this dwelling unit (i.e. unique within the scope of the MCH-01) except for the case when all of the following conditions are true:  D01 == F01 And D02 == F02 And C04_ResidentialHeatingSystemType == CentralGasFurnace.   Allow user to override this uniqueness rule if necessary.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C11_NotApplicableMessage == N/A then result = N/A  stored in NotApplicableMessage; Else If C11_IndoorUnitsCount = 1 result = C02_ResidentialHvacSystemAreaServed Else user input maximum 15 characters;  As default require value to be unique in this dwelling unit (i.e. unique within the scope of the MCH-01) except for the case when all of the following conditions are true:  D01 == F01 And D02 == F02 And C04_ResidentialHeatingSystemType == CentralGasFurnace.   Allow user to override this uniqueness rule if necessary.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="D04_DoesUnitProvideCFI_IAQ" type="comp:DoesUnitProvideCFI_IAQ">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Does Indoor Unit Provide CFI IAQ Ventilation?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If any of these conditions are true:  C11_IndoorUnitsCount  GT 1 Or CF1R  VentilationSystemType for this dwelling unit  == Balanced, BalancedERV or BalancedHRV, 
result = false display term No;  
Else If C11_NotApplicableMessage has a value And C04_ResidentialHeatingSystemType == CentralGasFurnace 
user selected Yes (true value) or No (false value); 
 
Else user selected Yes (true value) or No (false value).
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D05_IndoorUnitDucts" type="hvac:IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Duct Status</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">
                                             If C06_DuctSystemType == Ductless: result = Ductless; Else If C06_DuctSystemType ==  DuctedSystem  user selects from DuctsGT10Ft display term Ducted 
                                             <ns1:gt/>
                                              10ft length and DuctsLTE10Ft display term Ducted 
                                             <ns1:lte/>
                                              10ft length; Else If C06_DuctSystemType ==  DuctedAndDuctlessIndoorUnits  user selects from  DuctsGT10Ft display term Ducted 
                                             <ns1:gt/>
                                              10ft length, DuctsLTE10Ft display term Ducted 
                                             <ns1:lte/>
                                              10ft length and Ductless display term Ductless,
                                          </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D06_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplcableMessage == N/A then result = N/A stored in D06_NotApplicableMessage, Else result = B03_EfficiencyType.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="AFUE"/>
                                                
                                                
                                                <xs:enumeration value="COP"/>
                                                
                                                
                                                <xs:enumeration value="HSPF"/>
                                                
                                                
                                                <xs:enumeration value="HSPF2"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplcableMessage  == N/A then result = N/A stored in D06_NotApplicableMessage, Else result = B03_EfficiencyType.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="D07_EfficiencyInstalledValueAFUE" type="hvac:EfficiencyInstalledValueAFUE">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B04_NotApplicableMessage   == N/A result = N/A stored in D07_NotApplicableMessage Else User input numeric value  InclusiveRange ( 0.00, 1.00); Note stored result is fraction and display value is PRODUCT (result, 100) to display percent.  Check:  If result GTE B04_EfficiencyMinimumValueAFUE result complies Else flag it as a non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D07_EfficiencyInstalledValueCOP" type="hvac:EfficiencyInstalledValueCOP">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B04_NotApplicableMessage   == N/A result = N/A stored in D07_NotApplicableMessage Else User input numeric value  InclusiveRange ( 0.00, 1.00); Note stored result is fraction and display value is PRODUCT (result, 100) to display percent.  Check:  If result GTE B04_EfficiencyMinimumValueCOP result complies Else flag it as a non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D07_EfficiencyInstalledValueHSPF" type="hvac:EfficiencyInstalledValueHSPF">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B04_NotApplicableMessage  == N/A result = N/A stored in D07_NotApplicableMessage Else User input numeric value  InclusiveRange ( 0.00, 1.00); Note stored result is fraction and display value is PRODUCT (result, 100) to display percent; If result GTE B04_EfficiencyMinimumValueHSPF result complies Else flag it as a non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D07_EfficiencyHSPF2" type="hvac:EfficiencyHSPF2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B04_NotApplicableMessage  == N/A result = N/A stored in D07_NotApplicableMessage Else User input numeric value  InclusiveRange ( 0.00, 1.00); Note stored result is fraction and display value is PRODUCT (result, 100) to display percent; If result GTE B04_EfficiencyMinimumValueHSPF2 result complies Else flag it as a non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="D07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B04_NotApplicableMessage == N/A result = N/A stored in D04_NotApplicableMessage Else User input numeric value  InclusiveRange ( 0.00, 1.00); Note stored result is fraction and display value is PRODUCT (result, 100) to display percent.   If result GTE B04 EfficiencyMinimumValue  of same type result complies Else flag it as a non-compliant and do not let registration proceed.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="D08_HeatingUnitManufacturer" type="comp:HeatingUnitManufacturer">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating Unit Manufacturer</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D09_HeatingUnitModelNumber" type="comp:HeatingUnitModelNumber">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating Unit Model Number</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D10_HeatingUnitSerialNumber" type="comp:HeatingUnitSerialNumber">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating Unit Serial Number</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="D11_HeatingEquipmentRatedCapacity" type="hvac:HeatingEquipmentRatedCapacity">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Rated Heating Capacity, Output (Btu/h)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input numeric, xxxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="D11a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Cooling System Outdoor Condensing Unit or Package Unit Equipment Information (not heat pumps)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
This Section is applicable only if  one or more systems in section C has  C05_ResidentialCoolingSystemType
!= NoCooling And  != CentralLargePackagedHP, CentralPackagedHP, CentralSplitHP,  DuctlessSplitHP (display term Ductless mini-split HP), DuctedMiniSplitHP, AirToWaterHeatPump, GroundSourceHeatPump, DuctedMultiSplitHP, DuctlessMultiSplitHP,  DuctedDuctlessMultiSplitHP, DuctlessVRF_HP, SmallDuctHighVelocityHP, HydronicHP, HydronicHP_ForcedAir, RoomHP, VCHP_IndoorUnitDucted, VCHP_IndoorUnitDuctless or VCHP_IndoorUnitDuctedAndDuctless, SPVHP, PTHP;    Require one row of data in this table for each of the SC Systems listed in Section C where C05_ResidentialCoolingSystemType satisfies both of these conditions</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableCooling">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="E01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference to one of the ResidentialSpaceConditioningSystemName listed in section C</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="E02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C02</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="E03_EfficiencyType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Cooling Efficiency Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">As default result = B06_EfficiencyType.  Allow user to override the default and pick from list: EER, EER2, EERSEER, EER2SEER2, CEER;  Flag non-default values and report in project status notes field; a revised parent CC may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:EfficiencyType">
                                             
                                             
                                             <xs:enumeration value="CEER"/>
                                             
                                             
                                             <xs:enumeration value="EER"/>
                                             
                                             
                                             <xs:enumeration value="EER2"/>
                                             
                                             
                                             <xs:enumeration value="EERSEER"/>
                                             
                                             
                                             <xs:enumeration value="EER2SEER2"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E04_EfficiencyInstalledValueSEER" type="hvac:EfficiencyInstalledValueSEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input SEER numeric xx.x  stored in  EfficiencyInstalledValueSEER.   Check value: 
If B07_EfficiencyMinimumValueSEER IsPresent Then
If result  GTE B07_EfficiencyMinimumValueSEER, result complies
Else result does not comply
End If
Else If B07_NotApplicableMessage IsPresent And  If E03_EfficiencyType == SEER or EERSEER   result must be GTE 14 to comply;  
Else result does not comply
End If
Flag non-compliant values and do not let registration proceed if not in compliance.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04_EfficiencySEER2" type="hvac:EfficiencySEER2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input SEER2 numeric xx.x  stored in  EfficiencySEER2.   Check value: 
If B07_EfficiencyMinimumValueSEER2 IsPresent Then If result  GTE B07_EfficiencyMinimumValueSEER2, result complies Else result does not comply End If
Else If B07_NotApplicableMessage IsPresent And  If E03_EfficiencyType == SEER2  or EER2SEER2  result must be GTE 14.3
Elseif E03 = CEER, then value = N/A to comply;  Else result does not comply End If
Flag non-compliant values and do not let registration proceed if not in compliance.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If E03_EfficiencyType == CEER EER Or EER2  result = NA</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E04b_EfficiencyInstalledValueEER" type="hvac:EfficiencyInstalledValueEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input EER numeric xx.x  stored in  EfficiencyInstalledValueEER.   Check value: 
If B07b_EfficiencyMinimumValueEER IsPresent Then
If result  GTE B07b_EfficiencyMinimumValueEER, result complies
Else result does not comply
End If
Else If B07b_NotApplicableMessage IsPresent And  If E03_EfficiencyType == EER or EERSEER   result must be GTE 11.7 to comply;  
Else result does not comply
End If
  Flag non-compliant values and do not let registration proceed if not in compliance.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04b_EfficiencyEER2" type="hvac:EfficiencyEER2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input EER2 numeric xx.x  stored in  EfficiencyEER2.   Check value: 
If B07b_EfficiencyMinimumValueEER2 IsPresent Then If result  GTE B07b_EfficiencyMinimumValueEER2, result complies Else result does not comply End If
Else If B07b_NotApplicableMessage IsPresent And  If E03_EfficiencyType == EER2 or EER2SEER2 result must be GTE 11.2 to comply;  Else result does not comply  End If
Flag non-compliant values and do not let registration proceed if not in compliance.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E04b_EfficiencyInstalledValueCEER" type="hvac:EfficiencyInstalledValueCEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value EER/EER2/CEER</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input CEER numeric xx.x  stored in  EfficiencyInstalledValueCEER.   Check value: If  result  GTE B07_EfficiencyMinimumValueCEER, result complies;  Flag non-compliant values and do not let registration proceed if not in compliance.</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E05_CondenserManufacturer" type="comp:CondenserManufacturer">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Condenser or Package Unit Manufacturer</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="E05_PackageUnitManufacturer" type="comp:PackageUnitManufacturer">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Condenser or Package Unit Manufacturer</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="E06_CondenserModelNumber" type="comp:CondenserModelNumber">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Condenser or Package Unit Model Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
