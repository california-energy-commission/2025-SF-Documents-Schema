<?xml version="1.0" ?>
<xs:schema xmlns:ns1="http://www.lmonte.com/besm/d" xmlns:ns2="http://www.lmonte.com/besm/dtyp" xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF2RMCH01cE" version="2025.0.000">
   
   
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   
   
   <xs:element name="ComplianceDocumentPackage">
      
      
      <xs:complexType>
         
         
         <xs:sequence>
            
            
            <xs:element minOccurs="0" name="DocID">
               
               
               <xs:complexType>
                  
                  
                  <xs:attribute fixed="CF2RMCH01cE" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                  
                  <xs:attribute fixed="CERTIFICATE OF INSTALLATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                  
                  <xs:attribute fixed="Space Conditioning Systems, Ducts, and Fans" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
                  
                  <xs:attribute fixed="MCH01c Prescriptive Newly Constructed Buildings" name="docVariantSubtitle" type="comp:ComplianceDocumentVariantSubtitle"/>
                  
                  
                  <xs:attribute fixed="c" name="docVariantLetter" type="comp:ComplianceDocumentVariant"/>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Payload" type="comp:Payload"/>
            
            
            <xs:element name="DocumentData">
               
               
               <xs:complexType>
                  
                  
                  <xs:sequence>
                     
                     
                     <xs:element name="Header" type="comp:HeaderHERS"/>
                     
                     
                     <xs:element ref="cF2RMCH01cE"/>
                     
                     
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                     
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF2R_E"/>
                     
                     
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                  
                  </xs:sequence>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Report" type="xsd:base64Binary"/>
            
         
         </xs:sequence>
         
         
         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF2RMCH01cE" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF2RMCH01cE">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Space Conditioning Systems, Ducts, and Fans - MCH01c Prescriptive Newly Constructed Buildings</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">General Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="A01_DwellingUnitName" type="com:DwellingUnitName">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Dwelling Unit Name</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference text from parent CC</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A02_ClimateZone" type="com:ClimateZone">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Climate Zone</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference text from parent CC</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A03_DwellingUnitConditionedFloorArea" type="com:DwellingUnitConditionedFloorArea">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Dwelling Unit Total  Conditioned Floor Area (ft
                           <ns1:sup>2</ns1:sup>
                           )
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Value is numeric: xxxxx  
If parent  CC is CF1R-PRF, then 
If project scope = Newly Constructed (Addition Alone) Then 
If CF1R-PRF B02_BuildingAdditionalConditionedFloorArea == Adu03_BuildingAdditionalConditionedFloorArea
result = Adu03_BuildingAdditionalConditionedFloorArea
Else prompt user to enter a value equal to dwelling unit existing CFA + addition CFA
End If 
Else reference the value from CF1R PRF 
End If        
 
Else If parent  CC is CF1R-NCB-01, then 
If project scope =  AdditionGT1000 then 
prompt user to enter a value equal to dwelling unit existing CFA + addition CFA, 
Else If project scope = NewBuildingConstruction, then 
If ResidentialLowriseBuildingType = SingleFamily,   
reference value from CF1R-NCB field A10, 
End If
End If
 
Else If parent  CC  is CF1R-ADD-01, then 
If ResidentialLowriseBuildingType = SingleFamily 
reference value from field A08 from the CF1R-ALT-02 that is required for the dwelling unit according to CF1R-ADD-01 Section J,  
End If
 
Else If parent  CC is CF1R-ALT-01, then 
If ResidentialLowriseBuildingType = SingleFamily,  
reference value from field A08 from the CF1R-ALT-02 that is required for the dwelling unit according to CF1R-ALT-01 Section G 
End If
Else If parent  CC is CF1R-ALT-02, then reference value from CF1R-ALT-02 field A08.  
End If   
 
 Allow user to override default and input value; flag overridden values and report in project status notes field</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A04_ResidentialDwellingUnitSpaceConditioningCount" type="hvac:ResidentialDwellingUnitSpaceConditioningCount">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Number of Space Conditioning Systems in this dwelling unit.</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If parent CC is CF1R-ALT-02, use value from parent Section A A10 as default Or allow user to override default value and flag non-default values and report in project status notes field
Else 
user input the integer value xx
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A05_ComplianceMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Certificate of Compliance Type</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference document type property from CF1R; For choice Performance display text: performance (CF1R-PRF); for choice PrescriptiveAdditions display text:  prescriptive additions (CF1R-ADD)    For choice PrescriptiveAlterations display text: prescriptive alterations (CF1R-ALT);   For choice PrescriptiveNewConstruction display text: prescriptive newly constructed (CF1R-NCB)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="comp:ComplianceMethod">
                           
                           
                           <xs:enumeration value="Performance"/>
                           
                           
                           <xs:enumeration value="PrescriptiveAdditions"/>
                           
                           
                           <xs:enumeration value="PrescriptiveAlterations"/>
                           
                           
                           <xs:enumeration value="PrescriptiveNewConstruction"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A06_HvacLoadCalculationMethod" type="comp:HvacLoadCalculationMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Method Used to Calculate HVAC Loads (See Section 150.0(h))</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input; Choices to display: ASHRAE Handbook;  SMACNA Residential Comfort System Installation Standards Manual, ACCA Manual J, Not applicable - equipment change out, like-for-like, 
and Exception 1 to Section 150.0(h)1: Block loads for system sizing for additions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element maxOccurs="unbounded" name="A07_HvacOutdoorDesignCondSource" type="comp:HvacOutdoorDesignCondSource">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Outdoor Design Condition Source (See Section 150.0((h)2</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User select all that apply; Reference Joint Appendix JA2; ASHRAE Handbook; ACCA Manual J </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A08_DesignCoolingOutdoorTemp" type="hvac:DesignCoolingOutdoorTemp">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Cooling Outdoor Design Temperature Selected (F)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User enters temperature in degrees F</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A09_DesignHeatingOutdoorTemp" type="hvac:DesignHeatingOutdoorTemp">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Heating Outdoor Design Temperature Selected (F)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User enters temperature in degrees F</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A10_DesignSensibleCoolingLoad" type="hvac:DesignSensibleCoolingLoad">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Sensible Cooling Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = N/A stored in the  NotAppplicableMessage;  Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A10_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Sensible Cooling Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = N/A stored in the  NotAppplicableMessage; Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A11_DwellingUnitDesignHeatingLoad" type="hvac:DwellingUnitDesignHeatingLoad">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Heating Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = N/A stored in the  NotAppplicableMessage; Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A11_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Calculated Dwelling Unit Heating Load (Btu/h)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If   A06_HvacLoadCalculationMethod == NotApplicableEquipmentChangeout Then result = N/A stored in the  NotAppplicableMessage; Else User entry integer xxxxx</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:element name="A12_BedroomCount" type="com:BedroomCount">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Dwelling Unit Number of Bedrooms</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: integer xx;  If A05_ComplianceMethod == Performance Then 
If CF1R-PRF B05_BedroomsAdditionCount == Adu06_BedroomsAdditionCount
result = Adu06_BedroomsAdditionCount
Else use as default the value referenced from the parent CC Or allow user to override  default and input a new value, constrained to be GTE to default value from parent CC, flag non-default values and report of change in the project status notes field.  
End If
Else If ComplianceMethod != Performance  then user inputs integer value.
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="A12After">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Variant MCH-01c</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">MCH-01c - Space Conditioning Systems Ducts and Fans - Prescriptive, Newly Constructed Buildings</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: 
If A05_ComplianceMethod  == Performance, 
If CF1R-PRF project scope == Addition and/or Alteration Or Newly Constructed (Addition Alone) then display doc variation MCH-01d ;   
Else If  CF1R-PRF project scope == Newly Constructed display doc variation  MCH-01a 
End If     
Else If A05_ComplianceMethod == PrescriptiveAlterations, Or  PrescriptiveAddiitions, then display doc variation MCH-01b;  
Else If A05_ComplianceMethod  == PrescriptiveNewConstruction  then display doc variation MCH-01c  
End If</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="AEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           Notes: 
                           <ns1:l t="#">
                              <ns1:list>The outdoor design temperatures for heating shall be less than or equal to 99.0% Heating Dry Bulb or the Heating Winter Median of Extremes values </ns1:list>
                              

                              <ns1:list>The outdoor design temperatures for cooling shall be less than or equal to 1.0% Cooling Dry Bulb and Mean Coincident Wet Bulb values. </ns1:list>
                           </ns1:l>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Design Space Conditioning (SC) System Component Specifications from CF1R</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
Require one row of data in this table for each of the SC Systems identified on the parent CC report that is applicable to this dwelling unit.  [Note: use section K on CF1R-NCB-01]  Do not allow user to overwrite these referenced data</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="B_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">This table reports the space conditioning system features that were specified on the registered CF1R compliance document for this project.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableDesignComponents">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="B01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/Name from  parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto filled text: referenced from  parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B02_ResidentialHeatingSystemType" type="hvac:ResidentialHeatingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Heating System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto filled text: referenced from  parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B03_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B02_ResidentialHeatingSystemType == Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  Or HydronicHP_ForcedAir   result = NotApplicable stored in B03_NotApplicableMessage Else auto fill value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="AFUE"/>
                                                
                                                
                                                <xs:enumeration value="COP"/>
                                                
                                                
                                                <xs:enumeration value="HSPF"/>
                                                
                                                
                                                <xs:enumeration value="HSPF2"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B03_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B02_ResidentialHeatingSystemType == Hydronic, CombinedHydronic, HydronicForcedAir, CombinedHydronicForcedAir, HydronicHP,  Or HydronicHP_ForcedAir   result = NotApplicable stored in B03_NotApplicableMessage Else auto fill value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B04_EfficiencyMinimumValueAFUE" type="hvac:EfficiencyMinimumValueAFUE">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplicableMessage IsPresent   
result = NotApplicable stored in B04_NotApplicableMessage
Else  auto fill AFUE value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B04_EfficiencyMinimumValueCOP" type="hvac:EfficiencyMinimumValueCOP">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplicableMessage IsPresent   
result = NotApplicable stored in B04_NotApplicableMessage
 Else  auto fill COP value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B04_EfficiencyMinimumValueHSPF" type="hvac:EfficiencyMinimumValueHSPF">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplicableMessage IsPresent   
result = NotApplicable stored in B04_NotApplicableMessage
 Else  auto fill HSPF value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B04_EfficiencyMinimumValueHSPF2" type="hvac:EfficiencyMinimumValueHSPF2">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplicableMessage IsPresent   
result = NotApplicable stored in B04_NotApplicableMessage
Else  auto fill HSPF2 value referenced from parent CC for this system name</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Heating Efficiency Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If B03_NotApplicableMessage IsPresent   
result = NotApplicable stored in B04_NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="B05_ResidentialCoolingSystemType" type="hvac:ResidentialCoolingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Cooling System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto fill text referenced from parent CC for this system name</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B06_EfficiencyType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Auto fill text referenced fromparent CC for this system name   Else If data is not available on the parent CC Or B05_ResidentialCoolingSysstemType == NoCooling result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                          
                                          <xs:simpleType>
                                             
                                             
                                             <xs:restriction base="hvac:EfficiencyType">
                                                
                                                
                                                <xs:enumeration value="CEER"/>
                                                
                                                
                                                <xs:enumeration value="EER"/>
                                                
                                                
                                                <xs:enumeration value="EER2"/>
                                                
                                                
                                                <xs:enumeration value="EER2SEER2"/>
                                                
                                                
                                                <xs:enumeration value="EERSEER"/>
                                                
                                                
                                                <xs:enumeration value="SEER"/>
                                                
                                                
                                                <xs:enumeration value="SEER2"/>
                                                
                                             
                                             </xs:restriction>
                                             
                                          
                                          </xs:simpleType>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Auto fill text referenced from parent CC for this system name   Else If data is not available on the parent CC Or B05_ResidentialCoolingSysstemType == NoCooling result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B07_EfficiencyMinimumValueSEER" type="hvac:EfficiencyMinimumValueSEER">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Cooling Efficiency Value SEER/SEER2</xs:documentation>
                                             
                                             
