                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="F09_IndoorCoilSerialNumber" type="comp:IndoorCoilSerialNumber">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Serial Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="F09_FanCoilUnitSerialNumber" type="comp:FanCoilUnitSerialNumber">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Serial Number</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">User input alphanumeric string max length 50 characters</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="F10_IndoorUnitNominalCoolingCapacity" type="hvac:IndoorUnitNominalCoolingCapacity">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Nominal Cooling Capacity (tons)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C11_IndoorUnitsCount  GT 1 And  C04_ResidentialHeatingSystemType  Or C05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless  And F05_IndoorUnitDucts == DuctsGT10Ft Or DuctsLTE10Ft , user input numeric;  Else result = N/A stored in NotApplicableMessage display term Value not required</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="F10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Indoor Unit Nominal Cooling Capacity (tons)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If C11_IndoorUnitsCount  GT 1 And  C04_ResidentialHeatingSystemType  Or C05_ResidentialCoolingSystemType == VCHP_IndoorUnitDucted Or VCHP_IndoorUnitDuctedAndDuctless  And F05_IndoorUnitDucts == DuctsGT10Ft Or DuctsLTE10Ft , user input numeric;  Else result = N/A stored in NotApplicableMessage display term Value not required</xs:documentation>
                                             
                                             
                                             <xs:appinfo source="displayterm">
                                                
                                                
                                                <ns2:displayterm value="N/A">Value not required</ns2:displayterm>
                                                
                                             
                                             </xs:appinfo>
                                             
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
