         <xs:element maxOccurs="1" minOccurs="0" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Duct System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the parent CF1R Certificate of Compliance (CC)
 
This Section is applicable only if  one or more systems in section C has  value for C06_DuctSystemType != Ductless.      Require one row in this table for each space conditioning system in section D field D02 that meets BOTH of the following two conditions: C04_ResidentialHeatingSystemType == GasPackagedFurnace And C06_DuctSystemType == DuctedSystem.  Also require one row in this table for each indoor unit in section D field D03 that meets BOTH of the following two conditions: C04_ResidentialHeatingSystemType == GasPackagedFurnace  And value in D03 != F03.  Also require one row in this table for each space conditioning system in section E field E02 that meets ALL of the following three conditions: C05_ResidentialCoolingSystemType = CentralPackagedAC Or CentralLargePackagedAC And D02 != E02 (the same packaged unit is not already listed in section D) And C06_DuctSystemType == DuctedSystem.  Also require one row in this table for each space conditioning system in Section G field G02 that meets ALL of the following three conditions: C05_ResidentialCoolingSystemType = CentralPackagedHP Or CentralLargePackagedHP And D02 != G02 (the same packaged unit is not already listed in section E) And C06_DuctSystemType == DuctedSystem.  Also require one row of data to be entered for each indoor unit in F03_IndoorUnitName where F05_IndoorUnitDucts == DuctsGT10Ft Or  DuctsLTE10Ft;</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDuctSystem">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="I01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Identification or Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto fill from C01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Location or Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto fill from C02_ResidentialHvacSystemAreaServed for this system</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C04_ResidentialHeatingSystemType ==GasPackagedFurnace result = C02_ResidentialHvacSystemAreaServed; Else if C04_ResidentialHeatingSystemType Or C05_ResidentialCoolingSystemType == CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP result = C02_ResidentialHvacSystemAreaServed;   Else reference values in D03_IndoorUnitName and F03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I04_SupplyDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Supply Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from C07_DuctLocation as default.  Allow user to overwrite from this list: ConditionedSpace, ConditionedSpaceExcept12ft,  Outdoors, UnconditionedAttic, UnconditionedCrawlSpace, UnconditionedGarage. DuctsInMultipleLocations;  Flag non-default values and report in project status notes field.  a revised parent CC  may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:SupplyDuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                                                                         
                                             
                                             <xs:enumeration value="ControlledVentilationCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="DuctsInMultipleLocations"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedBasement"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                                                                          
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I05_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Supply Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User picks from: R-0.0, R-2.1, R-4.2, R-6, R-8, R-10, R-12.  Check: If result GTE I14_DuctRValueLimit result complies with following exception, If I08_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned then R0.0, R2.1 and R-4.2 comply; Else flag noncompliant value and do not allow registration to proceed.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I06_ReturnDuctLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Return Duct Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from C07_DuctLocation as default.  Allow user to overwrite from this list: ConditionedSpace, ConditionedSpaceExcept12ft,  Outdoors, UnconditionedAttic, UnconditionedCrawlSpace, UnconditionedGarage, DuctsInMultipleLocations;.  Flag non-default values and report in project status notes field.  a revised parent CC  may be required.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ReturnDuctLocation">
                                             
                                             
                                             <xs:enumeration value="ConditionedSpace"/>
                                                                                         
                                             
                                             <xs:enumeration value="ControlledVentilationCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="DuctsInMultipleLocations"/>
                                             
                                             
                                             <xs:enumeration value="Outdoors"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedAttic"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedBasement"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedCrawlSpace"/>
                                             
                                             
                                             <xs:enumeration value="UnconditionedGarage"/>
                                                                                              
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I07_DuctRValue">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Return Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User picks from: R-0.0, R-2.1, R-4.2, R-6, R-8, R-10, R-12.  Check: If result GTE I14_DuctRValueLimit result complies with following exception, If I08_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned then R0.0, R2.1 and R-4.2 comply;Else flag noncompliant value and do not allow registration to proceed.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValue">
                                             
                                             
                                             <xs:enumeration value="R0.0"/>
                                             
                                             
                                             <xs:enumeration value="R10"/>
                                             
                                             
                                             <xs:enumeration value="R12"/>
                                             
                                             
                                             <xs:enumeration value="R2.1"/>
                                             
                                             
                                             <xs:enumeration value="R4.2"/>
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I08_DuctMinimumRValueExceptions">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Exception from Min R-Value for Ducts In Conditioned Space</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">default result = NoException; Allow user to override and select one from list; 
UninsulatedInDirectConditioning display term Portions of ducts uninsulated  or less than R-6 in conditioned space
 
ALSO 
If I04_SupplyDuctLocation And I06_ReturnDuctLocation == ConditionedSpace 
allow user to select  RValueLT6EntirelyInConditioned   display term Ducts uninsulated or less than R-6 entirely in Conditioned Space
 
End if</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctMinimumRValueExceptions">
                                             
                                             
                                             <xs:enumeration value="NoException"/>
                                             
                                             
                                             <xs:enumeration value="RValueLT6EntirelyInConditioned"/>
                                             
                                             
                                             <xs:enumeration value="UninsulatedInDirectConditioning"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I09_DuctFilterGrilleSizingComplianceMethod">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Method of compliance with Airflow and Fan Efficacy Req's in 150.0(m)13</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If C05_ResidentialCoolingSystemType == NoCooling, then  result = ExemptNoCooling, display text: Exempt - No Cooling,  
Else If  C05_ResidentialCoolingSystemType == EvaporativeDirect,  EvaporativeIndirect, or EvaporativeIndirectDirect,  then  
result = ExemptEvaporativeSystem, display text :Exempt - Evaporative System, 
 
Else If in Section I fields I11_CanRA3_3AirflowProtocolsTestSystem Or  I12_CanFanEfficacyProtocolsTestSystem == false then 
result = ExemptRA3_3Protocols display text: Exempt - Approved Protocols N/A;    
 
Else If C09_ResidentialCoolingZoneType  == ZoneControlled, Or D04_DoesUnitProvideCFI_IAQ == true Or F04_DoesUnitProvideCFI_IAQ == true  then 
result = HERS_FanEfficacyAirflowRate display text: ECC Verified Fan Efficacy and Airflow Rate, 
 
Else user selects one from the following values:   HERS_FanEfficacyAirflowRate, display text: ECC Verified Fan Efficacy and Airflow Rate;  and HERS_ReturnDuctDesignTable150, display text:  ECC verified Return Duct Design per Table 150.0   
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:DuctFilterGrilleSizingComplianceMethod">
                                             
                                             
                                             <xs:enumeration value="ExemptEvaporativeSystem"/>
                                             
                                             
                                             <xs:enumeration value="ExemptNoCooling"/>
                                             
                                             
                                             <xs:enumeration value="ExemptRA3_3Protocols"/>
                                             
                                             
                                             <xs:enumeration value="HERS_FanEfficacyAirflowRate"/>
                                             
                                             
                                             <xs:enumeration value="HERS_ReturnDuctDesignTable150"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I10_DuctSystemAirFilterDeviceCount" type="hvac:DuctSystemAirFilterDeviceCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Number of Air Filter Devices on Duct System</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer value which determines number or rows per indoor unit system in next section If the total duct length is GT 10 ft</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I11_CanRA3_3AirflowProtocolsTestSystem" type="comp:CanRA3_3AirflowProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Airflow Protocols be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If system type in C04_ResidentialHeatingSystemType Or C05_ResidentialCoolingSystemType == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = false display term No;
 
Else  If system type in C04_ResidentialHeatingSystemType Or C05_ResidentialCoolingSystemType == CentralSplitAC, CentralSplitHP,   CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP 
result = true display term Yes  
 
Else user selects from list: Yes (Boolean true display text) or No  (Boolean false display text).  
End if
Check: if result == false, report in project status notes field that exemption from mandatory ECC verification of system airflow has been claimed. Enforcement agency confirmation is recommended.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I12_CanFanEfficacyProtocolsTestSystem" type="comp:CanFanEfficacyProtocolsTestSystem">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Can Approved Fan Efficacy Protocol be used to test this System?</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If system type in C04_ResidentialHeatingSystemType Or C05_ResidentialCoolingSystemType == DuctedMultiSplitHP, DuctedDuctlessMultiSplitHP, DuctedMultiSplitAC, DuctedDuctlessMultiSplitAC 
result = CanNotTest display term No;
 
Else If system type in C04_ResidentialHeatingSystemType Or C05_ResidentialCoolingSystemType == CentralSplitAC, CentralSplitHP,   CentralPackagedAC, CentralPackagedHP, CentralLargePackagedAC Or CentralLargePackagedHP 
result = CanTest display term Yes; 
 
Else user selects from list: CanTest display term Yes or CanNotTest display term  No.  
 
Check: if result == CanNotTest report in project status notes field that exemption from mandatory ECC verification of Fan  Efficacy has been claimed. Enforcement agency confirmation is recommended.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I13_IndoorUnitDucts" type="hvac:IndoorUnitDucts">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Total Duct Length</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If applicable value in D05_IndoorUnitDucts or F05_IndoorUnitDucts == DuctsGT10Ft result = DuctsGT10Ft; Else If applicable value in D05_IndoorUnitDucts or F05_IndoorUnitDucts == DuctsLTE10Ft  result = DuctsLTE10Ft;   Else user selects from list: DuctsLTE10Ft, DuctsGT10Ft</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="I14_DuctRValueLimit">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Required New Duct R-Value</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If B10_NotApplicableMessage != N/A reference B10_DuctRValue;  Else If A02_ClimateZone == 3, 5, 6 or 7 result = R6; Else If A02_ClimateZone == 1, 2, 4 or InRange (8,16) result = R8</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctRValueLimit">
                                             
                                             
                                             <xs:enumeration value="R6"/>
                                             
                                             
                                             <xs:enumeration value="R8"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I14a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_J">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Air Filter Device Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only if  one or more systems in section C has  value for C06 != Ductless Or If at least one ducted system in section I has I13 == DuctsGT10Ft.  Require one row of data for each Air filter device included in the count I10_DuctSystemAirFilterDeviceCount. for each ducted system in section I has I13 == DuctsGT10Ft.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="J_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory requirements for air filter devices are specified Section 150.0(m)12.  The installer shall place a sticker in or near each filter grille that displays the  design airflow rate for that filter grille/rack and the maximum allowed clean filter pressure drop at the design airflow rate.  This will inform the occupant of the airflow vs pressure drop performance required for replacement air filters.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableAirFilterDevice">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="J01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Identification or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-fill from C01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Location or Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-fill from C02_ResidentialHvacSystemAreaServed for this system</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from  I03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J04_DuctSystemAirFilterDeviceName" type="hvac:DuctSystemAirFilterDeviceName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Device Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input text, maximum 20 characters</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J05_DuctSystemAirFilterDeviceType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Rack Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user select from list:  FilterGrille, Mounted, MountedInline</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:DuctSystemAirFilterDeviceType">
                                             
                                             
                                             <xs:enumeration value="FilterGrille"/>
                                             
                                             
                                             <xs:enumeration value="Mounted"/>
                                             
                                             
                                             <xs:enumeration value="MountedInline"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J06_AirFilterDeviceAirflowRate" type="hvac:AirFilterDeviceAirflowRate">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Airflow Rate for Air Filter Device (cfm)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input numeric xxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J07_AirFilterDeviceDepth" type="hvac:AirFilterDeviceDepth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Depth (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">user input integer GTE 1</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J08_AirFilterDeviceLength" type="hvac:AirFilterDeviceLength">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Length (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J09_AirFilterDeviceWidth" type="hvac:AirFilterDeviceWidth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Air Filter Nominal Width (inch)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input integer GTE 1.00</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J10_AirFilterDeviceFaceArea" type="hvac:AirFilterDeviceFaceArea">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             Air Filter Calculated Nominal Face Area (inch
                                             <ns1:sup>2</ns1:sup>
                                             )
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: PRODUCT (J08_AirFilterDeviceLength, J09_AirFilterDeviceWidth )</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="J11_AirFilterDeviceFaceAreaRequiredMin" type="hvac:AirFilterDeviceFaceAreaRequiredMin">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If J07_AirFilterDeviceDepth == 1 result = PRODUCT(J06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in J11_AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="J11_AirFilterDeviceFaceAreaMessage" type="comp:AirFilterDeviceFaceAreaMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">
                                                Air Filter Required Minimum Face Area (inch
                                                <ns1:sup>2</ns1:sup>
                                                )
                                             </xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Calculated field; If J07_AirFilterDeviceDepth == 1 result = PRODUCT(J06_AirFilterDeviceAirflowRate / 150, 144) Else result = SpecifiedByDesigner stored in J11_AirFilterDeviceFaceAreaMessage display term Specified by System Designer</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="J12_AirFilterDeviceFaceAreaCompliance" type="comp:AirFilterDeviceFaceAreaCompliance">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Face Area  Compliance</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If J11_AirFilterDeviceFaceAreaMessage == SpecifiedByDesigner result = SpecifiedByDesigner Else if J10_AirFilterDeviceFaceArea GTE  J11_AirFilterDeviceFaceAreaRequiredMin result = FaceAreaComplies display term Complies else result = FaceAreaDoesNotComply display term Does Not Comply</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="J13_DuctSystemAirFilterDevicePressureDrop" type="hvac:DuctSystemAirFilterDevicePressureDrop">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Design Allowable Pressure Drop for Air Filter Device (inch W.C.)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If J07__AirFilterDeviceDepth == 1  result = 0.1 Else user input numeric x.xx in  InclusiveRange(0.01, 1.5)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="J13a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_K">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This Section is applicable only if  Section J is applicable</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="KBeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Mandatory Air Filter Device Requirements can be found in Section 150.0(m)12A-E.  Some mandatory requirements may apply in addition to those listed below.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Recirculated and outdoor air filtering</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All recirculated air and all outdoor air (including make up air) supplied to the occupiable space is filtered before passing through the system's thermal conditioning components.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Filter Device Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The space conditioning system shall be designed to accommodate the clean-filter pressure drop imposed by the system air filter device(s). The design airflow rate and maximum allowable clean-filter pressure drop at the design airflow rate applicable to each air filter shall be determined by the system designer.  The system installer shall affix a sticker/label to each system air filter grille/rack locations that discloses the filter's design airflow rate and the filter's maximum allowable clean-filter pressure drop at the design airflow rate.  The sticker/labels shall be permanently affixed to the air filter grille/rack, readily legible, and visible to a person replacing the air filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter access and regular service</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All system air filter devices shall be located and installed in such a manner as to allow access and regular service by the system owner.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media efficiency</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The system shall be provided with air filter's having a designated efficiency equal to or greater than MERV 13 when tested in accordance with ASHRAE Standard 52.2, or a particle size efficiency rating equal to or greater than 50% in the 0.30 to1.0 
                           <ns1:micron/>
                           m range and equal to or greater than 85 percent in the 1.0 - 3.0 
                           <ns1:micron/>
                           m range when tested in accordance with AHRI Standard 680.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air filter media manufacturer label</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The system shall be provided with air filters that have been labeled by the manufacturer to disclose efficiency and pressure drop ratings that conform to the efficiency and pressure drop requirements for the air filter grilles/racks..</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="K06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Prevent air bypassing filter</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Filter racks or grilles shall use gaskets, sealing, or other means to close gaps around inserted filters and prevent air from bypassing the filter.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="KEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="0" name="Section_L">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">ECC Verification Requirements for Duct Systems</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required if at least one system in section C has C06_DuctSystemType != Ductless.  Require one row or data for each of the indoor units listed in section I I03</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSDucts">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="L01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto filled from Section I  I01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto filled from Section I  I02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L03_IndoorUnitName" type="hvac:IndoorUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Indoor Unit Name or  Description of  Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference applicable values from section I I03_IndoorUnitName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L04_DuctLeakageTestRequired" type="comp:DuctLeakageTestRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH20   
                                             <ns1:line4/>
                                             Duct Leakage Test
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: result = true. display term Yes</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L05_DuctsInConditionedSpaceVerification" type="comp:DuctsInConditionedSpaceVerification">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH21  
                                             <ns1:line3/>
                                             Duct  Location Verification
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If I08_DuctMinimumRValueExceptions == RValueLT6EntirelyInConditioned  result = true; 
Else result = false.  
End If
Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L06_AHU_FanEfficacyVerificationRequired" type="comp:AHU_FanEfficacyVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH22  
                                             <ns1:line3/>
                                             AHU Fan Efficacy (W per cfm)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If section  I12_CanFanEfficacyProtocolsTestSystem == false result = false; Else If  I09_DuctFilterGrilleSizingComplianceMethod == HERS_FanEfficacyAirflowRate then result = true; Else If C05_ResidentialCoolingSystemType == NoCooling  And D04_DoesUnitProvideCFI_IAQ Or F06_DoesUnitProvideCFI_IAQ == true, then result = true;  Else result = false.  Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L07_AHU_AirflowRateVerificationRequired" type="comp:AHU_AirflowRateVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH23  
                                             <ns1:line3/>
                                             AHU Airflow Rate (cfm per ton)
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If in Section I field I11_CanRA3_3AirflowProtocolsTestSystem == false result = false; Else If  I09_DuctFilterGrilleSizingComplianceMethod == HERS_FanEfficacyAirflowRate then result = true;  Else If M03_RefrigerantChargeVerificationRequired == true And  L08_ReturnDuctDesignVerificationRequired == false then result = true;   Else If C05_ResidentialCoolingSystemType == NoCooling  And D04_DoesUnitProvideCFI_IAQ Or F06_DoesUnitProvideCFI_IAQ == true, then result = true;  Else result = false.  Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="L08_ReturnDuctDesignVerificationRequired" type="comp:ReturnDuctDesignVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH28  
                                             <ns1:line2/>
                                             Return Duct Design - Table 150.0-B or C
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If I09_DuctFilterGrilleSizingComplianceMethod ==  HERS_ReturnDuctDesignTable150BC then result = true, else result = false.  Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="L08a_SectionComments" type="comp:SectionComments">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Notes</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_M">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">ECC Verification Requirements For Space Conditioning Equipment</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">Require one row of data for each SC System listed in E01_ResidentialSpaceConditioningSystemName and H01_ResidentialSpaceConditioningSystemName</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableHERSEquipment">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="M01_ResidentialSpaceConditioningSystemName" type="hvac:ResidentialSpaceConditioningSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System ID/ Name from parent CC</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C01_ResidentialSpaceConditioningSystemName</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M02_ResidentialHvacSystemAreaServed" type="hvac:ResidentialHvacSystemAreaServed">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">SC System Description of Area Served</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled from C02_ResidentialHvacSystemAreaServed</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="M03_RefrigerantChargeVerificationRequired" type="comp:RefrigerantChargeVerificationRequired">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">
                                             MCH25  
                                             <ns1:line4/>
                                             Refrigerant Charge
                                          </xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field:  If A02_ClimateZone == 2 Or value in InclusiveRange ( 8,15) Then result = true; Else result = false.   Display Yes and No to represent Boolean result values true and false.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
