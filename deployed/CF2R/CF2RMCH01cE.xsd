If E03_EfficiencyType == EER  or EERSEER Then 
If result GTE 11.7 result complies
Else result does not comply
End If
End If
Else If B07_EfficiencyMinimumValueEER IsPresent 
If result  GTE B07_EfficiencyMinimumValueEER, 
result complies
Else result does not comply
End If
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="H08b_EfficiencyEER2" type="hvac:EfficiencyEER2">
                                          
                                          
