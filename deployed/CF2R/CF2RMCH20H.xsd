                  <xsd:element name="Bsmt12_DuctLeakageTestStatusUsingSmokeTest" type="comp:DuctLeakageTestStatusUsingSmokeTest">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Compliance Statement:</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">If  Bsmt11_DuctLeakageTestActual LTE Bsmt10_DuctLeakageAllowed result = PassAllowableDuctLeakageRate, display term:    System Passes - System Complies With Allowable Duct Leakage Rate Criterion.   Else result = PassUsingSmokeTestRes   display term: System Passes Using Smoke Test On Altered System In Existing Building... (complete display term in base definition)</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element minOccurs="0" name="Section_C">
            <xsd:annotation>
               <xsd:documentation source="FieldText">Ducts Located in Garage Spaces</xsd:documentation>
               <xsd:documentation source="CalculationsAndRules">This section is required if A08_AreDuctsInGarage== true.</xsd:documentation>
               <xsd:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element fixed="TotalLeakage" name="C01_LeakageTestMethod" type="comp:LeakageTestMethod">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Duct Leakage Test Method</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Auto-filled value = TotalLeakage (this is the only method allowed)</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C02_DuctSystemLeakageFactor" type="comp:DuctSystemLeakageFactor">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Leakage Factor</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Auto-filled value = 0.06</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C03_AirflowMethod" type="comp:AirflowMethod">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Air Handling Unit Airflow (AHU Airflow) Determination Method</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Auto-filled from  Section B1/2/3/4/5 field 01 AirflowMethod</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:choice maxOccurs="1">
                     <xsd:element name="C04_AHU_AirflowMeasured" type="comp:AHU_AirflowMeasured">
                        <xsd:annotation>
                           <xsd:documentation source="FieldText">Measured AHU Airflow (cfm)</xsd:documentation>
                           <xsd:documentation source="CalculationsAndRules">Auto-filled from AHU_AirflowMeasured in Section B1/3/4/5 field 06 or Section B2 field 05</xsd:documentation>
                        </xsd:annotation>
                     </xsd:element>
                     <xsd:element name="C04_NotApplicableMessage" type="comp:NotApplicableMessage">
                        <xsd:annotation>
                           <xsd:documentation source="FieldText">Measured AHU Airflow (cfm)</xsd:documentation>
                           <xsd:documentation source="CalculationsAndRules"> Auto-filled from NotApplicableMessage in Section B1/3/4/5 field 06 or Section B2 field 05</xsd:documentation>
                        </xsd:annotation>
                     </xsd:element>
                  </xsd:choice>
                  <xsd:element name="C05_DuctLeakageAllowed" type="comp:DuctLeakageAllowed">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Calculated Target Allowable Duct Leakage (cfm)</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Calculated field: Switch (Section B1/3/4/5 field 01_AirflowMethod) 
case DefaultAirflowMethod: result = PRODUCT (B05_HvacSystemConditionedFloorArea, 0.5, 0.06); 
case CoolingSystemMethod: result = PRODUCT (B02_CondenserNominalCoolingCapacity, 400, 0.06);  
case HeatingSystemMethod: result = PRODUCT (B04_HvacSystemHeatingCapacity, 21.7,  0.06);  
case MeasuredAirflowMethod: result = PRODUCT (AHU_AirflowMeasured, 0.06); 
case IndoorUnitMethod: result = PRODUCT (B03_IndoorUnitNominalCoolingCapacity, 350, 0.06).
End Switch</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C06_DuctLeakageTestActual" type="comp:DuctLeakageTestActual">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Actual Duct Leakage Rate from Leakage Test Measurement (cfm)</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">Auto-filled from DuctLeakageTestActual in Section B1/3/4/5 field 11</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element name="C07_DoesGarageDuctLeakageTestPass" type="comp:DoesGarageDuctLeakageTestPass">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Compliance Statement:</xsd:documentation>
                        <xsd:documentation source="CalculationsAndRules">If  C06_DuctLeakageTestActual LTE C05_DuctLeakageAllowed result = true display term Ducts in garage passes - overall system leakage complies  Else result = false display term Ducts in garage passes using smoke test of an altered HVAC system in an existing building <d:l t="*"> <d:list> No visible smoke exits the accessible portions of the ducts in the garage.</d:list></d:l></xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
         <xsd:element minOccurs="0" name="Section_D">
            <xsd:annotation>
               <xsd:documentation source="FieldText">Additional Requirements for Compliance</xsd:documentation>
               <xsd:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xsd:documentation>
            </xsd:annotation>
            <xsd:complexType>
               <xsd:sequence>
                  <xsd:element minOccurs="0" name="D01">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">No Temporary Taping Allowed</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">System was tested in its normal operation condition.  No temporary taping allowed.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D02">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Outside Air (OA) Ducts for Central Fan Integrated (CFI)</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">Outside air (OA) duct connections to the central forced air duct system shall not be sealed/taped off during duct leakage testing. OA ducts used for Central Fan Integrated (CFI) Indoor Air Quality ventilation systems, or Central Fan Ventilation Cooling Systems, that utilize dampers that open only when OA is required and automatically close when OA is not required, may configure the OA damper to the closed position during duct leakage testing.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D03">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Supply and Return Register Boots</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">All supply and return register boots were sealed to the drywall.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D04">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Building Cavities</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">Building cavities were not used as plenums or platform returns in lieu of ducts.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D05">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Cloth Backed Tape</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">If cloth backed tape was used it was covered with Mastic and draw bands.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D06">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">All Connection Points Sealed</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">All connection points between the air handler and the supply and return plenums are completely sealed.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D06After_HeadingForC07toC09">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"><d:b>Visual Inspection at Final Construction Stage (applicable if system was tested at rough-in).</d:b></xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D06After_Note">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText"/>
                        <xsd:documentation source="AdditionalRequirements">After installing the interior finishing wall and verifying that the above rough-in tests was completed, the following procedure must be performed</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D07">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Supply and return registers</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">For all supply and return registers, verify that the spaces between the register boot and the interior finishing wall are properly sealed.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D08">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Rough-in duct leakage test</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">If the house rough-in duct leakage test was conducted without an air handler installed, inspect the connection points between the air handler and the supply and return plenums to verify that the connection points are properly sealed.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D09">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Inspect all joints</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">Inspect all joints to ensure that no cloth backed rubber adhesive duct tape is used.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D10">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Certified Low Leakage Air-Handling Unit</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">For Duct Systems with Low Leakage Air-Handling Unit (LLAHU): The Low Leakage Air-handling Unit Model identified on this compliance document is included in the list of certified Low Leakage Air-Handling Units published on the Energy Commission Website at: http://www.energy.ca.gov/rules-and-regulations/building-energy-efficiency/manufacturer-certification-building-equipment/low</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="D11">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">Smoke Test method</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">If the system complies using the Smoke Test method, the smoke test was conducted in accordance with the requirements of Reference Residential Appendix RA3.1.4.3.6.  Systems that comply using smoke test shall not be included in sample groups for ECC verification compliance.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
                  <xsd:element minOccurs="0" name="DEndNote1">
                     <xsd:annotation>
                        <xsd:documentation source="FieldText">End Note 1</xsd:documentation>
                        <xsd:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xsd:documentation>
                     </xsd:annotation>
                  </xsd:element>
               </xsd:sequence>
            </xsd:complexType>
         </xsd:element>
      </xsd:sequence>
   </xsd:complexType>
   <xsd:element name="cF2RMCH20H" type="CF2RMCH20H">
      <xsd:annotation>
         <xsd:documentation>This element contains all of the data and text required to generate the CF2RMCH20H compliance report.</xsd:documentation>
      </xsd:annotation>
   </xsd:element>
</xsd:schema>
