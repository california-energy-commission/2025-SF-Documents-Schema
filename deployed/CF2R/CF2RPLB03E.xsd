<?xml version="1.0" ?>
<xs:schema xmlns:ns1="http://www.lmonte.com/besm/d" xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF2RPLB03E" version="2025.0.000">
   
   
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   
   
   <xs:element name="ComplianceDocumentPackage">
      
      
      <xs:complexType>
         
         
         <xs:sequence>
            
            
            <xs:element minOccurs="0" name="DocID">
               
               
               <xs:complexType>
                  
                  
                  <xs:attribute fixed="CF2RPLB03E" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                  
                  <xs:attribute fixed="CERTIFICATE OF INSTALLATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                  
                  <xs:attribute fixed="Pool And Spa Heating Systems" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Payload" type="comp:Payload"/>
            
            
            <xs:element name="DocumentData">
               
               
               <xs:complexType>
                  
                  
                  <xs:sequence>
                     
                     
                     <xs:element name="Header" type="comp:HeaderHERS"/>
                     
                     
                     <xs:element ref="cF2RPLB03E"/>
                     
                     
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                     
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF2R_E"/>
                     
                     
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                  
                  </xs:sequence>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Report" type="xsd:base64Binary"/>
            
         
         </xs:sequence>
         
         
         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF2RPLB03E" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF2RPLB03E">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Pool And Spa Heating Systems</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Pool And Spa System Type</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="A01_PoolSpaType" type="comp:PoolSpaType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pool And Spa System Type</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list: PoolOnly display term Pool only, PoolSpa display term Pool and spa, SpaOnly display term Spa only</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Pool And Spa Systems And Equipment Requirements (Section 110.4(a) and 110.5)</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="B01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Comply with Regulations</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">A pool or spa heating system or equipment subject to State or federal applicance efficiency standards shall comply with applicable provisions of Section 110.1A..</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="B02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Accessible on-off switch</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">A readily accessible on-off switch is mounted on the outside of the heater, which allows the heater to be shut off without the user adjusting the thermostat setting.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="B03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Energy-efficient operation instructions</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">A weatherproof plate or card providing the energy efficiency rating and instructions for the energy-efficient operation of the pool and/or spa heater is permanently mounted and easily readable.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="B04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">No pilot light</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Heating system has no pilot light.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="BEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Pool And Spa System Installation Requirements (Section 110.4(b))</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="C01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Addition of solar heating equipment</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Equipment installed to heat water for pools and/or spas shall be selected from equipment meeting the standards shown in Table 110.4-A. </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Cover for outdoor pools or spas</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">At least 1 inches of horizontal or vertical pipe shall be installed between the filter and heater, or dedicated suction and return lines, or built-in or built-up connections to allow for future solar heating equipment are provided.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Cover for outdoor pools or spas</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Outdoor pools and/or spas with electric or gas heating equipment shall be installed with a pool cover.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pool system directional inlets</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Pool system has directional inlets to adequately mix the pool water</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="C05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pool system time switch</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Pool system has a permanent time switch that allows all pumps to be set or programmed to run during off-peak periods only, and for the minimum tome necessary to maintain the water in the condition required by applicable public health standards.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="CEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_D">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Pool And Spa Systems Heating Source Sizing Requirements (Section 110.4(c))</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="D01_PoolSpaSurfaceArea" type="hvac:PoolSpaSurfaceArea">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
                           Total Pool or Spa Surface Area (ft
                           <ns1:sup>2</ns1:sup>
                        </xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input integer</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D02_PoolSpaComplianceMethod" type="comp:PoolSpaComplianceMethod">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Method of Compliance</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects one from list of values:
MethodSolarHeater display term 1. Solar pool heater with a solar collector surface area that is greater than or equal to 60 percent of the pool and/or spa surface area.
MethodHPPH display term 2. Heat Pump Pool Heater (HPPH),  MethodRenewRecover display term 3. 60% on-site renewable or recovery energy 
MethodSolarHPCombo display term 4. Combination solar pool heater and heat pump pool heater with no additional supplementary heater,  MethodAlternateHeating display term 5. Alterative pool heating system approved by CEC Executive Director,
MethodException display term 6. N/A - Qualified Exceptions (must select Qualifying Exception below) </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D03_PoolSpaComplianceExceptions" type="comp:PoolSpaComplianceExceptions">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Qualifying Exceptions to Section 110.4(c)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects one from list of values: ExceptionNA display term 1. N/A, ExceptionSpaElectric display term 2. Portable electric spas compliant with 20 CCR 1605.3(g)(7) of the Appliance Efficiency Regulations, 
ExceptionAlternations display term 3. Alterations to existing pool and/or spa with existing heating systems or equipment, ExceptionSolar display term 4. A pool and/or spa that is heated solely by a solar pool heating system without any backup heater
ExceptionSpaGas display term 5. Heating systems which are used exclusively for permanent spa applications in existing buildings with gas availability 
ExceptionSpaSARA display term 6. Heating systems which are used exclusively for permanent spa applications where there is inadequate Solar Access Roof Area (SARA) as specified in Section 150.1(c)14 for a solar pool heating system to be installed</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="D04_PoolSpaMethodRequirements" type="comp:PoolSpaMethodRequirements">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Additional Requirements</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: Switch ( D02_PoolSpaComplianceMethod) case MethodSolarHeater: result = SolarHeater display term "This project requires a solar pool heating system with a solar collector surface area that is equivalent to 60 percent or greater of the pool and/or spa surface area. The minimum solar collector surface area required:" + D04a_SolarCollectorMinimumSurfaceArea 
case MethodHPPH: result = HPPH display term "This project requires a Heat Pump Pool Heater (HPPH) as the primary heat source. The HPPH shall be sized according to the HPPH manufacturer's specifications. If the HPPH manufacturer's specifications do not include information on HPPH sizing, use the sizing provisions in Reference Joint Appendix JA16.3. The supplementary heater can be of any energy source.”
case MethodRenewRecover: result = RenewRecover display term "This project requires an on-site renewable or on-site recovery energy source that provides at least 60 percent of the calculated annual energy consumption of the pool and/or spa heater. The mechanical engineer or responsible person shall provide documentation and submit together with this CF2R.
case MethodSolarHPCombo result = SolarHPCombo display term This project requires a combination solar pool heater and heat pump pool heater. The system shall have no additional supplementary heater.
case MethodAlternateHeating: result = AlternateHeating display term &gt;&gt; The system shall be verified as an CEC Executive Director approved alterative.  case ExceptionSpaGas: case ExceptionSpaSARA: result PoolSpaExceptionDoc display term The responsible person shall provide documentation for the qualifying exception and submit together with this CF2R.
</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="D04a_SolarCollectorMinimumSurfaceArea" type="comp:SolarCollectorMinimumSurfaceArea">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Minimum solar collector surface area</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If D04_PoolSpaMethodRequirements != MethodSolarHeater this field is not required Else If D04_PoolSpaMethodRequirements == MethodSolarHeater result = D01_PoolSpaSurfaceArea x 0.6 which is appended to the text displayed in D04_PoolSpaMethodRequirements </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="DEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_E">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Controls for Heat Pump Pool Heaters with Supplementary Heating  Requirements (Section 110.4(c))</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is only applicable if PoolSpaType in A01_PoolSpaType != SpaOnly.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="E01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Supplementary heater</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Supplementary heater shall not operate when the heating load can be met by the heat pump pool heater alone; and</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="E02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Cut-on Cut-off Temperatures</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The cut-on temperature for heat pump heating is higher than the cut-on temperature for supplementary heating, and the cut-off temperature for heat pump heating is higher than the cut-off temperature for supplementary heating</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="EEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_F">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Pool Pump Sizing And Flow Rate Specification (Section 150.0(p))</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is only applicable if PoolSpaType in A01_PoolSpaType != SpaOnly.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="F01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Certified pool pumps</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Dedicated-purpose pool pumps and replacement dedicated-purpose pump motors subject to State or federal appliance efficiency standards shall be listed in the CEC's directory of certified equipment. Dedicated-purpose pool pumps shall meet the applicable standards set forth in 20 CCR 1605.1(g)(7) of the Appliance Efficiency Regulations. Replacement dedicated-purpose pool pump motors shall meet the applicable standards set forth in 20 CCR 1605.3 of the Appliance Efficiency Regulations</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pool pump flow rate</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           The pool pump flow rate shall not exceed the maximum pump flow rate calculated based on pool sizing in the table below. The return pipe diameter, suction pipe diameter, and filter area shall be at least as large as the required minimums shown in the table. 
                           <ns1:line1/>
                            Alternatively, a flow calculation or flow test result shall be provided to demonstrate that the pump flow rate is less than 6 hour filtration turnover, and the return pipe flow rate does not exceed 8 fps and that the suction pipe flow rate does not exceed 6 fps.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F03_IsAlterrnativePoolPumpFlowResultProvided" type="comp:IsAlterrnativePoolPumpFlowResultProvided">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">An alternative compliance calculation or a flow test result is provided for this pool or spa use (must attach flow calculation or flow test result to this form)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from Boolean values:  true value, display term  Yes and false value, display term  No.  If F06_PoolVolume GT 48,000 gal, Then result  must be true, display text Yes.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Pump speeds default</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Dedicated-purpose pool pumps with more than one speed shall have controls which default to the filtration flow rate when no auxiliary pool loads are operating</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="F05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Default In 24 hours</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">For dedicated-purpose pool pumps with more than one speed, the controls shall default to the filtration flow rate setting within 24 hours and shall have an override capability for servicing.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F06_PoolVolume" type="hvac:PoolVolume">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Volume of pool (gallons)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input numeric xx,xxx</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F07_PoolFilterType" type="hvac:PoolFilterType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Filter Type (Cartridge, Sand, DE)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from list: Cartridge display term Cartridge, DE display term Diatomaceous Earth (DE), Sand display term Sand</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element maxOccurs="1" name="F08a_PoolReturnPipeDiameterMinimumRequired" type="hvac:PoolReturnPipeDiameterMinimumRequired">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Min Return Pipe Diameter (inches)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F03_IsAlterrnativePoolPumpFlowResultProvided == false, result is based on values from F06_PoolVolume and F07_PoolFilterType used to identify the result in Table C  found in the user instructions section of the Word layout document, 2022-CF2R-PLB-03-PoolAndSpaHeatingSystems.docx.   Else If F03_IsAlterrnativePoolPumpFlowResultProvided == true, result = N/a  stored in the NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element maxOccurs="1" name="F08a_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Min Return Pipe Diameter (inches)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F03_IsAlterrnativePoolPumpFlowResultProvided == true, result = N/a  stored in the NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element maxOccurs="1" name="F08b_PoolSuctionPipeDiameterMinimumRequired" type="hvac:PoolSuctionPipeDiameterMinimumRequired">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Min Suction Pipe Diameter (inches)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F03_IsAlterrnativePoolPumpFlowResultProvided == false, result is based on values from F06_PoolVolume and F07_PoolFilterType used to identify the result in Table C  found in the user instructions section of the Word layout document, 2022-CF2R-PLB-03-PoolAndSpaHeatingSystems.docx.   Else If F03_IsAlterrnativePoolPumpFlowResultProvided == true, result = N/a  stored in the NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element maxOccurs="1" name="F08b_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Required Min Suction Pipe Diameter (inches)</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F03_IsAlterrnativePoolPumpFlowResultProvided == true, result = N/a  stored in the NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element maxOccurs="1" name="F08c_PoolFilterSurfaceAreaMinimumRequired" type="hvac:PoolFilterSurfaceAreaMinimumRequired">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">
                              Required Min Filter Area (ft
                              <ns1:sup>2</ns1:sup>
                              )
                           </xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">Calculated field: If F03_IsAlterrnativePoolPumpFlowResultProvided == false, result is based on values from F06_PoolVolume and F07_PoolFilterType used to identify the result in Table C  found in the user instructions section of the Word layout document, 2022-CF2R-PLB-03-PoolAndSpaHeatingSystems.docx.   Else If F03_IsAlterrnativePoolPumpFlowResultProvided == true, result = N/a  stored in the NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
