                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C03_ArrayModuleType" type="hvac:ArrayModuleType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Type</xs:documentation>
                                             
                                             
