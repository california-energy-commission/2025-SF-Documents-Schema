                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Level Power Eletronics</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B13 which may be NA</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
