                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C08_InverterEfficiencyPercent" type="hvac:InverterEfficiencyPercent">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Inverter Efficiency (%)</xs:documentation>
                                          
                                          
