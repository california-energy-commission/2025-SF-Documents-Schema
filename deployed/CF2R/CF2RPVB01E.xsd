<?xml version="1.0" ?>
<xs:schema xmlns:ns1="http://www.lmonte.com/besm/d" xmlns:xs="http://www.w3.org/2001/XMLSchema" attributeFormDefault="unqualified" elementFormDefault="qualified" targetNamespace="http://www.lmonte.com/besm/CF2RPVB01E" version="2025.0.000">
   
   
   <xs:import namespace="http://www.lmonte.com/besm/com" schemaLocation="../base/ResCommon.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/bld" schemaLocation="../base/ResBuilding.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/env" schemaLocation="../base/ResEnvelope.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/lit" schemaLocation="../base/ResLighting.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/hvac" schemaLocation="../base/ResHvac.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/comp" schemaLocation="../base/ResCompliance.xsd"/>
   
   
   <xs:import namespace="http://www.lmonte.com/besm/dtyp" schemaLocation="../base/DataTypes.xsd"/>
   
   
   <xs:element name="ComplianceDocumentPackage">
      
      
      <xs:complexType>
         
         
         <xs:sequence>
            
            
            <xs:element minOccurs="0" name="DocID">
               
               
               <xs:complexType>
                  
                  
                  <xs:attribute fixed="CF2RPVB01E" name="doc" type="comp:ComplianceDocumentTag"/>
                  
                  
                  <xs:attribute fixed="CERTIFICATE OF INSTALLATION" name="docType" type="comp:ComplianceDocumentType"/>
                  
                  
                  <xs:attribute fixed="Photovoltaic Systems" name="docTitle" type="comp:ComplianceDocumentTitleRes"/>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Payload" type="comp:Payload"/>
            
            
            <xs:element name="DocumentData">
               
               
               <xs:complexType>
                  
                  
                  <xs:sequence>
                     
                     
                     <xs:element name="Header" type="comp:HeaderHERS"/>
                     
                     
                     <xs:element ref="cF2RPVB01E"/>
                     
                     
                     <xs:element name="DocAuthor" type="comp:DocumentAuthor"/>
                     
                     
                     <xs:element name="RespPerson" type="comp:ResponsiblePersonCF2R_E"/>
                     
                     
                     <xs:element name="Footer" type="comp:Footer"/>
                     
                  
                  </xs:sequence>
                  
               
               </xs:complexType>
               
            
            </xs:element>
            
            
            <xs:element name="Report" type="xsd:base64Binary"/>
            
         
         </xs:sequence>
         
         
         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF2RPVB01E" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF2RPVB01E">
      
      
      <xs:annotation>
         
         
         <xs:documentation>Photovoltaic Systems</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element minOccurs="1" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">General Information</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="ABeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>Note: This Certificate of Installation document is only applicable if a PV system is in the proposed design or PV Exceptions are selected in the CF1R-PRF-01 or CF1R-NCB-01.</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A01_ProjectCity" type="comp:ProjectCity">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Project Location (City)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Auto-filled: reference value from CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A02_ResidentialLowriseBuildingType" type="com:ResidentialLowriseBuildingType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Building type</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Auto-filled: reference value from CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A03_ClimateZone" type="com:ClimateZone">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Climate Zone</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Auto-filled: reference value from CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="A04_ComplianceCertificateType" type="comp:ComplianceCertificateType">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Method of Compliance:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Reference value from CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A05_PhotoVoltaicExceptionRes" type="comp:PhotoVoltaicExceptionRes">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Qualifying Exceptions</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If CF1R-PRF reports Battery Storage or Community solar result = N/A stored in NotApplicableMessage Else User picks from list.  Enum values are BatteryStorage, LT1_8kWdcRequired, NoExceptionsNA, LimitedSolarAccess, PlansBefore2020, CommunitySolar, DeclaredEmergencyArea, SnowLoad, Section10_109k</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A05_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Qualifying Exceptions</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If CF1R-PRF reports Battery Storage or Community solar result = N/A stored in NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
                  
                  <xs:choice maxOccurs="1">
                     
                     
                     <xs:element name="A06_PVExceptionString" type="comp:PVExceptionString">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Community Solar</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If A05_PhotoVoltaicExceptionRes == ComunitySolar, load field from CF1R-PRF if available
Or allow user input; Else result = NotApplicable store in NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                     
                     <xs:element name="A06_NotApplicableMessage" type="comp:NotApplicableMessage">
                        
                        
                        <xs:annotation>
                           
                           
                           <xs:documentation source="FieldText">Community Solar</xs:documentation>
                           
                           
                           <xs:documentation source="CalculationsAndRules">If A05_PhotoVoltaicExceptionRes == ComunitySolar, load field from CF1R-PRF if available
Or allow user input; Else result = NotApplicable store in NotApplicableMessage</xs:documentation>
                           
                        
                        </xs:annotation>
                        
                     
                     </xs:element>
                     
                  
                  </xs:choice>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_B">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Design Photovoltaic Systems Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required If A05_PhotoVoltaicExceptionRes !=  LimitedSolarAccess Or CommunitySolar Or DeclaredEmergencyArea Or SnowLoad Or Section10_109k Or LT1_8kWdcRequired</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableDesign">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="B01_ArrayName" type="hvac:ArrayName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">PV Array ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If available reference value from CF1R; Else user input</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B02_ArrayPowerOutput" type="hvac:ArrayPowerOutput">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Adjusted Minimum PV Size (kW)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled: reference value from CF1R</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="B03_ArrayAdjustedPowerOutput" type="hvac:ArrayAdjustedPowerOutput">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Adjusted Minimum PV Size from Qualified Exception Requirement (kW)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If CF1R-PRF parent result = B02_ArrayPowerOutput, Else If prescriptive CC And A05_PhotoVoltaicExceptionRes == NoExceptionsNA result = O09 from CF1R; Else user input decimal non-negative value.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B04_ArrayModuleType" type="hvac:ArrayModuleType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B04_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B05_CFI_PV" type="comp:CFI_PV">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CFI</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If parent CF1R is performance 
value loaded from CF1R-PRF  Da06_CFI_PV which is true (display term Yes) if CFI1 or CFI2 is chosen and otherwise is false (display term No)
 
Else If parent CF1R is prescriptive 
reult = NotApplicable display term N/A stored in NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B05_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">CFI</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If parent CF1R is prescriptive 
reult = NotApplicable display term N/A stored in NotApplicableMessage
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="B06_Azimuth" type="dtyp:Azimuth">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Azimuth (deg)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If A04_ComplianceCertificateType == Performance Then 
If  B05_CFI_PV == true Then
If CF1R-PRF XML  Da07_AzimuthRange data Not Present
user input value that is in range 150 - 270;
Else If CF1R-PRF Da07_AzimuthRange == 150To270 for CFI1
user input value that is in range 150 - 270;  
Else If CF1R-PRF Da07_AzimuthRange == 105To300 for CFI2
user input value that is in range 105 - 300
End If
 
Else If  B05_CFI_PV == false 
If CF1R-PRF XML  Da07_AzimuthRange data Not Present
user input value that is in range 0 - 359;
Else result = CF1R-PRF Da07_Azimuth value which is in range 0 -359; 
End If
End If
 
Else If A04_ComplianceCertificateType = Prescriptive 
user input value that is in range 0 - 359;
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B07_TiltMeasurementType" type="env:TiltMeasurementType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tilt Input (deg/Pitch)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A04_ComplianceMethod == Performance 
result = CF1R-PRF Da08 which may be N/A;
Else user selects tilt degrees or pitch
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tilt Input (deg/Pitch)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A04_ComplianceMethod == Performance 
result = CF1R-PRF Da08 which may be N/A;
Else user selects tilt degrees or pitch
End If</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B08_Tilt" type="dtyp:Tilt">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Angle/Tilt</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A04_ComplianceMethod Not== Performance  
 
If  B07_TiltMeasurementType = TiltDegrees 
If B06_Azimuth LTE 59 Or  GTE 301 
user inputs value that must be  InclusiveRange(0,10) stored in B08_Tilt  
Else If B06_Azimuth  InclusiveRange(90, 300) 
user inputs value that must be  InclusiveRange(0,90) stored in B08_Tilt  
 
 
Else If B07_TiltMeasurementType = TiltPitch 
If B06_Azimuth LTE 59 Or   GTE 301 
user inputs value that must be InclusiveRange(0,2) stored in B08_RoofRise; 
Else If B06_Azimuth  InclusiveRange(90, 300) 
user inputs value that must be InclusiveRange(0,50) stored in B08_RoofRise;
End If
End If
 
Else If A04_ComplianceMethod == Performance Then 
If B05_CFI_PV == true 
result is value from CF1R-PRF that is LTE 7 stored in  B08_RoofRise; 
Else  value from CF1R-PRF</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B08_RoofRise" type="env:RoofRise">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Angle/Tilt</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A04_ComplianceMethod Not== Performance  
 
If  B07_TiltMeasurementType = TiltDegrees 
If B06_Azimuth LTE 59 Or  GTE 301 
user inputs value that must be  InclusiveRange(0,10) stored in B08_Tilt  
Else If B06_Azimuth  InclusiveRange(90, 300) 
user inputs value that must be  InclusiveRange(0,90) stored in B08_Tilt  
 
 
Else If B07_TiltMeasurementType = TiltPitch 
If B06_Azimuth LTE 59 Or   GTE 301 
user inputs value that must be InclusiveRange(0,2) stored in B08_RoofRise; 
Else If B06_Azimuth  InclusiveRange(90, 300) 
user inputs value that must be InclusiveRange(0,50) stored in B08_RoofRise;
End If
End If
 
Else If A04_ComplianceMethod == Performance Then 
If B05_CFI_PV == true 
result is value from CF1R-PRF that is LTE 7 stored in  B08_RoofRise; 
Else  value from CF1R-PRF</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="B09_AnnualSolarAccess" type="hvac:AnnualSolarAccess">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Annual Solar Access (%)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If A04_ComplianceCertificateType == Performance Then
result = CF1R-PRF Da12_AnnualSolarAccess
Else 
result = 98
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B10_InverterEfficiencyPercent" type="hvac:InverterEfficiencyPercent">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Inverter Efficiency (%)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B10_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Inverter Efficiency (%)</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="B11_PhotoVoltaicShading">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Shading Requirement Compliance Path</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Result = MinimumShadingCriterion</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="comp:PhotoVoltaicShading">
                                             
                                             
                                             <xs:enumeration value="MinimalShadingCritierion"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B12_ArrayType" type="hvac:ArrayType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Array Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B12_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Array Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="B13_PowerElectronics" type="hvac:PowerElectronics">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Level Power Eletronics</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="B13_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Level Power Eletronics</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Value from CF1R-PRF Else NA stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="B14_PV_SystemPowerOutput" type="hvac:PV_SystemPowerOutput">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total DC System Size (kW)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Caculated field: Sum All (B03_ArrayAdjustedPowerOutput)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_C">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Installed Photovoltaic Systems Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required If A05_PhotoVoltaicExceptionRes !=  LT1_8kWdcRequired, LimitedSolarAccess Or CommunitySolar Or DeclaredEmergencyArea Or SnowLoad Or Section10_109k Or LT1_8kWdcRequired.  For each record in Section B TableDesign, require a record in TableInstalled.  If an array has B05_CFI_PV == true, allow user to add a new record for that array in the TableInstalled.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element name="TableInstalled">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="C01_ArrayName" type="hvac:ArrayName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">PV Array ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Auto-filled: reference value from CF1R; else user input</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="C02_ArrayPowerOutput" type="hvac:ArrayPowerOutput">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">DC System Size (kW)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If B05_CFI_PV == false then result = B03_ArrayAdjustedPowerOutput but allow user to override; Else user input</xs:documentation>
                                          
                                       
