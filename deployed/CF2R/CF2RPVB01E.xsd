                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="C11_PV_SystemPowerOutput" type="hvac:PV_SystemPowerOutput">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total DC System Size (kW)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Caculated field: Sum All (C02_ArrayPowerOutput)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="CEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:b>If the installer certifies that the installed PV system matches or exceed the design PV system, the building complies with the PV system requirement, otherwise it does not comply.</ns1:b>
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
