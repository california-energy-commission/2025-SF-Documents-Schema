                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Array Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B12 which may be NA</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="C10_PowerElectronics" type="hvac:PowerElectronics">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Module Level Power Eletronics</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B13 as default;  If B13_PowerElectronics == NoPowerElectronics, then allow user to override and select from list: Microinverters display term Microinverters and PowerOptimizers display term DC Power Optimizers</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
