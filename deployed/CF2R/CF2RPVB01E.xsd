                                       <xs:element name="C09_ArrayType" type="hvac:ArrayType">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Array Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference value from B12</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
