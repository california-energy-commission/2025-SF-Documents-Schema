                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Manometer Serial Number</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input text</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
