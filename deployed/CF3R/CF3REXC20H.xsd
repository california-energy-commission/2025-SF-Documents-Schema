                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Azimuth</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Data is loaded from registered parent CC</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
