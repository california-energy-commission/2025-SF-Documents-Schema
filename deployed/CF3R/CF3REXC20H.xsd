                        <xs:documentation source="CalculationsAndRules">User selects from list: Pressurization, Depressurization</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="Env09_AirLeakageRateMeasuredACH50" type="comp:AirLeakageRateMeasuredACH50">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Target Enclosure Air Leakage from CF1R (ACH50)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Data is loaded from registered CF1R</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="Env10_CFM50Existing" type="comp:CFM50Existing">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Tested Pre-Retrofit CFM50</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input number</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
