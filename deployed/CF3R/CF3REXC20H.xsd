                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="Env12_ExistingConditionVerificationStatus" type="comp:ExistingConditionVerificationStatus">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If this existing condition has been verified, user selects Pass (Boolean true), Else if any part of this existing condition is not verified, user selects Fail (Boolean false).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="Env13_DoAllExistingConditionsComply" type="comp:DoAllExistingConditionsComply">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification Status</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If the value for Env12_ExistingConditionVerificationStatus == equals true, result is true display term Pass - all existing conditions have been verified.  
Else  
 result is false display term   Fail - one or more of the existing conditions not present. Enter reason for failure in correction notes field below</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
