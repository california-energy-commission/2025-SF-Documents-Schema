                     <xsd:attribute name="doc" type="comp:ComplianceDocumentTag" fixed="CF3RMCH25H"/>
                     <xsd:attribute name="docType" type="comp:ComplianceDocumentType" fixed="CERTIFICATE OF VERIFICATION"/>
                     <xsd:attribute name="docTitle" type="comp:ComplianceDocumentTitleRes" fixed="Refrigerant Charge Verification"/>
