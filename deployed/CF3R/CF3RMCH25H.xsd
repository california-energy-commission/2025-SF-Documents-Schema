               </xsd:element>
               <xsd:element name="Report" type="xsd:base64Binary"/>
            </xsd:sequence>
            <xsd:attribute name="revision" type="xsd:string" use="required" fixed="rev 20250101"/>
            <xsd:attribute name="doc" type="comp:ComplianceDocumentTag" use="required" fixed="CF3RMCH25H"/>
         </xsd:complexType>
      </xsd:element>
      <xsd:element name="cF3RMCH25H" type="CF3RMCH25H">
         <xsd:annotation>
            <xsd:documentation>This element contains all of the data and text required to generate the CF3RMCH25H compliance report.</xsd:documentation>
         </xsd:annotation>
      </xsd:element>
   </xsd:complexType>
</xsd:schema>
