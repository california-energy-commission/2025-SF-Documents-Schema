         <xs:attribute fixed="rev 20250101" name="revision" type="xsd:string" use="required"/>
         
         
         <xs:attribute fixed="CF3RPLB22H" name="doc" type="comp:ComplianceDocumentTag" use="required"/>
         
      
      </xs:complexType>
      
   
   </xs:element>
   
   
   <xs:complexType name="CF3RPLB22H">
      
      
      <xs:annotation>
         
         
         <xs:documentation> Verified Single Dwelling Unit Hot Water System Distribution</xs:documentation>
         
      
      </xs:annotation>
      
      
      <xs:sequence>
         
         
         <xs:element minOccurs="0" name="Section_A">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Design  Verified Dwelling Unit Water Heating Systems Information (other than HPWH)</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the CF1R Certificate of Compliance (CC).   This  section is required if the CF1R parent  has any non-HPWH systems, Require one row of data for each non-HPWH system identified on the CF1R</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="A_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">This table reports features of  water heating system(s) other than HPWH systems that were specified on the registered CF1R compliance document for this project.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableDesignSystem">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="A01_ResidentialDwellingUnitName" type="com:ResidentialDwellingUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dwelling Unit Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from CF1R; If single family, enter string: Single Family</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A02_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heating System ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC (see header for rules)</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A03_ResidentialWaterHeatingSystemType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heating System Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC Allowed values are: DHW display term: DHW, HydronicSpaceConditioningDHW display term: Combined Hydronic and Hydronic display term</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:ResidentialWaterHeatingSystemType">
                                             
                                             
                                             <xs:enumeration value="DHW"/>
                                             
                                             
                                             <xs:enumeration value="Hydronic"/>
                                             
                                             
                                             <xs:enumeration value="HydronicSpaceConditioningDHW"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A04_ResidentialWaterHeaterType" type="hvac:ResidentialWaterHeaterType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water-Heater Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC Allowed values are: BoilerWaterHeater display term: Boiler, IndirectWaterHeating display term:  Indirect, InstantaneousCommercial display term: Commercial Instantaneous, InstantaneousResDutyCommercial display term: Residential-Duty Commercial Instantaneous, InstantaneousConsumer display term: Consumer Instantaneous,   StorageCommercial display term: Commercial Storage, StorageResDutyCommercial display term: Residential-Duty Commercial Storage,   StorageConsumer display term: Consumer Storage</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A05_WaterHeaterTotalSystemCount" type="hvac:WaterHeaterTotalSystemCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText"># of Like (or Identical) Water Heaters in System</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A06_WaterHeaterFuelSource">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Fuel Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC Allowed values: Electricity display term Electricity, NaturalGas display term Natural Gas, PropaneGas display term Propane gas, WaterHeatingHP display term Heat Pump</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                       
                                       <xs:simpleType>
                                          
                                          
                                          <xs:restriction base="hvac:WaterHeaterFuelSource">
                                             
                                             
                                             <xs:enumeration value="Electricity"/>
                                             
                                             
                                             <xs:enumeration value="NaturalGas"/>
                                             
                                             
                                             <xs:enumeration value="PropaneGas"/>
                                             
                                             
                                             <xs:enumeration value="WaterHeatingHP"/>
                                             
                                          
                                          </xs:restriction>
                                          
                                       
                                       </xs:simpleType>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="A07_WaterHeaterRatedInputUnits" type="hvac:WaterHeaterRatedInputUnits">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Rated Input Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A06_WaterHeaterFuelSource == WaterHeatingHP result = N/A stored in _NotApplicableMessage; Else  reference value from parent CC.  Allowed values: If A06_WaterHeaterFuelSource == NaturalGas Or PropaneGas result = BtuHr Else If A06_WaterHeaterFuelSource == Electricity result = kW</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="A07_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Rated Input Type</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A06_WaterHeaterFuelSource == WaterHeatingHP result = N/A stored in _NotApplicableMessage; Else  reference value from parent CC.  Allowed values: If A06_WaterHeaterFuelSource == NaturalGas Or PropaneGas result = BtuHr Else If A06_WaterHeaterFuelSource == Electricity result = kW</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="A08_WaterHeaterElectricFiredRatedInput" type="hvac:WaterHeaterElectricFiredRatedInput">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Rated Input Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A06_WaterHeaterFuelSource == WaterHeatingHP result = N/A stored in the NotApplicableMessage;  Else If prescriptive parent CC result = N/A  stored in the NotApplicableMessage; Else If performance parent CC reference value from parent CC.  If A07_WaterHeaterRatedInputUnits == kW store result in WaterHeaterElectricFiredRatedInput Else store result in WaterHeaterGasFiredRatedInput</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="A08_WaterHeaterGasFiredRatedInput" type="hvac:WaterHeaterGasFiredRatedInput">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Rated Input Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A06_WaterHeaterFuelSource == WaterHeatingHP result = N/A stored in the NotApplicableMessage;  Else If prescriptive parent CC result = N/A  stored in the NotApplicableMessage; Else If performance parent CC reference value from parent CC.  If A07_WaterHeaterRatedInputUnits == kW store result in WaterHeaterElectricFiredRatedInput Else store result in WaterHeaterGasFiredRatedInput</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="A08_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Rated Input Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">If A06_WaterHeaterFuelSource == WaterHeatingHP result = N/A stored in the NotApplicableMessage;  Else If prescriptive parent CC result = N/A  stored in the NotApplicableMessage; Else If performance parent CC reference value from parent CC.  If A07_WaterHeaterRatedInputUnits == kW store result in WaterHeaterElectricFiredRatedInput Else store result in WaterHeaterGasFiredRatedInput</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                                                        
                                    
                                    <xs:element name="A09_ResidentialDHWDwellingUnitDistributionType" type="hvac:ResidentialDHWDwellingUnitDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dwelling Unit DHW System Distribution Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If performance parent CC, Then If A09_IsDHW_Central == false  allowed values are: StandardDistribution display term: Standard Distribution System; PointOfUse display term: Point Of Use, StandardDistributionCentralParallelPiping display term: Central Parallel Piping;  RecirculationNonDemand display term:  Recirculation System Non-Demand Control; 
DemandRecirculationManualControl display term: Demand Recirculation Manual Control;  DemandRecirculationSensorControls display term: Demand Recirculation Sensor Control; StandardDistributionInsulatedPipesHERS display term  Verified Pipe Insulation for Central Systems, StandardDistributionCentralParallelPipingHERS display term  Verified Central Parallel Piping, DemandRecirculationManualControlHERS display term  Verified Demand Recirculation Manual Control, DemandRecirculationSensorControlsHERS display term Verified Demand Recirculation Sensor Controls; 
Else  If A09_IsDHW_Central == true allowed values are: StandardDistribution. Display term: Standard Distribution System, StandardDistributionInsulatedPipesHERS display term  Verified Pipe Insulation for Central Systems;  
End If

Else If prescriptive parent CC  allowed values are: StandardDistribution display term: Standard Distribution System; DemandRecirculationManualControl display term: Demand Recirculation Manual Control;  DemandRecirculation display term Demand Recirculation;  
End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A10_CompactDistributionType" type="hvac:CompactDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Compact Distrib.</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If parent CF1R = NCB-01, then if NCB-01 Field M07 = CompactHotWaterDistributionSystemHERS or CompactHotWaterDistributionSystemBasic or CompactDistributionDrainHeatRecoveryHERS then value is BasicType else NotCompact;
                                             Else if parent CF1R = ALT-01 or ADD-01, then value = NotCompact;
                                             Else if information not available from PRF-01, allow user select. Allowed values are
                                             *Basic
                                             *Expanded
                                             *NotCompact;
                                             Else use value from PRF-01;
                                          </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="A11_DWHR_Type" type="hvac:DWHR_Type">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Drain Water Heat Recovery</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If parent CF1R = NCB-01, then if NCB-01 Field M09 = CompactDistriutionDrainHeatRecoveryHERS or DrainWaterHeatRecoveryHERS then value is DWHR else NoDWHR;
                                             Else if parent CF1R = ALT-01 or ADD-01, then value = NoDWHR;
                                             Else if information not available from PRF-01, allow user select. Allowed values are
                                             *DWHR
                                             *NoDWHR;
                                             Else use value from PRF-01;
                                          </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_A2">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Design  Verified Dwelling Unit  HPWH System Information</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">In this section parent CC refers to the CF1R Certificate of Compliance.This section is required if the CF1R parent  has any HPWH systems, Require one row of data for each HPWH system identified on the CF1R</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="A2_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">This table reports features of HPWH water heating system(s)  that were specified on the registered CF1R compliance document for this project.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="TableHpwhd">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:complexType>
                        
                        
                        <xs:sequence>
                           
                           
                           <xs:element maxOccurs="unbounded" minOccurs="1" name="Row">
                              
                              
                              <xs:complexType>
                                 
                                 
                                 <xs:sequence>
                                    
                                    
                                    <xs:element name="Hpd01_ResidentialDwellingUnitName" type="com:ResidentialDwellingUnitName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dwelling Unit Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from CF1R; If single family, enter string: Single Family</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd02_WaterHeatingSystemName" type="hvac:WaterHeatingSystemName">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Water Heating System ID or Name</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC.</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd03_HeatPumpWaterHeaterModel" type="hvac:HeatPumpWaterHeaterModel">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Modeled Equipment Make and Model</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If  prescriptive parent CC result = Tier3NEEA; Else reference value from performance parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd04_WaterHeaterTotalSystemCount" type="hvac:WaterHeaterTotalSystemCount">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText"># of Like (or Identical) Water Heaters in System</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference values from parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd05_TankLocation" type="hvac:TankLocation">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Tank Location</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference value from parent CC</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element name="Hpd06_ExteriorTankInsulation" type="hvac:ExteriorTankInsulation">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Exterior Tank Insulation R-Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference values from performance parent CC Else result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element name="Hpd06_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Exterior Tank Insulation R-Value</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference values from perofrmance parent CC Else result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:choice maxOccurs="1">
                                       
                                       
                                       <xs:element minOccurs="0" name="Hpd06a_StorageCapacity" type="hvac:StorageCapacity">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Volume</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference values from  performance parent CC Else If prescriptive parent CC allow user input; Else result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                       
                                       <xs:element minOccurs="0" name="Hpd06a_NotApplicableMessage" type="comp:NotApplicableMessage">
                                          
                                          
                                          <xs:annotation>
                                             
                                             
                                             <xs:documentation source="FieldText">Tank Volume</xs:documentation>
                                             
                                             
                                             <xs:documentation source="CalculationsAndRules">Reference values from  performance parent CC Else If prescriptive parent CC allow user input; Else result = N/A stored in NotApplicableMessage</xs:documentation>
                                             
                                          
                                          </xs:annotation>
                                          
                                       
                                       </xs:element>
                                       
                                    
                                    </xs:choice>
                                    
                                    
                                    <xs:element name="Hpd07_ResidentialDHWDwellingUnitDistributionType" type="hvac:ResidentialDHWDwellingUnitDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Dwelling Unit DHW System Distribution Type</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Reference parent CC as follows: If performance parent CC values are: StandardDistribution display term: Standard Distribution System; PointOfUse display term: Point Of Use, StandardDistributionCentralParallelPiping display term: Central Parallel Piping;  RecirculationNonDemand display term:  Recirculation System Non-Demand Control; DemandRecirculationManualControl display term: Demand Recirculation Manual Control;  
DemandRecirculationSensorControls display term: Demand Recirculation Sensor Control; StandardDistributionInsulatedPipesHERS display term  Verified Pipe Insulation for Central Systems, StandardDistributionCentralParallelPipingHERS display term  Verified Central Parallel Piping, DemandRecirculationManualControlHERS display term  Verified Demand Recirculation Manual Control, DemandRecirculationSensorControlsHERS display term  Verified Demand Recirculation Sensor Controls; 
Else If prescriptive parent CC values are: StandardDistribution display term: Standard Distribution System; DemandRecirculationManualControl display term: Demand Recirculation Manual Control;   DemandRecirculation display term Demand Recirculation;  End If</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd08_CompactDistributionType" type="hvac:CompactDistributionType">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Compact Distribution</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If parent CF1R = NCB-01, then if NCB-01 Field M07 = CompactHotWaterDistributionSystemHERS or CompactHotWaterDistributionSystemBasic or CompactDistributionDrainHeatRecoveryHERS then value is BasicType else NotCompact;
                                             Else if parent CF1R = ALT-01 or ADD-01, then value = NotCompact; Else if information not available from PRF-01, allow user select. Allowed values are
                                             *Basic
                                             *Expanded
                                             *NotCompact;
                                             Else use value from PRF-01; </xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="Hpd09_DWHR_Type" type="hvac:DWHR_Type">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Drain Water Heat Recovery</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">If parent CF1R = NCB-01, then if NCB-01 Field M07 = CompactDistriutionDrainHeatRecoveryHERS or DrainWaterHeatRecoveryHERS then value is DWHR else NoDWHR;
                                             Else if parent CF1R = ALT-01 or ADD-01, then value = NoDWHR; Else if information not available from PRF-01, allow user select. Allowed values are
                                             *DWHR
