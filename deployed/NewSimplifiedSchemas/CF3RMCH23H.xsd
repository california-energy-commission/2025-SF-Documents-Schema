                                          <xs:documentation source="FieldText">Measured Airflow with All Other Zones Off (CFM)</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">User input numeric value: xxxx</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                    
                                    <xs:element name="F07_DoesZoneComplyWithRequiredAirflowRate" type="comp:DoesZoneComplyWithRequiredAirflowRate">
                                       
                                       
                                       <xs:annotation>
                                          
                                          
                                          <xs:documentation source="FieldText">Zone Compliance Status</xs:documentation>
                                          
                                          
                                          <xs:documentation source="CalculationsAndRules">Calculated field: If F06_ZoneMeasuredAirflow GTE F03_AirflowRequiredPerControlledZone, then result = true display term Pass;  Else result = false display term  Fail</xs:documentation>
                                          
                                       
                                       </xs:annotation>
                                       
                                    
                                    </xs:element>
                                    
                                 
                                 </xs:sequence>
                                 
                              
                              </xs:complexType>
                              
                           
                           </xs:element>
                           
                        
                        </xs:sequence>
                        
                     
                     </xs:complexType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="F08_DoAllZonesComplyWithRequiredAirflowRate" type="comp:DoAllZonesComplyWithRequiredAirflowRate">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Compliance Statement:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If F07_DoesZoneComplyWithRequiredAirflowRate == true for all rows, then result = true display term  System airflow rate complies,    Else result = false display term  System does not comply with minimum airflow rate requirement.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="0" name="Section_G">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Central Fan Ventilation Cooling System Airflow Rate Measurement</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required If A12_CFVCS_Type != NotCFVCS  In this section MCH-01 refers to the project CF2R-MCH-01</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="G_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The procedures for central fan ventilation cooling system airflow rate verification are specified in Reference Residential Appendix RA3.3.4</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="G01_AirflowRequiredMinimumTarget" type="hvac:AirflowRequiredMinimumTarget">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Required Minimum Ventilation System Airflow Rate (cfm)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If parent document = CF2R-MCH-01b, then value = 300; Else Auto-filled with value from Mch01 C11 Central Fan Ventilation Cooling Airflow</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="G02_AirflowMeasuredRate" type="hvac:AirflowMeasuredRate">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Actual System Ventilation Airflow Rate measurement (cfm)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User input numeric xxxx</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="G03_DoesCFVCS_AirflowComply" type="comp:DoesCFVCS_AirflowComply">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Compliance Statement</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">Calculated field: If A12_CFVCS_Type  == FixedCFVCS And G02_AirflowMeasuredRate GTE G01_AirflowRequiredMinimumTarget OR If A12_CFVCS_Type == VariableCFVCS And G02_AirflowMeasuredRate LTE G01_AirflowRequiredMinimumTarget, 
result = true display term  System ventilation airflow rate complies. Else result = false display term  System does not comply with minimum  ventilation airflow rate requirement</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element maxOccurs="1" minOccurs="1" name="Section_H">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Additional Requirements</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">Ths section is always requird and displayed</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="H01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Air Filters Installed properly</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Air filters that meet the applicable requirements of Standards Section 150.0(m)12 or 150.0(m)13 were properly installed in the system during system air flow rate measurement identified on this Certificate of Installation.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Airflow rate measurement apparatus certified</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The airflow rate measurement apparatus used to perform the airflow rate measurement identified on this Certificate of Installation was calibrated in accordance with the apparatus manufacturer's specifications and conforms to the instrumentation specifications given in RA3.3.1.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Bypass Duct</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If A05 Nominal Cooling Capacity != N/A display this field</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           A visual inspection shall confirm that bypass ducts that deliver conditioned supply air directly to the space conditioning system return duct airflow are not used on 
                           <ns2:u> newly constructed</ns2:u>
                            zonally controlled systems unless the Performance Certificate of Compliance indicates an allowance for use of a bypass duct.  When a bypass duct is accounted for on the Performance Certificate of Compliance, the airflow rate shall conform to the specifications listed on this document.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                    
                  <xs:element minOccurs="0" name="H04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">All registers fully open</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All registers were fully open during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">System fan testing speed</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">System fan was set at maximum speed during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Fresh Air Duct</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">If fresh air duct is part of the HVAC system it was not closed during the diagnostic test.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Fan Efficacy tested value</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Airflow rate and fan watt draw shall be simultaneous measurements when used to calculate the Fan Efficacy tested value.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H08">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Multi-speed compressor</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Multi-speed compressor space cooling systems or variable speed compressor systems with controls that vary fan speed subect to the number of zones, as certified by the installer may verify air flow (cfm/ton) and fan efficacy (Watt/cfm) with system operating at the maximum compressor capacity and system fan speed with all zones calling for conditioning.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H09">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Alternative Compliance</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">For altered systems that do not comply with the minimum 300 cfm per ton airflow rate requirement but opt to comply using the remedial actions on this MCH-23 compliance document according to Section RA3.3.3.1.5, the system's thermostat shall conform to the specifications in Reference Joint Appendix JA5 and shall be capable of receiving and responding to Demand Response Signals prior to final approval of the building permit by the enforcing agency (Section 150.2(b)1Fia).</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="H10_DoesSystemComplyWithRequirements" type="comp:DoesSystemComplyWithRequirements">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification Status:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">For Pass choice display text: Pass - all applicable requirements are met.  For Fail choice display text: Fail - one or more applicable requirements are not met. Enter reason for failure in corrections notes field below.  For N/A choice display text: All n/a - This entire table is not applicable</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="H11_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Correction Notes:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If Verification Status= Fail, then text entry in this Corrections Notes field is required</xs:documentation>
                        
                    
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="HEndNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">End Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The responsible person's signature on this compliance document affirms that all applicable requirements in this table have been met.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
         </xs:element>
         
         
         <xs:element minOccurs="1" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Determination of ECC Verification Compliance</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">This section is required.</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
                
               <xs:sequence>
                  
                   
                  <xs:element minOccurs="0" name="I_BeginNote1">
                     
                      
                     <xs:annotation>
                        
                         
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                          
                        <xs:documentation source="AdditionalRequirements">All applicable sections of this document shall indicate compliance with the specified verification protocol requirements in order for this Certificate of Verification as a whole to be determined to be in compliance.</xs:documentation>
                        
                      
                     </xs:annotation>
                     
                   
                  </xs:element>
                  
                   
                  <xs:element name="I01_DoesCF3R_Pass" type="comp:DoesCF3R_Pass">
                     
                       
                     <xs:annotation>
                        
                          
                        <xs:documentation source="FieldText"/>
                        
                          
                        <xs:documentation source="CalculationsAndRules">If  B01_HSPP_PSPP_ComplianceMethod =! HSPP_PSPP_NotInstalled; and C04_IsAirflowMeasurementDeviceCertified == true; and (Ems04_DoesForcedAirSystemAirflowRateComply Or Essz04_DoesForcedAirSystemAirflowRateComply Or Ealt04_DoesForcedAirSystemAirflowRateComply == true) 
And If present D09_DoesForcedAirSystemPassAlternativeComplianceRequirements == true And If present F08_DoAllZonesComplyWithRequiredAirflowRate == true; And If present G03_DoesCentralFanVentilationCoolingSystemAirflowComply == true and H10_DoesSystemComplyWithRequirements == Pass or N/A then result = true display term  Complies: All specified verification protocol requirements on this document are met;  Else result = false display term  Does not comply: One or more specified verification protocol requirements on this document are not met.</xs:documentation>
                        
                       
                     </xs:annotation>
                     
                   
                  </xs:element>
                  
                 
               </xs:sequence>
               
             
            </xs:complexType>
            
          
         </xs:element>
         
      
      </xs:sequence>
      
   
   </xs:complexType>
   
   
   <xs:element name="cF3RMCH23H" type="CF3RMCH23H">
      
      
      <xs:annotation>
         
         
         <xs:documentation>This element contains all of the data and text required to generate the CF3RMCH23H compliance report.</xs:documentation>
         
      
      </xs:annotation>
      
   
   </xs:element>
   

