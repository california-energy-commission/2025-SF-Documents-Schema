         <xs:element minOccurs="0" name="Section_I">
            
            
            <xs:annotation>
               
               
               <xs:documentation source="FieldText">Weigh In Charge Procedure - Additional Requirements</xs:documentation>
               
               
               <xs:documentation source="CalculationsAndRules">This section is required if A18 RefrigerantChargeVerificationMethodECC == WeighInObservation.</xs:documentation>
               
               
               <xs:documentation source="MinOccurs">If this section doesn't apply, display only the section FieldText and the statement 'This section does not apply to this project.'</xs:documentation>
               
            
            </xs:annotation>
            
            
            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="I01">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Brazing of Refrigerant Lines</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">If refrigerant line connections require welding, the system is braised with dry nitrogen in lines and indoor coil</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I02">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Prior to Introducing Refrigerant</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">
                           <ns1:tab1/>
                            i. In all cases where the OEM instructions call for checking gas leaks with vacuum, prior to introducing refrigerant, system is evacuated to 500 microns or less and, when isolated, has risen no more than 300 microns after 5 minutes.
                           <ns1:line1/>
                           

                           <ns1:tab1/>
                            In all cases where the OEM instructions call for checking gas leaks with nitrogen gas, the system was pressurized to the manufacturer's specified  pressure and if the pressure could not be maintained, leaks were located and fixed.
                        </xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I03">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Prior to Introducing Refrigerant</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">Observation and documentation of the vacuum and pressurization tests are not required if no fittings (other than the fitting to the compressor) are compression or flare fittings</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I04">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Lineset Adjustment</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The calculated weight adjustment for lineset length is based on the length and diameter of the lineset</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I05">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Coil Adjustment</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The calculated weight adjustment for coil size is based on manufacturer instructions.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I06">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total Adjustment</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The actual total weight adjustment is equal to the sum of the calculated weight adjustment for lineset and coil size.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I07">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Total Weight Refrigerant</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">The calculated and actual total weights of refrigerant in the system are recorded on or near the nameplate label in indelible ink or other permanent means.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="I08_DoesSystemComplyWithRequirements">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Verification Status:</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from Pass or Fail</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">(Note: If Verification Status for this table indicates "Fail", the reason shall be described in the correction notes for this table.)</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                     
                     <xs:simpleType>
                        
                        
                        <xs:restriction base="comp:DoesSystemComplyWithRequirements">
                           
                           
                           <xs:enumeration value="Fail"/>
                           
                           
                           <xs:enumeration value="Pass"/>
                           
                        
                        </xs:restriction>
                        
                     
                     </xs:simpleType>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element minOccurs="0" name="I08a_SectionCorrectionNotes" type="comp:SectionCorrectionNotes">
                     
                     
