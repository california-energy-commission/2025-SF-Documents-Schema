                  <xs:element name="G06_MeasuredSuperheatWithinManufacturerSpec" type="comp:MeasuredSuperheatWithinManufacturerSpec">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Measured Superheat (Line G04) is within Manufacturer's Specifications ( if known)</xs:documentation>
                        
                        
                        <xs:documentation source="CalculationsAndRules">User selects from NotKnown, WithinManufacturerRange (Yes), or NotWithinManufacturerRange (No)</xs:documentation>
                        
                     
