            <xs:complexType>
               
               
               <xs:sequence>
                  
                  
                  <xs:element minOccurs="0" name="J_BeginNote1">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">Begin Note 1</xs:documentation>
                        
                        
                        <xs:documentation source="AdditionalRequirements">All applicable sections of this document shall indicate compliance with the specified verification protocol requirements in order for this Certificate of Verification as a whole to be determined to be in compliance.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
                  
                  <xs:element name="J01_DoesCF3R_Pass" type="comp:DoesCF3R_Pass">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText"/>
                        
                        
                        <xs:documentation source="CalculationsAndRules">If C03 IsDigitalRefrigerantGaugeCalibrationCurrent == true And C04 IsDigitalThermocoupleCalibrationCurrent == true And D01 MeasurementAccessHoleMethod != MAH_NotInstalledFailsToComply,  And E04_DoesSystemComplyWithAirflowRateVerification == true And If Present Fsh11_IsRefrigerantChargeSuperheatCompliant == true, Or Fsc09_IsRefrigerantChargeSubcoolingCompliant == true
 And If Present G07_IsMeteringDeviceVerificationCompliant == true And If Present H13_IsRefrigerantChargeWeighInCompliant == true And I08_DoesSystemComplyWithRequirements == Pass,  then result is true.  For Boolean true value display text This System Complies with all requirements.    Else result is false.  For Boolean false value display text;  This   System Does Not Comply.</xs:documentation>
                        
                     
                     </xs:annotation>
                     
                  
                  </xs:element>
                  
               
               </xs:sequence>
               
            
            </xs:complexType>
            
         
