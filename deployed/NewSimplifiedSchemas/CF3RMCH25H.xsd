                  <xs:element name="G05_IsMeasuredSuperheatWithinCEC_Range" type="comp:IsMeasuredSuperheatWithinCEC_Range">
                     
                     
                     <xs:annotation>
                        
                        
                        <xs:documentation source="FieldText">
